@model ForgotPasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot Password - Eventify Pro";
}

<main class="auth-container">
    <section class="auth-card" aria-labelledby="forgotPasswordTitle">
        <div class="auth-card-header">
            <span class="auth-kicker">Account Recovery</span>
            <h1 id="forgotPasswordTitle">Forgot Password?</h1>
            <p>Enter your email address and we'll send you a secure link to reset your password.</p>
        </div>

       
        @if (TempData["SuccessMessage"] is string message)
        {
            <div class="alert-success">@message</div>
        }

        <form asp-controller="Account" asp-action="ForgotPassword" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="input-group">
                <input asp-for="Email" id="email" placeholder=" " autocomplete="email" required />
                <label asp-for="Email">Email address</label>
                <span asp-validation-for="Email" class="field-validation"></span>
            </div>

            <p class="info-text">
                Make sure to enter the exact email address associated with your Eventify Pro account.
            </p>

            <div class="auth-actions" style="margin-top: 15px;">
                <a asp-controller="Account" asp-action="Login" class="link-btn">
                    <i class="fas fa-arrow-left" style="margin-right: 5px;"></i> Back to login
                </a>
                <button type="submit" class="primary-btn">Send Reset Link</button>
            </div>
        </form>
    </section>

    <aside class="auth-illustration" aria-hidden="true">
        <div class="illustration-content">
            <div class="floating-icons">
                <div class="floating-icon icon-1"><i class="fas fa-envelope"></i></div>
                <div class="floating-icon icon-2"><i class="fas fa-key"></i></div>
                <div class="floating-icon icon-3"><i class="fas fa-shield-alt"></i></div>
                <div class="floating-icon icon-4"><i class="fas fa-unlock-alt"></i></div>
                <div class="floating-icon icon-5"><i class="fas fa-user-lock"></i></div>
            </div>
            <div class="illustration-card">
                <div class="card-shine"></div>
                <i class="fas fa-unlock-alt main-icon"></i>
                <h2>Secure Recovery</h2>
                <p>Get back into your account quickly and securely to manage your events.</p>
            </div>
        </div>
    </aside>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}