@model EventifyPro.Web.ViewModels.Account.ResetPasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Reset Password - Eventify Pro";
}

<main class="auth-container">
    <section class="auth-card" aria-labelledby="resetPasswordTitle">
        <div class="auth-card-header">
            <span class="auth-kicker">New Credentials</span>
            <h1 id="resetPasswordTitle">Reset Password</h1>
            <p>Create a strong, secure password for your account.</p>
        </div>

        <form asp-controller="Account" asp-action="ResetPassword" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <div class="input-group">
                <input asp-for="NewPassword" id="newPassword" type="password" placeholder=" " autocomplete="new-password" required />
                <label asp-for="NewPassword">New Password</label>
                <span asp-validation-for="NewPassword" class="field-validation"></span>
            </div>

            <div class="input-group">
                <input asp-for="ConfirmPassword" id="confirmPassword" type="password" placeholder=" " autocomplete="new-password" required />
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <span asp-validation-for="ConfirmPassword" class="field-validation"></span>
            </div>

            <div class="auth-actions" style="margin-top: 15px;">
                <a asp-controller="Account" asp-action="Login" class="link-btn">
                    <i class="fas fa-arrow-left" style="margin-right: 5px;"></i> Back to login
                </a>
                <button type="submit" class="primary-btn">Reset Password</button>
            </div>
        </form>
    </section>

    <aside class="auth-illustration" aria-hidden="true">
        <div class="illustration-content">
            <div class="floating-icons">
                <div class="floating-icon icon-1"><i class="fas fa-envelope"></i></div>
                <div class="floating-icon icon-2"><i class="fas fa-key"></i></div>
                <div class="floating-icon icon-3"><i class="fas fa-shield-alt"></i></div>
                <div class="floating-icon icon-4"><i class="fas fa-unlock-alt"></i></div>
                <div class="floating-icon icon-5"><i class="fas fa-user-lock"></i></div>
            </div>
            <div class="illustration-card">
                <div class="card-shine"></div>
                <i class="fas fa-key main-icon"></i>
                <h2>Choose Wisely</h2>
                <p>Use a combination of upper/lowercase letters, numbers, and symbols for maximum security.</p>
            </div>
        </div>
    </aside>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
