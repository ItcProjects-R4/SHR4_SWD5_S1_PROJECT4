@model VerifyPasswordResetOtpViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Verify Reset Code - Eventify Pro";
}

<main class="auth-container">
    <section class="auth-card" aria-labelledby="confirmEmailTitle">
        <div class="auth-card-header">
            <span class="auth-kicker">Password Recovery</span>
            <h1 id="confirmEmailTitle">Verify Recovery Code</h1>
            <p>We've sent a 6-character verification code to <strong style="color: var(--primary);">@Model.Email</strong>. Please enter it below.</p>
        </div>

        @if (TempData["SuccessMessage"] is string message)
        {
            <div class="alert-success" style="margin-bottom: 20px; padding: 12px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); border-radius: 8px; color: #10b981; font-size: 14px; font-weight: 500;">
                <i class="fas fa-check-circle" style="margin-right: 6px;"></i> @message
            </div>
        }

        @if (TempData["ErrorMessage"] is string errorMsg)
        {
            <div class="alert-danger" style="margin-bottom: 20px; padding: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 8px; color: #ef4444; font-size: 14px; font-weight: 500;">
                <i class="fas fa-exclamation-circle" style="margin-right: 6px;"></i> @errorMsg
            </div>
        }

        <form asp-controller="Account" asp-action="VerifyPasswordResetOtp" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary" style="color: #ef4444; font-size: 14px; margin-bottom: 16px; font-weight: 500;"></div>

            <!-- Keep track of Email -->
            <input type="hidden" asp-for="Email" />

            <div class="input-group">
                <input asp-for="OtpCode" id="otpCode" placeholder=" " maxlength="6" pattern="^[a-zA-Z0-9]{6}$" required autocomplete="one-time-code" autofocus style="text-transform: uppercase;" />
                <label asp-for="OtpCode">6-Character Verification Code</label>
                <span asp-validation-for="OtpCode" class="field-validation" style="color: #ef4444; font-size: 12px; margin-top: 4px; display: block;"></span>
            </div>

            <div class="auth-actions" style="margin-top: 24px;">
                <button type="submit" class="primary-btn" style="width: 100%; justify-content: center;">
                    Verify Code <i class="fas fa-check" style="margin-left: 8px;"></i>
                </button>
            </div>
        </form>

        <div style="display: flex; flex-direction: column; gap: 20px; align-items: center; margin-top: 24px;">
            <div class="divider" style="width: 100%; margin: 10px 0;">
                <span>Didn't receive the code?</span>
            </div>

            <div id="timer-section" style="text-align: center;">
                <p class="info-text" id="timer-text" style="margin-bottom: 0; font-size: 14px; color: var(--text-muted);">
                    You can request a new code in <strong id="timer" style="color: var(--primary); font-size: 16px;">02:00</strong>
                </p>

                <form asp-controller="Account" asp-action="ResendPasswordResetOtp" method="post" id="resend-form" style="display: none;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Email" value="@Model.Email" />
                    <button type="submit" class="link-btn" style="background: none; border: none; cursor: pointer; font-size: 15px; font-weight: 600; color: var(--primary);">
                        <i class="fas fa-sync-alt" style="margin-right: 5px;"></i> Resend Code
                    </button>
                </form>
            </div>

            <a asp-controller="Account" asp-action="Login" class="link-btn" style="margin-top: 10px; font-size: 14px;">
                <i class="fas fa-arrow-left" style="margin-right: 5px;"></i> Back to login
            </a>
        </div>
    </section>

    <aside class="auth-illustration" aria-hidden="true">
        <div class="illustration-content">
            <div class="floating-icons">
                <div class="floating-icon icon-1"><i class="fas fa-paper-plane"></i></div>
                <div class="floating-icon icon-2"><i class="fas fa-envelope-open-text"></i></div>
                <div class="floating-icon icon-3"><i class="fas fa-lock"></i></div>
                <div class="floating-icon icon-4"><i class="fas fa-user-check"></i></div>
                <div class="floating-icon icon-5"><i class="fas fa-shield-alt"></i></div>
            </div>
            <div class="illustration-card">
                <div class="card-shine"></div>
                <i class="fas fa-key main-icon" style="color: #8A2BE2; font-size: 4rem; margin-bottom: 20px; display: inline-block;"></i>
                <h2>Verify OTP!</h2>
                <p>Check your email for the 6-character code to unlock password reset.</p>
            </div>
        </div>
    </aside>
</main>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let timeLeft = 120;
            const timerElement = document.getElementById("timer");
            const timerText = document.getElementById("timer-text");
            const resendForm = document.getElementById("resend-form");

            const countdown = setInterval(function () {
                timeLeft--;

                let minutes = Math.floor(timeLeft / 60);
                let seconds = timeLeft % 60;

                let formattedTime =
                    (minutes < 10 ? "0" + minutes : minutes) + ":" +
                    (seconds < 10 ? "0" + seconds : seconds);

                if (timerElement) {
                    timerElement.textContent = formattedTime;
                }

                if (timeLeft <= 0) {
                    clearInterval(countdown);
                    if (timerText) timerText.style.display = "none";
                    if (resendForm) resendForm.style.display = "block";
                }
            }, 1000);

            // Automatically uppercase the OTP code input
            const otpInput = document.getElementById("otpCode");
            if (otpInput) {
                otpInput.addEventListener("input", function() {
                    this.value = this.value.toUpperCase();
                });
            }
        });
    </script>
}
