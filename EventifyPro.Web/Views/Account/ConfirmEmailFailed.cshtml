@model string
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Email Verification Failed - Eventify Pro";
}

<main class="auth-container">
    <section class="auth-card" aria-labelledby="confirmFailedTitle">
        <div class="auth-card-header" style="text-align: center;">
            <span class="auth-kicker" style="background: #fee2e2; color: #b91c1c;">Error</span>
            <h1 id="confirmFailedTitle" style="font-size: 32px; margin-bottom: 15px;">Verification Failed</h1>
            <p>We couldn't verify your email address. The confirmation link might be invalid, expired, or has already been used.</p>
        </div>

        <div style="display: flex; flex-direction: column; gap: 24px; align-items: center; margin-top: 10px; width: 100%;">
            <div style="width: 80px; height: 80px; border-radius: 50%; background: #fee2e2; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-times" style="color: #dc2626; font-size: 38px;"></i>
            </div>

            @if (!string.IsNullOrEmpty(Model))
            {
                <div class="validation-summary" style="width: 100%; text-align: center;">
                    @Model
                </div>
            }

            <a asp-controller="Account" asp-action="Login" class="primary-btn" style="width: 100%; text-align: center; display: inline-flex; justify-content: center; align-items: center; min-height: 50px;">
                Back to Login
            </a>
        </div>
    </section>

    <aside class="auth-illustration" aria-hidden="true">
        <div class="illustration-content">
            <div class="floating-icons">
                <div class="floating-icon icon-1"><i class="fas fa-exclamation-triangle"></i></div>
                <div class="floating-icon icon-2"><i class="fas fa-times"></i></div>
                <div class="floating-icon icon-3"><i class="fas fa-envelope"></i></div>
                <div class="floating-icon icon-4"><i class="fas fa-unlink"></i></div>
                <div class="floating-icon icon-5"><i class="fas fa-shield-alt"></i></div>
            </div>
            <div class="illustration-card">
                <div class="card-shine" style="background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), transparent 70%);"></div>
                <i class="fas fa-exclamation-triangle main-icon" style="color: #dc2626;"></i>
                <h2>Link Invalid</h2>
                <p>Try logging in. If your account is not verified, a new link will be sent automatically.</p>
            </div>
        </div>
    </aside>
</main>
