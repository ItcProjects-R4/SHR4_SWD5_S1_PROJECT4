@model LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Sign In - Eventify Pro";
}

<main class="auth-container">
    <section class="auth-card" aria-labelledby="loginTitle">
        <div class="auth-card-header">
            <span class="auth-kicker">Welcome back</span>
            <h1 id="loginTitle">Sign in</h1>
            <p>Access your tickets, events, and scanner tools.</p>
        </div>

        @if (TempData["SuccessMessage"] is string message)
        {
            <div class="alert-success">@message</div>
        }

        <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="input-group">
                <input asp-for="Email" id="email" placeholder=" " autocomplete="email" required />
                <label asp-for="Email">Email address</label>
                <span asp-validation-for="Email" class="field-validation"></span>
            </div>

            <div class="input-group">
                <input asp-for="Password" id="password" placeholder=" " autocomplete="current-password" required />
                <label asp-for="Password">Password</label>
                <button type="button" class="show-password" data-toggle-password="password" aria-label="Show password">
                    <i class="fas fa-eye"></i>
                </button>
                <span asp-validation-for="Password" class="field-validation"></span>
            </div>

            <div class="auth-row">
                <label class="remember-me">
                    <input asp-for="RememberMe" />
                    <span>Remember me</span>
                </label>
                <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-link">Forgot password?</a>
            </div>

            <div class="auth-actions">
                <a asp-controller="Account" asp-action="Register" class="link-btn">Create account</a>
                <button type="submit" class="primary-btn">Sign In</button>
            </div>
        </form>

        <div class="divider">
            <span>or continue with</span>
        </div>

        <div class="social-buttons">
            <button class="social-btn" type="button">
                <svg class="brand-icon google-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                    <path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.84z" />
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06L5.84 9.9C6.71 7.3 9.14 5.38 12 5.38z" />
                </svg>
                Google
            </button>
            <button class="social-btn" type="button">
                <svg class="brand-icon microsoft-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path fill="#F25022" d="M2 2h9.5v9.5H2V2z" />
                    <path fill="#7FBA00" d="M12.5 2H22v9.5h-9.5V2z" />
                    <path fill="#00A4EF" d="M2 12.5h9.5V22H2v-9.5z" />
                    <path fill="#FFB900" d="M12.5 12.5H22V22h-9.5v-9.5z" />
                </svg>
                Microsoft
            </button>
        </div>
    </section>

    <aside class="auth-illustration" aria-hidden="true">
        <div class="illustration-content">
            <div class="floating-icons">
                <div class="floating-icon icon-1"><i class="fas fa-ticket-alt"></i></div>
                <div class="floating-icon icon-2"><i class="fas fa-qrcode"></i></div>
                <div class="floating-icon icon-3"><i class="fas fa-music"></i></div>
                <div class="floating-icon icon-4"><i class="fas fa-calendar-check"></i></div>
                <div class="floating-icon icon-5"><i class="fas fa-star"></i></div>
            </div>
            <div class="illustration-card">
                <div class="card-shine"></div>
                <i class="fas fa-ticket-alt main-icon"></i>
                <h2>Welcome Back!</h2>
                <p>Pick up where you left off and keep your events moving.</p>
            </div>
        </div>
    </aside>
</main>

@section Scripts {
    <script>
        document.querySelectorAll("[data-toggle-password]").forEach((button) => {
          button.addEventListener("click", () => {
            const input = document.getElementById(button.dataset.togglePassword);
            const icon = button.querySelector("i");

            if (!input || !icon) return;

            const showPassword = input.type === "password";
            input.type = showPassword ? "text" : "password";
            icon.className = showPassword ? "fas fa-eye-slash" : "fas fa-eye";
            button.setAttribute("aria-label", showPassword ? "Hide password" : "Show password");
          });
        });
    </script>
    <partial name="_ValidationScriptsPartial" />
}
