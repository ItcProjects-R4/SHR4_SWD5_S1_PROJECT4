@model HomeIndexViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Eventify Pro - Smart Event Management Platform";
}

<section class="hero" id="home">
    <div class="hero-slideshow">
        <div class="hero-slide active" style="background-image: url('@Url.Content("~/Images/Home/Home1.png")')"></div>
        <div class="hero-slide" style="background-image: url('@Url.Content("~/Images/Home/Home2.png")')"></div>
        <div class="hero-slide" style="background-image: url('@Url.Content("~/Images/Home/Home3.png")')"></div>
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-container">
        <div class="hero-content">
            <div class="hero-badge">
                <i class="fas fa-bolt"></i>
                <span>#1 Event Management Platform</span>
            </div>
            <h1 class="hero-title">
                Create <span class="gradient-text">Unforgettable</span> <br />Events
                Effortlessly
            </h1>
            <p class="hero-description">
                The complete platform for creating and managing events, concerts,
                conferences, and workshops. Sell tickets online and verify them with
                QR Code seamlessly.
            </p>
            <div class="hero-buttons">
                <a asp-controller="Account" asp-action="Register" class="btn-primary btn-large">
                    <i class="fas fa-rocket"></i> Start Free Trial
                </a>
                <a href="#" class="btn-outline btn-large" id="watchDemoBtn">
                    <i class="fas fa-play-circle"></i> Watch Demo
                </a>
            </div>
            <div class="hero-stats">
                <div class="stat-item">
                    <h3 class="counter" data-target="50000">0</h3>
                    <p>Tickets Sold</p>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <h3 class="counter" data-target="2500">0</h3>
                    <p>Active Organizers</p>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <h3 class="counter" data-target="850">0</h3>
                    <p>Successful Events</p>
                </div>
            </div>
        </div>
        <div class="hero-visual">
            <div class="hero-card card-main">
                <div class="card-image">
                    <i class="fas fa-music"></i>
                    <div class="card-tag">VIP</div>
                </div>
                <div class="card-content">
                    <h4>Summer Music Festival 2026</h4>
                    <div class="card-info">
                        <span><i class="fas fa-calendar"></i> June 15</span>
                        <span><i class="fas fa-map-marker-alt"></i> Cairo</span>
                    </div>
                    <div class="card-footer">
                        <span class="price">$50</span>
                        <button class="btn-book">Book Now</button>
                    </div>
                </div>
            </div>
            <div class="hero-card card-floating card-1">
                <i class="fas fa-qrcode"></i>
                <div>
                    <h5>QR Code</h5>
                    <p>Secure Ticket</p>
                </div>
            </div>
            <div class="hero-card card-floating card-2">
                <i class="fas fa-check-circle"></i>
                <div>
                    <h5>Payment Done</h5>
                    <p>Successfully</p>
                </div>
            </div>
            <div class="hero-card card-floating card-3">
                <i class="fas fa-users"></i>
                <div>
                    <h5>+1,250</h5>
                    <p>Confirmed</p>
                </div>
            </div>
        </div>
    </div>
    <div class="hero-slideshow-dots">
        <button class="hero-slideshow-dot active" aria-label="Slide 1"></button>
        <button class="hero-slideshow-dot" aria-label="Slide 2"></button>
        <button class="hero-slideshow-dot" aria-label="Slide 3"></button>
    </div>

</section>

<section class="features section" id="features">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Features</span>
            <h2>
                Everything You Need <span class="gradient-text">in One Place</span>
            </h2>
            <p>
                Powerful and smart tools to manage your events from start to finish
            </p>
        </div>
        <div class="features-grid">
            <div class="feature-card reveal">
                <div class="feature-icon icon-1">
                    <i class="fas fa-calendar-plus"></i>
                </div>
                <h3>Event Creation</h3>
                <p>
                    Create professional events easily with full customization for
                    details, images.
                </p>
                <a href="#" class="feature-link" data-feature="event-creation">
                    Learn More <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="feature-card reveal">
                <div class="feature-icon icon-2">
                    <i class="fas fa-ticket-alt"></i>
                </div>
                <h3>Multiple Ticket Types</h3>
                <p>
                    Create VIP, regular, or free tickets with different prices and
                    features for each type
                </p>
                <a href="#" class="feature-link" data-feature="ticket-types">
                    Learn More <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="feature-card reveal">
                <div class="feature-icon icon-3"><i class="fas fa-qrcode"></i></div>
                <h3>Secure QR Code</h3>
                <p>
                    Each ticket has a unique encrypted QR Code that prevents fraud and
                    reuse
                </p>
                <a href="#" class="feature-link" data-feature="qr-code">
                    Learn More <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="feature-card reveal">
                <div class="feature-icon icon-4">
                    <i class="fas fa-credit-card"></i>
                </div>
                <h3>Secure Payments</h3>
                <p>
                    Stripe integration for secure online payments with support for all
                    major cards
                </p>
                <a href="#" class="feature-link" data-feature="payments">
                    Learn More <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="feature-card reveal">
                <div class="feature-icon icon-5">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h3>Smart Dashboard</h3>
                <p>
                    Track sales, statistics, and attendance in real-time with an
                    easy-to-use interface
                </p>
                <a href="#" class="feature-link" data-feature="dashboard">
                    Learn More <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="feature-card reveal">
                <div class="feature-icon icon-6">
                    <i class="fas fa-envelope-open-text"></i>
                </div>
                <h3>Auto Notifications</h3>
                <p>
                    Send booking confirmations and reminders to attendees via email
                    automatically
                </p>
                <a href="#" class="feature-link" data-feature="notifications">
                    Learn More <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</section>

<section class="how-it-works section" id="how">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">How It Works</span>
            <h2>
                4 Simple Steps to <span class="gradient-text">Event Success</span>
            </h2>
            <p>
                From creation to event day, we're with you every step of the way
            </p>
        </div>
        <div class="steps-container">
            <div class="step-line"></div>
            <div class="step reveal">
                <div class="step-number">1</div>
                <div class="step-icon"><i class="fas fa-pen-fancy"></i></div>
                <h3>Create Your Event</h3>
                <p>
                    Add details, images, location, and define ticket types and prices
                </p>
            </div>
            <div class="step reveal">
                <div class="step-number">2</div>
                <div class="step-icon"><i class="fas fa-share-alt"></i></div>
                <h3>Share with Audience</h3>
                <p>Users browse events and book tickets effortlessly</p>
            </div>
            <div class="step reveal">
                <div class="step-number">3</div>
                <div class="step-icon"><i class="fas fa-money-bill-wave"></i></div>
                <h3>Receive Payments</h3>
                <p>Secure payments via Stripe and QR tickets sent automatically</p>
            </div>
            <div class="step reveal">
                <div class="step-number">4</div>
                <div class="step-icon"><i class="fas fa-check-double"></i></div>
                <h3>Verify at Entry</h3>
                <p>Scanner verifies QR Code instantly to validate tickets</p>
            </div>
        </div>
    </div>
</section>

<section class="roles section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Users</span>
            <h2>A Platform <span class="gradient-text">for Everyone</span></h2>
            <p>Four types of users, each with their own special permissions</p>
        </div>
        <div class="roles-grid">
            <div class="role-card reveal">
                <div class="role-avatar"><i class="fas fa-user-shield"></i></div>
                <h3>Admin</h3>
                <p>Complete system management and full control</p>
                <ul>
                    <li><i class="fas fa-check"></i> Manage Users</li>
                    <li><i class="fas fa-check"></i> System Monitoring</li>
                    <li><i class="fas fa-check"></i> Full Analytics</li>
                </ul>
            </div>
            <div class="role-card reveal">
                <div class="role-avatar"><i class="fas fa-user-tie"></i></div>
                <h3>Organizer</h3>
                <p>Create and manage events and sell tickets</p>
                <ul>
                    <li><i class="fas fa-check"></i> Create Events</li>
                    <li><i class="fas fa-check"></i> Manage Tickets</li>
                    <li><i class="fas fa-check"></i> Track Sales</li>
                </ul>
            </div>
            <div class="role-card reveal">
                <div class="role-avatar"><i class="fas fa-user"></i></div>
                <h3>Attendee</h3>
                <p>Browse events and book tickets easily</p>
                <ul>
                    <li><i class="fas fa-check"></i> Browse Events</li>
                    <li><i class="fas fa-check"></i> Book Tickets</li>
                    <li><i class="fas fa-check"></i> My Tickets</li>
                </ul>
            </div>
            <div class="role-card reveal">
                <div class="role-avatar"><i class="fas fa-qrcode"></i></div>
                <h3>Scanner</h3>
                <p>Verify tickets at event entrance</p>
                <ul>
                    <li><i class="fas fa-check"></i> Scan QR Code</li>
                    <li><i class="fas fa-check"></i> Instant Verify</li>
                    <li><i class="fas fa-check"></i> Update Status</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="landing-feedback section enhanced-bg-glow" id="feedback">
    <div class="container">
        <div class="section-header">
            <span class="section-tag-enhanced"><i class="fas fa-comments"></i> Testimonials</span>
            <h2>What Users <span class="gradient-text">Say About Us</span></h2>
            <p>Authentic reviews from Attendees, Organizers, and gate Scanners using Eventify Pro.</p>
        </div>

        @if (Model.ApprovedFeedback.Any())
        {
            <div class="feedback-carousel-enhanced" data-feedback-carousel data-page-size="3">
                <div class="landing-feedback-grid-enhanced">
                    @foreach (var feedback in Model.ApprovedFeedback)
                    {
                        string displayName = feedback.DisplayName ?? "User";
                        string initials = displayName.Length > 0 ? displayName.Substring(0, 1).ToUpper() : "U";

                        <article class="landing-feedback-card-enhanced" data-feedback-card>
                            <div>
                                <div class="testimonial-rating">
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                </div>
                                <p>"@feedback.Message"</p>
                            </div>
                            <div class="feedback-author-enhanced">
                                <div class="feedback-avatar-gradient">
                                    @initials
                                </div>
                                <div class="feedback-author-info">
                                    <h3>@feedback.DisplayName</h3>
                                    <span>@feedback.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                        </article>
                    }
                </div>

                <div class="carousel-controls-enhanced">
                    <button type="button" class="btn-nav-enhanced" data-feedback-prev aria-label="Previous feedback">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                    <div class="carousel-dots" data-feedback-dots>
                        <!-- Dots will be dynamically generated by Javascript -->
                    </div>
                    <button type="button" class="btn-nav-enhanced" data-feedback-next aria-label="Next feedback">
                        <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="landing-feedback-empty-enhanced">
                <i class="fas fa-comment-dots"></i>
                <p>No approved reviews yet. Be the first to share your ticketing experience!</p>
                <a asp-controller="Home" asp-action="Feedback" class="btn-primary">Write a Review <i class="fas fa-arrow-right"></i></a>
            </div>
        }
    </div>
</section>

<section class="cta section">
    <div class="container">
        <div class="cta-box">
            <div class="cta-content">
                <h2>
                    Ready to Launch Your
                    <span class="gradient-text">Next Event?</span>
                </h2>
                <p>
                    Join thousands of successful organizers and create unforgettable
                    events
                </p>
                <div class="cta-buttons">
                    <a asp-controller="Account" asp-action="Register" class="btn-primary btn-large">
                        <i class="fas fa-rocket"></i> Start Free
                    </a>
                    <a asp-controller="Home" asp-action="HelpCenter" class="btn-outline btn-large">
                        <i class="fas fa-phone"></i> Contact Us
                    </a>
                </div>
            </div>
            <div class="cta-decoration">
                <i class="fas fa-ticket-alt"></i>
            </div>
