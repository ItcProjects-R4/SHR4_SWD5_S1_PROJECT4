@model EventifyPro.Web.ViewModels.Admin.AdminNotificationViewModel
@using Eventify.Domain.Enums
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Notifications Center";
    ViewData["HeaderTitle"] = "Notifications Center 📢";
    ViewData["HeaderSubtitle"] = "Send system-wide announcements or targeted alerts to specific users.";
}

@section Styles {
    <style>
        /* ===== Grid Layout ===== */
        .settings-grid {
            display: grid;
            grid-template-columns: 1.2fr 1.8fr;
            gap: 32px;
            align-items: start;
        }
        @@media (max-width: 992px) {
            .settings-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ===== Cards ===== */
        .card {
            background: white;
            border-radius: 20px;
            padding: 32px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
            margin-bottom: 32px;
        }
        .card-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text);
        }
        .card-title i {
            color: var(--primary);
        }

        /* ===== Form Controls ===== */
        .form-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-light);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid var(--border);
            border-radius: 12px;
            font-family: inherit;
            font-size: 14px;
            color: var(--text);
            background: var(--soft-purple);
            outline: none;
            transition: var(--transition);
        }
        .form-control:focus {
            border-color: var(--primary);
            background: white;
            box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.1);
        }
        textarea.form-control {
            resize: vertical;
            min-height: 120px;
        }
        .text-danger {
            color: var(--error);
            font-size: 12px;
            margin-top: 6px;
            display: block;
            font-weight: 500;
        }

        label .text-danger {
            display: inline;
            margin-top: 0;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 12px 28px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: var(--transition);
            border: none;
            font-family: inherit;
            width: 100%;
        }
        .btn-primary {
            background: var(--gradient);
            color: white;
            box-shadow: 0 4px 12px rgba(124, 58, 237, 0.25);
        }
        .btn-primary:hover {
            box-shadow: 0 8px 24px rgba(124, 58, 237, 0.4);
            transform: translateY(-2px);
        }

        /* ===== Table ===== */
        .table-responsive {
            overflow-x: auto;
        }
        .custom-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }
        .custom-table th {
            padding: 16px 20px;
            font-size: 12px;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--text-light);
            border-bottom: 2px solid var(--border);
            letter-spacing: 0.5px;
        }
        .custom-table td {
            padding: 18px 20px;
            font-size: 13.5px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
            vertical-align: middle;
        }
        .custom-table tr:last-child td {
            border-bottom: none;
        }
        .custom-table tr:hover td {
            background-color: var(--soft-purple);
        }

        /* ===== Notification Badges & Tags ===== */
        .notif-tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            border-radius: 50px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
        }
        .notif-tag.maintenance {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
        }
        .notif-tag.systemupdate {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }
        .notif-tag.customalert {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning);
        }
        
        .recipient-badge {
            background: var(--light-purple);
            color: var(--primary-dark);
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 500;
        }

        .text-truncate-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 250px;
            line-height: 1.4;
        }

        .no-data {
            padding: 40px;
            text-align: center;
            color: var(--text-light);
        }
        .no-data i {
            font-size: 40px;
            margin-bottom: 12px;
            color: var(--accent);
            opacity: 0.5;
        }
    </style>
}

<div asp-validation-summary="All" class="text-danger" style="margin-bottom: 24px; padding: 16px; border-radius: 12px; background: rgba(239, 68, 68, 0.05); display: @(ViewData.ModelState.IsValid ? "none" : "block")"></div>

<!-- Dashboard Grid -->
<div class="settings-grid">
    <!-- Send Notification Form Card -->
    <div class="card">
        <div class="card-title">
            <i class="fas fa-paper-plane"></i>
            <span>Send Announcement</span>
        </div>

        <form action="/Admin/SendNotification" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="IsSystemWide">Scope</label>
                <select class="form-control" id="IsSystemWide" name="IsSystemWide">
                    <option value="true" selected="@(Model.IsSystemWide ? "selected" : null)">System-Wide (All Users)</option>
                    <option value="false" selected="@(!Model.IsSystemWide ? "selected" : null)">Specific User</option>
                </select>
            </div>

            <div class="form-group" id="recipientEmailGroup" style="display: none;">
                <label for="RecipientEmail">Recipient Email</label>
                <input type="email" class="form-control" id="RecipientEmail" name="RecipientEmail" value="@Model.RecipientEmail" placeholder="user@example.com" />
                <span asp-validation-for="RecipientEmail" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="Type">Notification Type</label>
                <select class="form-control" id="Type" name="Type">
                    <option value="SystemUpdate" selected="@(Model.Type == NotificationType.SystemUpdate ? "selected" : null)">⚙️ System Update</option>
                    <option value="Maintenance" selected="@(Model.Type == NotificationType.Maintenance ? "selected" : null)">🔧 Planned Maintenance</option>
                    <option value="CustomAlert" selected="@(Model.Type == NotificationType.CustomAlert ? "selected" : null)">🔔 Custom Alert</option>
                </select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="Title">Title</label>
                <input type="text" class="form-control" id="Title" name="Title" value="@Model.Title" required placeholder="Enter notification title..." />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="Message">Message</label>
                <textarea class="form-control" id="Message" name="Message" required placeholder="Write details here...">@Model.Message</textarea>
                <span asp-validation-for="Message" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="RedirectUrl">Action Link (Optional)</label>
                <input type="text" class="form-control" id="RedirectUrl" name="RedirectUrl" value="@Model.RedirectUrl" placeholder="/Attendee/Dashboard or custom relative URL" />
                <span asp-validation-for="RedirectUrl" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="margin-top: 10px;">
                <i class="fas fa-paper-plane"></i> Send Notification
            </button>
        </form>
    </div>

    <!-- Sent Notification History Card -->
    <div class="card" style="padding-bottom: 16px;">
        <div class="card-title">
            <i class="fas fa-history"></i>
            <span>Recent Sent Announcements</span>
        </div>

        <div class="table-responsive">
            @if (!Model.SentNotifications.Any())
            {
                <div class="no-data">
                    <i class="fa-regular fa-bell-slash"></i>
                    <p>No announcements sent recently.</p>
                </div>
            }
            else
            {
                <table class="custom-table">
                   <thead>
                       <tr>
                           <th>Type</th>
                           <th>Content</th>
                           <th>Recipient</th>
                           <th>Sent At</th>
                       </tr>
                   </thead>
                   <tbody>
                       @foreach (var notification in Model.SentNotifications)
                       {
                           string tagClass = "customalert";
                           string emoji = "🔔";
                           switch (notification.Type)
                           {
                               case NotificationType.Maintenance:
                                   tagClass = "maintenance";
                                   emoji = "🔧";
                                   break;
                               case NotificationType.SystemUpdate:
                                   tagClass = "systemupdate";
                                   emoji = "⚙️";
                                   break;
                           }

                           <tr>
                               <td>
                                   <span class="notif-tag @tagClass">
                                       @emoji @notification.Type.ToString()
                                   </span>
                               </td>
                               <td>
                                   <strong style="display: block; font-size: 13.5px; margin-bottom: 2px;">@notification.Title</strong>
                                   <span class="text-truncate-2" title="@notification.Message">@notification.Message</span>
                               </td>
                               <td>
                                   <span class="recipient-badge">
                                       @notification.Recipient
                                   </span>
                               </td>
                               <td style="font-size: 12px; color: var(--text-light); white-space: nowrap;">
                                   @notification.CreatedAt.ToEgyptTime().ToString("MMM dd, hh:mm tt")
                               </td>
                           </tr>
                       }
                   </tbody>
                </table>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const isSystemWideSelect = document.getElementById("IsSystemWide");
            const recipientEmailGroup = document.getElementById("recipientEmailGroup");

            function toggleRecipientField() {
                if (isSystemWideSelect.value === "true") {
                    recipientEmailGroup.style.display = "none";
                    document.getElementById("RecipientEmail").removeAttribute("required");
                } else {
                    recipientEmailGroup.style.display = "block";
                    document.getElementById("RecipientEmail").setAttribute("required", "required");
                }
            }

            isSystemWideSelect.addEventListener("change", toggleRecipientField);
            toggleRecipientField();
        });
    </script>
}
