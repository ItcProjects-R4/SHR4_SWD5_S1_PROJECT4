@{
    Layout = null;
}

<style>
    /* الصفحة بالكامل */
    .scanner-page-content {
        min-height: 100vh;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 20px;
        background: linear-gradient(135deg, #f5f7ff 0%, #eef2ff 100%);
    }

    /* الكارد */
    .welcome-container {
        width: 100%;
        max-width: 750px;
        text-align: center;
        background: #ffffff;
        padding: 70px 50px;
        border-radius: 28px;
        box-shadow: 0 10px 30px rgba(138, 43, 226, 0.12), 0 2px 10px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(138, 43, 226, 0.08);
        transition: transform 0.3s ease;
    }

        .welcome-container:hover {
            transform: translateY(-4px);
        }

    /* العنوان */
    .welcome-title {
        color: #8A2BE2;
        font-size: clamp(3rem, 6vw, 5rem);
        font-weight: 800;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 4px;
        line-height: 1.1;
    }

    /* النص الصغير */
    .welcome-subtitle {
        color: #666;
        font-size: 1.4rem;
        margin-top: 18px;
        font-weight: 500;
        line-height: 1.6;
    }

    /* للموبايل */
    @@media (max-width: 768px) {
        .welcome-container {
            padding: 50px 25px;
            border-radius: 22px;
        }

        .welcome-subtitle {
            font-size: 1.1rem;
        }
    }
</style>


<div class="scanner-page-content">
    <div class="welcome-container">
        <h1 class="welcome-title">Welcome Admin</h1>
        <p class="welcome-subtitle">Here is your dashboard overview.</p>
    </div>
</div>