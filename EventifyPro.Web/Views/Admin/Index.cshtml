@model EventifyPro.Web.ViewModels.Admin.AdminDashboardViewModel
@inject Microsoft.AspNetCore.Identity.UserManager<Eventify.Domain.Entities.ApplicationUser> UserManager
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Dashboard";
    ViewData["HeaderTitle"] = "Admin Dashboard 🛡️";
    ViewData["HeaderSubtitle"] = "System overview and management";
}

@section Styles {
    <style>
        /* ===== STATS CARDS ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
        }
        .stat-card {
            background: white;
            padding: 24px;
            border-radius: 20px;
            display: flex;
            gap: 16px;
            align-items: flex-start;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }
        .stat-card::before {
            content: "";
            position: absolute;
            top: 0;
            right: 0;
            width: 100px;
            height: 100px;
            background: var(--soft-purple);
            border-radius: 50%;
            transform: translate(40px, -40px);
            opacity: 0.5;
            transition: var(--transition);
        }
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-md);
        }
        .stat-card:hover::before {
            transform: translate(30px, -30px) scale(1.2);
        }

        .stat-icon {
            width: 56px;
            height: 56px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 22px;
            flex-shrink: 0;
            position: relative;
            z-index: 1;
            transition: var(--transition);
        }
        .stat-card:hover .stat-icon {
            transform: rotate(-8deg) scale(1.05);
        }
        .icon-purple {
            background: linear-gradient(135deg, #5b21b6, #7c3aed);
        }
        .icon-pink {
            background: linear-gradient(135deg, #ec4899, #f472b6);
        }
        .icon-blue {
            background: linear-gradient(135deg, #3b82f6, #60a5fa);
        }
        .icon-green {
            background: linear-gradient(135deg, #10b981, #34d399);
        }

        .stat-info {
            position: relative;
            z-index: 1;
        }
        .stat-info p {
            font-size: 13px;
            color: var(--text-light);
            margin-bottom: 4px;
            font-weight: 500;
        }
        .stat-info h3 {
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 6px;
            color: var(--text);
        }

        /* ===== TABS ===== */
        .tab-btn {
            background: transparent;
            color: var(--text-light);
            border: 1px solid transparent;
        }
        .tab-btn.active {
            background: var(--soft-purple) !important;
            color: var(--primary) !important;
            border-color: var(--border) !important;
        }

        .tab-panel {
            animation: fadeIn 0.4s ease;
        }
        
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ===== TABLE CARD ===== */
        .table-card {
            background: white;
            padding: 28px;
            border-radius: 20px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
            overflow-x: auto;
        }
        .data-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 700px;
        }
        .data-table thead {
            border-bottom: 2px solid var(--border);
        }
        .data-table th {
            padding: 14px 12px;
            text-align: left;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .data-table td {
            padding: 16px 12px;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }
        .data-table tbody tr {
            transition: var(--transition);
        }
        .data-table tbody tr:hover {
            background: var(--soft-purple);
        }
        .data-table tbody tr:last-child td {
            border-bottom: none;
        }

        /* Status & Role Tags */
        .role-tag {
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 700;
        }
        .role-tag.organizer {
            background: rgba(124, 58, 237, 0.1);
            color: var(--primary);
        }
        .role-tag.attendee {
            background: rgba(59, 130, 246, 0.1);
            color: #3b82f6;
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 12px 28px;
            border-radius: 50px;
            font-family: inherit;
            font-weight: 600;
            font-size: 15px;
            cursor: pointer;
            border: none;
            transition: var(--transition);
            background: var(--gradient);
            color: var(--white);
            box-shadow: 0 8px 25px rgba(124, 58, 237, 0.35);
            text-decoration: none;
        }
        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(124, 58, 237, 0.5);
        }
        .btn-small {
            padding: 8px 18px;
            font-size: 13px;
        }
        .btn-full {
            width: 100%;
            justify-content: center;
        }

        /* Modal styling */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .modal-overlay.active {
            display: flex;
        }
        .modal-card {
            background: white;
            border-radius: 20px;
            width: 90%;
            max-width: 480px;
            padding: 28px;
            box-shadow: var(--shadow-lg);
            position: relative;
        }

        /* Floating Bulk Bar */
        .bulk-bar {
            position: fixed;
            bottom: -100px;
            left: 50%;
            transform: translateX(-50%);
            width: 90%;
            max-width: 700px;
            background: white;
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 16px 24px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
            z-index: 999;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            opacity: 0;
            pointer-events: none;
        }
        .bulk-bar.active {
            bottom: 24px;
            opacity: 1;
            pointer-events: auto;
        }
        .bulk-bar-content {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            flex-wrap: wrap;
        }
        .bulk-bar-info {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            font-weight: 600;
            color: var(--text);
        }
        .bulk-bar-buttons {
            display: flex;
            gap: 8px;
        }
        .btn-bulk {
            padding: 8px 16px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 13px;
            cursor: pointer;
            border: none;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .btn-bulk.approve {
            background: var(--success);
            color: white;
        }
        .btn-bulk.approve:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }
        .btn-bulk.cancel {
            background: var(--soft-purple);
            color: var(--primary);
        }
        .btn-bulk.cancel:hover {
            background: var(--light-purple);
        }
    </style>
}

<!-- Stats Grid -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon icon-purple">
            <i class="fas fa-hourglass-half"></i>
        </div>
        <div class="stat-info">
            <p>Pending Organizers</p>
            <h3>@Model.PendingOrganizers.Count</h3>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon icon-green">
            <i class="fas fa-check-double"></i>
        </div>
        <div class="stat-info">
            <p>Verified Organizers</p>
            <h3>@Model.VerifiedOrganizers.Count</h3>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon icon-blue">
            <i class="fas fa-comments"></i>
        </div>
        <div class="stat-info">
            <p>Pending Feedback</p>
            <h3>@Model.PendingFeedback.Count</h3>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon icon-pink">
            <i class="fas fa-comment-dots"></i>
        </div>
        <div class="stat-info">
            <p>Approved Feedback</p>
            <h3>@Model.ApprovedFeedback.Count</h3>
        </div>
    </div>
</div>

<!-- Tabs Header -->
<div class="tabs" style="margin-top: 32px; margin-bottom: 24px; display: flex; gap: 8px; flex-wrap: wrap; border-bottom: 1px solid var(--border); padding-bottom: 12px;">
    <button class="tab-btn active" onclick="switchTab('pending-orgs')" style="display: flex; align-items: center; gap: 8px; padding: 10px 18px; border-radius: 8px; border: none; font-weight: 600; font-size: 14px; cursor: pointer; transition: var(--transition);">
        <i class="fas fa-hourglass-half"></i> Pending Organizers (<span id="count-pending-orgs">@Model.PendingOrganizers.Count</span>)
    </button>
    <button class="tab-btn" onclick="switchTab('pending-events')" style="display: flex; align-items: center; gap: 8px; padding: 10px 18px; border-radius: 8px; border: none; font-weight: 600; font-size: 14px; cursor: pointer; transition: var(--transition);">
        <i class="fas fa-calendar-alt"></i> Pending Events (<span id="count-pending-events">@Model.PendingEvents.Count</span>)
    </button>
    <button class="tab-btn" onclick="switchTab('verified-orgs')" style="display: flex; align-items: center; gap: 8px; padding: 10px 18px; border-radius: 8px; border: none; font-weight: 600; font-size: 14px; cursor: pointer; transition: var(--transition);">
        <i class="fas fa-check-circle"></i> Verified Organizers (<span id="count-verified-orgs">@Model.VerifiedOrganizers.Count</span>)
    </button>
    <button class="tab-btn" onclick="switchTab('pending-feedback')" style="display: flex; align-items: center; gap: 8px; padding: 10px 18px; border-radius: 8px; border: none; font-weight: 600; font-size: 14px; cursor: pointer; transition: var(--transition);">
        <i class="fas fa-comments"></i> Feedback Moderation (<span id="count-pending-feedback">@Model.PendingFeedback.Count</span>)
    </button>
</div>

<!-- Tab Panel: Pending Organizers -->
<div id="pending-orgs" class="tab-panel">
    @if (Model.PendingOrganizers.Any())
    {
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; padding: 0 8px;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <input type="checkbox" id="selectAllOrganizers" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary);" />
                <label for="selectAllOrganizers" style="font-size: 14px; font-weight: 700; color: var(--text); cursor: pointer; user-select: none;">Select All Pending Organizers</label>
            </div>
            <div id="selectionCountOrgs" style="font-size: 13.5px; font-weight: 600; color: var(--text-light); display: none;">
                <span id="checkedCountOrgs">0</span> selected
            </div>
        </div>

        <div class="moderation-grid">
            @foreach (var org in Model.PendingOrganizers)
            {
                <div class="org-card" style="background: var(--white); border: 1px solid var(--border); border-radius: 20px; padding: 24px; display: flex; flex-direction: column; gap: 16px; box-shadow: var(--shadow-sm); transition: var(--transition); position: relative;">
                    <div style="position: absolute; top: 20px; right: 20px; z-index: 10;">
                        <input type="checkbox" class="org-checkbox" value="@org.UserId" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary);" />
                    </div>
                    <div style="display: flex; align-items: center; gap: 16px; padding-right: 20px;">
                        <div style="width: 50px; height: 50px; border-radius: 10px; background: #ffffff; border: 1px solid var(--border); overflow: hidden; display: flex; align-items: center; justify-content: center; padding: 2px; flex-shrink: 0;">
                            @if (!string.IsNullOrEmpty(org.LogoUrl))
                            {
                                <img src="@org.LogoUrl" alt="Logo" style="width: 100%; height: 100%; object-fit: contain;" />
                            }
                            else
                            {
                                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--soft-purple); color: var(--primary); font-weight: 700; font-size: 16px;">
                                    @org.OrganizationName.Substring(0, Math.Min(2, org.OrganizationName.Length)).ToUpper()
                                </div>
                            }
                        </div>
                        <div>
                            <h4 style="font-size: 16px; font-weight: 700; color: var(--text);">@org.OrganizationName</h4>
                            <p style="font-size: 12px; color: var(--text-light);"><i class="fas fa-user" style="margin-right: 4px;"></i> <a href="@Url.Action("UserDetails", "AdminUsers", new { id = org.UserId, returnUrl = Context.Request.Path + Context.Request.QueryString })" style="color: var(--primary); text-decoration: none; font-weight: 600;" class="user-details-link">@org.FullName</a></p>
                        </div>
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 8px; font-size: 13px; background: var(--soft-purple); padding: 14px; border-radius: 12px; border: 1px solid var(--border);">
                        <div style="display: flex; justify-content: space-between;">
                            <span style="color: var(--text-light);">Email:</span>
                            <span style="font-weight: 600; text-overflow: ellipsis; overflow: hidden; max-width: 180px;" title="@org.Email">@org.Email</span>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span style="color: var(--text-light);">Phone:</span>
                            <span style="font-weight: 600;">@(org.BusinessPhone ?? "N/A")</span>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span style="color: var(--text-light);">Website:</span>
                            <span style="font-weight: 600;">
                                @if (!string.IsNullOrEmpty(org.WebsiteUrl))
                                {
                                    <a href="@org.WebsiteUrl" target="_blank" style="color: var(--primary); text-decoration: none;">Link <i class="fas fa-external-link-alt" style="font-size: 10px;"></i></a>
                                }
                                else
                                {
                                    <span>N/A</span>
                                }
                            </span>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span style="color: var(--text-light);">Comm. Reg:</span>
                            <span style="font-weight: 600;">@(org.CommercialRegister ?? "N/A")</span>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span style="color: var(--text-light);">Tax ID:</span>
                            <span style="font-weight: 600;">@(org.TaxNumber ?? "N/A")</span>
                        </div>
                    </div>
                     <div style="margin-top: auto; display: flex; gap: 10px; width: 100%;">
                         <form asp-controller="AdminFeedback" asp-action="ApproveOrganizer" method="post" style="flex: 1;">
                             @Html.AntiForgeryToken()
                             <input type="hidden" name="userId" value="@org.UserId" />
                             <button type="submit" class="btn-primary btn-small btn-full" style="display: flex; align-items: center; justify-content: center; gap: 6px; width: 100%;">
                                 <i class="fas fa-check"></i> Approve
                             </button>
                         </form>
                         <button type="button" class="btn-primary btn-small" style="background: var(--error) !important; color: white !important; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25); display: flex; align-items: center; justify-content: center; gap: 6px;" onclick="openRejectOrgModal('@org.UserId', '@org.OrganizationName.Replace("'", "\\'")')">
                             <i class="fas fa-ban"></i> Reject
                         </button>
                     </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state" style="border: 2px dashed var(--border); border-radius: 20px; padding: 48px; text-align: center; color: var(--text-light); background: var(--white);">
            <i class="fas fa-briefcase" style="font-size: 44px; color: var(--accent); margin-bottom: 16px;"></i>
            <h3 style="font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 4px;">No Pending Approvals</h3>
            <p style="font-size: 14px;">All registered organizers have been verified and activated.</p>
        </div>
    }
</div>

<!-- Tab Panel: Pending Events -->
<div id="pending-events" class="tab-panel" style="display: none;">
    @if (Model.PendingEvents.Any())
    {
        <div class="moderation-grid">
            @foreach (var ev in Model.PendingEvents)
            {
                <div class="org-card" style="background: var(--white); border: 1px solid var(--border); border-radius: 20px; padding: 24px; display: flex; flex-direction: column; gap: 16px; box-shadow: var(--shadow-sm); transition: var(--transition);">
                    <div style="display: flex; align-items: center; gap: 16px;">
                        <div style="width: 60px; height: 60px; border-radius: 12px; background: #ffffff; border: 1px solid var(--border); overflow: hidden; display: flex; align-items: center; justify-content: center; padding: 2px; flex-shrink: 0;">
                            @if (!string.IsNullOrEmpty(ev.ImageUrl))
                            {
                                <img src="@ev.ImageUrl" alt="Event Image" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;" />
                            }
                            else
                            {
                                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--soft-purple); color: var(--primary); font-weight: 700; font-size: 18px; border-radius: 8px;">
                                    EV
                                </div>
                            }
                        </div>
                        <div style="flex-grow: 1; min-width: 0;">
                            <h4 style="font-size: 16px; font-weight: 700; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@ev.Title">@ev.Title</h4>
                            <p style="font-size: 12px; color: var(--text-light);"><i class="fas fa-tag" style="margin-right: 4px;"></i> @(ev.Category?.Name ?? "Uncategorized")</p>
                        </div>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 8px; font-size: 13px; background: var(--soft-purple); padding: 14px; border-radius: 12px; border: 1px solid var(--border);">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px;">
                            <span style="color: var(--text-light); flex-shrink: 0;">Organizer:</span>
                            <span style="font-weight: 600; text-align: right; text-overflow: ellipsis; overflow: hidden; max-width: 180px;" title="@(ev.Organizer?.Email)">
                                @(ev.Organizer?.FullName ?? "Unknown")
                            </span>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span style="color: var(--text-light);">Start Date:</span>
                            <span style="font-weight: 600;">@ev.StartDate.ToEgyptTime().ToString("dd MMM yyyy, hh:mm tt")</span>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span style="color: var(--text-light);">Location:</span>
                            <span style="font-weight: 600; text-align: right; text-overflow: ellipsis; overflow: hidden; max-width: 180px;" title="@ev.Location, @ev.City">
                                @ev.City (@ev.Location)
                            </span>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span style="color: var(--text-light);">Capacity:</span>
                            <span style="font-weight: 600;">@(ev.MaxCapacity?.ToString() ?? "Unlimited")</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                            <span style="color: var(--text-light);">Tickets:</span>
                            <span style="font-weight: 600; text-align: right;">
                                @if (ev.TicketTypes.Any())
                                {
                                    @string.Join(", ", ev.TicketTypes.Select(t => $"{t.Name} (${t.Price})"))
                                }
                                else
                                {
                                    <em style="color: var(--text-light);">No ticket types</em>
                                }
                            </span>
                        </div>
                    </div>

                    <div style="margin-top: auto; display: flex; gap: 10px; width: 100%;">
                        <form asp-controller="AdminEvents" asp-action="ApproveEvent" asp-route-id="@ev.Id" method="post" style="flex: 1;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-primary btn-small btn-full" style="display: flex; align-items: center; justify-content: center; gap: 6px; width: 100%;">
                                <i class="fas fa-check"></i> Approve
                            </button>
                        </form>
                        <button type="button" class="btn-primary btn-small" style="background: var(--error) !important; color: white !important; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25); display: flex; align-items: center; justify-content: center; gap: 6px;" onclick="openRejectEventModal(@ev.Id, '@ev.Title.Replace("'", "\\'")')">
                            <i class="fas fa-times"></i> Reject
                        </button>
                        <a href="/Events/Details/@ev.Id" target="_blank" class="btn-primary btn-small" style="background: var(--text-light) !important; box-shadow: none; display: flex; align-items: center; justify-content: center; padding: 0 12px;" title="View Preview">
                            <i class="fas fa-eye"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state" style="border: 2px dashed var(--border); border-radius: 20px; padding: 48px; text-align: center; color: var(--text-light); background: var(--white);">
            <i class="fas fa-calendar-check" style="font-size: 44px; color: var(--accent); margin-bottom: 16px;"></i>
            <h3 style="font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 4px;">No Pending Events</h3>
            <p style="font-size: 14px;">All submitted events have been reviewed and published.</p>
        </div>
    }
</div>

<!-- Tab Panel: Verified Organizers -->
<div id="verified-orgs" class="tab-panel" style="display: none;">
    @if (Model.VerifiedOrganizers.Any())
    {
        <div class="table-card" style="background: var(--white); border: 1px solid var(--border); border-radius: 20px; overflow: hidden; box-shadow: var(--shadow-sm);">
            <div class="table-responsive">
                <table class="data-table" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border); background: var(--soft-purple);">
                        <th style="padding: 14px 18px; text-align: left; font-size: 12px; font-weight: 700; color: var(--text-light); text-transform: uppercase;">Logo</th>
                        <th style="padding: 14px 18px; text-align: left; font-size: 12px; font-weight: 700; color: var(--text-light); text-transform: uppercase;">Organization</th>
                        <th style="padding: 14px 18px; text-align: left; font-size: 12px; font-weight: 700; color: var(--text-light); text-transform: uppercase;">Contact Person</th>
                        <th style="padding: 14px 18px; text-align: left; font-size: 12px; font-weight: 700; color: var(--text-light); text-transform: uppercase;">Email</th>
                        <th style="padding: 14px 18px; text-align: left; font-size: 12px; font-weight: 700; color: var(--text-light); text-transform: uppercase;">Phone</th>
                        <th style="padding: 14px 18px; text-align: left; font-size: 12px; font-weight: 700; color: var(--text-light); text-transform: uppercase;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var org in Model.VerifiedOrganizers)
                    {
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 14px 18px;">
                                <div style="width: 40px; height: 40px; border-radius: 8px; background: #ffffff; border: 1px solid var(--border); overflow: hidden; display: flex; align-items: center; justify-content: center; padding: 2px;">
                                    @if (!string.IsNullOrEmpty(org.LogoUrl))
                                    {
                                        <img src="@org.LogoUrl" alt="Logo" style="width: 100%; height: 100%; object-fit: contain;" />
                                    }
                                    else
                                    {
                                        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--soft-purple); color: var(--primary); font-weight: 700; font-size: 12px;">
                                            @org.OrganizationName.Substring(0, Math.Min(2, org.OrganizationName.Length)).ToUpper()
                                        </div>
                                    }
                                </div>
                            </td>
                            <td style="padding: 14px 18px; font-weight: 700; color: var(--text);">
                                @org.OrganizationName
                                @if (!string.IsNullOrEmpty(org.WebsiteUrl))
                                {
                                    <div style="font-size: 11px; font-weight: 500; margin-top: 2px;"><a href="@org.WebsiteUrl" target="_blank" style="color: var(--primary); text-decoration: none;">@org.WebsiteUrl</a></div>
                                }
                            </td>
                            <td style="padding: 14px 18px;">@org.FullName</td>
                            <td style="padding: 14px 18px;"><a href="mailto:@org.Email" style="color: inherit; text-decoration: none;">@org.Email</a></td>
                            <td style="padding: 14px 18px;">@(org.BusinessPhone ?? "N/A")</td>
                            <td style="padding: 14px 18px;">
                                <span class="role-tag attendee" style="background: rgba(16, 185, 129, 0.1); color: var(--success); display: inline-flex; align-items: center; gap: 4px;">
                                    <i class="fas fa-check-circle" style="font-size: 10px;"></i> Verified
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state" style="border: 2px dashed var(--border); border-radius: 20px; padding: 48px; text-align: center; color: var(--text-light); background: var(--white);">
            <i class="fas fa-shield-halved" style="font-size: 44px; color: var(--accent); margin-bottom: 16px;"></i>
            <h3 style="font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 4px;">No Verified Organizers</h3>
            <p style="font-size: 14px;">Once you verify a pending organizer, they will be listed here.</p>
        </div>
    }
</div>

<!-- Tab Panel: Feedback Moderation -->
<div id="pending-feedback" class="tab-panel" style="display: none;">
    @if (Model.PendingFeedback.Any())
    {
        <div class="moderation-grid">
            @foreach (var fb in Model.PendingFeedback)
            {
                <div class="org-card" style="background: var(--white); border: 1px solid var(--border); border-radius: 20px; padding: 24px; display: flex; flex-direction: column; gap: 16px; box-shadow: var(--shadow-sm); transition: var(--transition);">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--primary-light); color: var(--white); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 16px; flex-shrink: 0;">
                            @fb.DisplayName.Substring(0, Math.Min(1, fb.DisplayName.Length)).ToUpper()
                        </div>
                        <div>
                            <h4 style="font-size: 15px; font-weight: 700; color: var(--text); line-height: 1.3;">@fb.DisplayName</h4>
                            <p style="font-size: 11px; color: var(--text-light);">@fb.CreatedAt.ToEgyptTime().ToString("dd MMM yyyy, hh:mm tt")</p>
                        </div>
                    </div>
                    <div style="font-size: 13.5px; line-height: 1.6; color: var(--text-light); background: var(--soft-purple); padding: 14px; border-radius: 12px; border: 1px solid var(--border); flex-grow: 1; font-style: italic;">
                        "@fb.Message"
                    </div>
                    <div style="margin-top: auto; display: flex; gap: 10px; width: 100%;">
                         <form asp-controller="AdminFeedback" asp-action="ApproveFeedback" method="post" style="flex: 1;">
                             @Html.AntiForgeryToken()
                             <input type="hidden" name="id" value="@fb.Id" />
                             <button type="submit" class="btn-primary btn-small btn-full" style="background: var(--success) !important; color: white !important; display: flex; align-items: center; justify-content: center; gap: 6px; width: 100%;">
                                 <i class="fas fa-check"></i> Approve
                             </button>
                         </form>
                         <form asp-controller="AdminFeedback" asp-action="DeleteFeedback" method="post" onsubmit="return confirm('Are you sure you want to delete this feedback?')">
                             @Html.AntiForgeryToken()
                             <input type="hidden" name="id" value="@fb.Id" />
                             <button type="submit" class="btn-primary btn-small" style="background: var(--error) !important; color: white !important; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25); display: flex; align-items: center; justify-content: center; gap: 6px;">
                                 <i class="fas fa-trash-alt"></i> Delete
                             </button>
                         </form>
                     </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state" style="border: 2px dashed var(--border); border-radius: 20px; padding: 48px; text-align: center; color: var(--text-light); background: var(--white);">
            <i class="fas fa-comment-slash" style="font-size: 44px; color: var(--accent); margin-bottom: 16px;"></i>
            <h3 style="font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 4px;">No Pending Feedback</h3>
            <p style="font-size: 14px;">All submitted user feedback has been moderated.</p>
        </div>
    }
</div>

<!-- Reject Organizer Modal -->
<div id="rejectOrgModal" class="modal-overlay" onclick="handleOrgOverlayClick(event)">
    <div class="modal-card">
        <button onclick="closeRejectOrgModal()" style="position: absolute; top: 16px; right: 16px; border: none; background: transparent; font-size: 20px; cursor: pointer; color: var(--text-light);">&times;</button>
        <h3 style="font-size: 18px; font-weight: 800; color: var(--error); margin-bottom: 12px;">Reject Organizer Application</h3>
        <p id="modalOrgTitle" style="font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 20px;">-</p>

        <form asp-controller="AdminFeedback" asp-action="RejectOrganizer" method="post" style="display: flex; flex-direction: column; gap: 16px;">
            @Html.AntiForgeryToken()
            <input type="hidden" id="modalOrgUserId" name="userId" />

            <div style="display: flex; flex-direction: column; gap: 6px;">
                <label style="font-size: 12px; font-weight: 700; color: var(--text-light); text-transform: uppercase;">Reason for Rejection</label>
                <textarea name="reason" required placeholder="Provide a reason why this business profile is being rejected. This will be sent to the applicant." class="filter-input" style="width: 100%; min-height: 100px; resize: vertical; border: 2px solid var(--border); border-radius: 12px; padding: 12px; font-family: inherit; font-size: 14px; outline: none;"></textarea>
            </div>

            <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 10px;">
                <button type="button" class="btn-primary btn-small" style="background: var(--text-light) !important; box-shadow: none;" onclick="closeRejectOrgModal()">Cancel</button>
                <button type="submit" class="btn-primary btn-small" style="background: var(--error) !important; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25);">Reject Application</button>
            </div>
        </form>
    </div>
</div>

<!-- Reject Event Modal -->
<div id="rejectEventModal" class="modal-overlay" onclick="handleEventOverlayClick(event)">
    <div class="modal-card">
        <button onclick="closeRejectEventModal()" style="position: absolute; top: 16px; right: 16px; border: none; background: transparent; font-size: 20px; cursor: pointer; color: var(--text-light);">&times;</button>
        <h3 style="font-size: 18px; font-weight: 800; color: var(--error); margin-bottom: 12px;">Reject Event</h3>
        <p id="modalRejectEventTitle" style="font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 20px;">-</p>

        <form asp-controller="AdminEvents" asp-action="RejectEvent" method="post" style="display: flex; flex-direction: column; gap: 16px;">
            @Html.AntiForgeryToken()
            <input type="hidden" id="modalRejectEventId" name="id" />

            <div style="display: flex; flex-direction: column; gap: 6px;">
                <label style="font-size: 12px; font-weight: 700; color: var(--text-light); text-transform: uppercase;">Reason for Rejection</label>
                <textarea name="reason" required placeholder="Describe why this event is being rejected. This will be sent to the organizer." class="filter-input" style="width: 100%; min-height: 100px; resize: vertical; border: 2px solid var(--border); border-radius: 12px; padding: 12px; font-family: inherit; font-size: 14px; outline: none;"></textarea>
            </div>

            <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 10px;">
                <button type="button" class="btn-primary btn-small" style="background: var(--text-light) !important; box-shadow: none;" onclick="closeRejectEventModal()">Cancel</button>
                <button type="submit" class="btn-primary btn-small" style="background: var(--error) !important; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25);">Reject Event</button>
            </div>
        </form>
    </div>
</div>

<!-- Floating Organizers Bulk Actions Bar -->
<div id="bulkOrgsActionsBar" class="bulk-bar">
    <div class="bulk-bar-content">
        <div class="bulk-bar-info">
            <i class="fas fa-info-circle" style="color: var(--primary); font-size: 18px;"></i>
            <span>Selected <b id="bulkOrgsCount">0</b> organizers</span>
        </div>
        <div class="bulk-bar-buttons">
            <button type="button" onclick="submitBulkOrgsAction()" class="btn-bulk approve">
                <i class="fas fa-check"></i> Approve Selected
            </button>
            <button type="button" onclick="clearOrgsSelection()" class="btn-bulk cancel">
                Cancel
            </button>
        </div>
    </div>
</div>

<!-- Hidden Bulk Form for Organizers -->
<form id="bulkApproveOrgsForm" asp-controller="AdminFeedback" asp-action="BulkApproveOrganizers" method="post" style="display: none;">
    @Html.AntiForgeryToken()
    <div id="bulkApproveOrgsIdsContainer"></div>
</form>

@section Scripts {
    <script src="~/js/admin-dashboard.js" asp-append-version="true"></script>
}