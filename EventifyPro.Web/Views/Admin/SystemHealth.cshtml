@model EventifyPro.Web.ViewModels.Admin.SystemHealthViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "System Health";
    ViewData["HeaderTitle"] = "System Health Monitor 🖥️";
    ViewData["HeaderSubtitle"] = "Real-time process performance, database checks, and captured system exceptions.";
}

@section Styles {
    <style>
        .health-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 24px;
            margin-bottom: 32px;
        }

        .metric-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 28px;
            box-shadow: var(--shadow-sm);
            display: flex;
            align-items: center;
            gap: 20px;
            transition: var(--transition);
        }
        .metric-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-md);
        }

        .metric-icon {
            width: 60px;
            height: 60px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: white;
            flex-shrink: 0;
        }
        .icon-orange { background: linear-gradient(135deg, #f59e0b, #d97706); }
        .icon-blue { background: linear-gradient(135deg, #3b82f6, #2563eb); }
        .icon-green { background: linear-gradient(135deg, #10b981, #059669); }
        .icon-purple { background: linear-gradient(135deg, #8b5cf6, #7c3aed); }

        .metric-details {
            flex-grow: 1;
        }
        .metric-details p {
            font-size: 13px;
            color: var(--text-light);
            font-weight: 500;
            margin-bottom: 4px;
        }
        .metric-details h3 {
            font-size: 24px;
            font-weight: 800;
            color: var(--text);
            margin: 0;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            border-radius: 50px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }
        .status-badge.success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }
        .status-badge.danger {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
        }

        .details-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 32px;
            box-shadow: var(--shadow-sm);
            margin-bottom: 32px;
        }
        .details-card h4 {
            font-size: 16px;
            font-weight: 800;
            color: var(--primary-dark);
            margin-top: 0;
            margin-bottom: 24px;
            border-bottom: 1px dashed var(--border);
            padding-bottom: 12px;
        }

        .system-info-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
        }
        .system-info-item {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .info-label {
            font-size: 11.5px;
            font-weight: 700;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .info-value {
            font-size: 14.5px;
            font-weight: 600;
            color: var(--text);
        }

        .logs-table-container {
            overflow-x: auto;
        }
        .logs-table {
            width: 100%;
            border-collapse: collapse;
        }
        .logs-table th {
            padding: 12px 16px;
            text-align: left;
            font-size: 11.5px;
            font-weight: 700;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--border);
            background: var(--soft-purple);
        }
        .logs-table td {
            padding: 14px 16px;
            font-size: 13.5px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
            vertical-align: middle;
        }
        .logs-table tbody tr:hover {
            background: rgba(91, 33, 182, 0.01);
        }

        .btn-view-stack {
            padding: 5px 10px;
            border: 1px solid var(--border);
            background: var(--soft-purple);
            color: var(--primary);
            font-weight: 600;
            font-size: 12px;
            border-radius: 6px;
            cursor: pointer;
            transition: var(--transition);
        }
        .btn-view-stack:hover {
            background: var(--primary);
            color: white;
        }

        .stack-trace-box {
            display: none;
            background: #1f2937;
            color: #f3f4f6;
            font-family: monospace;
            font-size: 11.5px;
            padding: 16px;
            border-radius: 8px;
            margin-top: 10px;
            max-height: 250px;
            overflow-y: auto;
            white-space: pre-wrap;
            border: 1px solid #374151;
        }

        .btn-danger-custom {
            background: var(--error) !important;
            color: white !important;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25);
            border: none;
            padding: 10px 20px;
            font-weight: 600;
            font-size: 13.5px;
            border-radius: 10px;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-danger-custom:hover {
            opacity: 0.9;
            transform: translateY(-2px);
        }
    </style>
}

<div class="health-grid">
    <!-- CPU Usage Card -->
    <div class="metric-card">
        <div class="metric-icon icon-orange">
            <i class="fas fa-microchip"></i>
        </div>
        <div class="metric-details">
            <p>Process CPU Usage</p>
            <h3>@Model.CpuUsage.ToString("F1")%</h3>
        </div>
    </div>

    <!-- RAM Usage Card -->
    <div class="metric-card">
        <div class="metric-icon icon-blue">
            <i class="fas fa-memory"></i>
        </div>
        <div class="metric-details">
            <p>RAM (Working Set)</p>
            <h3>@Model.MemoryUsageMB.ToString("F1") MB</h3>
        </div>
    </div>

    <!-- DB Status Card -->
    <div class="metric-card">
        <div class="metric-icon icon-green">
            <i class="fas fa-database"></i>
        </div>
        <div class="metric-details">
            <p>Database Connectivity</p>
            <div>
                @if (Model.DatabaseConnected)
                {
                    <span class="status-badge success"><i class="fas fa-check-circle"></i> Connected</span>
                }
                else
                {
                    <span class="status-badge danger"><i class="fas fa-times-circle"></i> Disconnected</span>
                }
            </div>
        </div>
    </div>

    <!-- Server Uptime Card -->
    <div class="metric-card">
        <div class="metric-icon icon-purple">
            <i class="fas fa-hourglass-start"></i>
        </div>
        <div class="metric-details">
            <p>Server Uptime</p>
            <h3>@Model.SystemUptime</h3>
        </div>
    </div>
</div>

<!-- System Details Card -->
<div class="details-card">
    <h4>Server & Environment Details</h4>
    <div class="system-info-list">
        <div class="system-info-item">
            <span class="info-label">Operating System</span>
            <span class="info-value">@Model.OsVersion</span>
        </div>
        <div class="system-info-item">
            <span class="info-label">.NET Runtime</span>
            <span class="info-value">@Model.DotNetVersion</span>
        </div>
        <div class="system-info-item">
            <span class="info-label">Process Private Memory</span>
            <span class="info-value">@Model.PrivateMemoryMB.ToString("F1") MB</span>
        </div>
    </div>
</div>

<!-- System Error Logs Card -->
<div class="details-card">
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border); padding-bottom: 12px; margin-bottom: 24px; flex-wrap: wrap; gap: 16px;">
        <h4 style="border-bottom: none; margin: 0; padding-bottom: 0;">Captured System Exceptions (@Model.ErrorLogs.Count)</h4>
        @if (Model.ErrorLogs.Any())
        {
            <form asp-controller="AdminSettings" asp-action="ClearSystemErrors" method="post" onsubmit="return confirm('Are you sure you want to permanently delete all error logs?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-danger-custom">
                    <i class="fas fa-trash-alt"></i> Clear Logs
                </button>
            </form>
        }
    </div>

    @if (Model.ErrorLogs.Any())
    {
        <div class="logs-table-container">
            <table class="logs-table">
                <thead>
                    <tr>
                        <th style="width: 160px;">Timestamp</th>
                        <th>Error Message</th>
                        <th>Path</th>
                        <th>User ID</th>
                        <th style="width: 120px; text-align: right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.ErrorLogs.Count; i++)
                    {
                        var log = Model.ErrorLogs[i];
                        <tr>
                            <td style="font-family: monospace; font-size: 12px;">@log.Timestamp</td>
                            <td style="font-weight: 600; color: var(--error);">@log.Message</td>
                            <td style="font-family: monospace; font-size: 12.5px;">@(log.Path ?? "/")</td>
                            <td style="font-family: monospace; font-size: 11px;">@(log.UserId ?? "Anonymous")</td>
                            <td style="text-align: right;">
                                @if (!string.IsNullOrEmpty(log.StackTrace))
                                {
                                    <button class="btn-view-stack" onclick="toggleStackTrace('stack-@i')">View Stack</button>
                                }
                                else
                                {
                                    <span style="font-style: italic; font-size: 12px; color: var(--text-light);">No Stack</span>
                                }
                            </td>
                        </tr>
                        @if (!string.IsNullOrEmpty(log.StackTrace))
                        {
                            <tr id="row-stack-@i" style="display: none; background: #fafafa;">
                                <td colspan="5" style="padding: 16px; border-bottom: 1px solid var(--border);">
                                    <div style="font-size: 12px; font-weight: 700; color: var(--text-light); margin-bottom: 6px;">
                                        Source: <span style="font-family: monospace; font-weight: 600; color: var(--text);">@(log.Source ?? "Unknown")</span>
                                    </div>
                                    <div id="stack-@i" class="stack-trace-box">@log.StackTrace</div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div style="text-align: center; padding: 48px; color: var(--text-light);">
            <i class="fas fa-check-circle" style="font-size: 48px; color: var(--success); margin-bottom: 16px; opacity: 0.8;"></i>
            <h3 style="font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 4px;">No Errors Logged</h3>
            <p style="font-size: 14px;">Great! The system is running smoothly with zero exceptions captured recently.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        function toggleStackTrace(id) {
            const stackBox = document.getElementById(id);
            const parentRow = document.getElementById('row-' + id);
            if (stackBox.style.display === 'block') {
                stackBox.style.display = 'none';
                parentRow.style.display = 'none';
            } else {
                stackBox.style.display = 'block';
                parentRow.style.display = 'table-row';
            }
        }

        // Auto-refresh the system health metrics every 30 seconds
        setInterval(function() {
            // Only refresh if no stack trace is currently open/visible to avoid disruption
            const openTraces = document.querySelectorAll('tr[id^="row-stack-"]:not([style*="display: none"])');
            if (openTraces.length === 0) {
                window.location.reload();
            }
        }, 30000);
    </script>
}
