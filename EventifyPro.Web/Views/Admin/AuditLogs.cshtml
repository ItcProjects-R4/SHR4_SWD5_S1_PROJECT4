@model IEnumerable<Eventify.Domain.Entities.AuditLog>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Audit Logs";
    ViewData["HeaderTitle"] = "System Audit Logs 🔍";
    ViewData["HeaderSubtitle"] = "Track all database updates, insertions, and deletions executed in the platform.";

    var tableNameFilter = ViewBag.TableNameFilter as string;
    var actionFilter = ViewBag.ActionFilter as string;
    var userIdFilter = ViewBag.UserIdFilter as string;
    var startDate = ViewBag.StartDate as string;
    var endDate = ViewBag.EndDate as string;
    var pageNumber = (int)ViewBag.PageNumber;
    var totalPages = (int)ViewBag.TotalPages;
    var totalCount = (int)ViewBag.TotalCount;
    var uniqueTables = ViewBag.UniqueTables as List<string> ?? new List<string>();
    var uniqueActions = ViewBag.UniqueActions as List<string> ?? new List<string>();
    var userMap = ViewBag.UserMap as Dictionary<string, string> ?? new Dictionary<string, string>();
}

@section Styles {
    <style>
        /* Filter Panel */
        .filter-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 28px;
            box-shadow: var(--shadow-sm);
        }

        .filter-form {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)) auto;
            gap: 16px;
            align-items: flex-end;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .input-group label {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .filter-input {
            width: 100%;
            height: 44px;
            padding: 10px 14px;
            border-radius: 10px;
            border: 2px solid var(--border);
            background: var(--soft-purple);
            color: var(--text);
            font-family: inherit;
            font-size: 13.5px;
            outline: none;
            transition: var(--transition);
        }
        .filter-input:focus {
            border-color: var(--accent);
            background: white;
        }

        .btn-group {
            display: flex;
            gap: 8px;
            height: 44px;
        }
        .btn-primary {
            background: var(--gradient);
            color: white;
            border: none;
            padding: 0 24px;
            font-weight: 600;
            border-radius: 10px;
            cursor: pointer;
            transition: var(--transition);
            box-shadow: 0 4px 12px rgba(91, 33, 182, 0.2);
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13.5px;
        }
        .btn-primary:hover {
            box-shadow: 0 6px 20px rgba(91, 33, 182, 0.3);
            transform: translateY(-2px);
        }
        .btn-secondary {
            background: var(--soft-purple);
            color: var(--primary-dark);
            border: 1px solid var(--border);
            padding: 0 16px;
            font-weight: 600;
            border-radius: 10px;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13.5px;
        }
        .btn-secondary:hover {
            background: var(--light-purple);
        }

        /* Table Card */
        .table-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            margin-bottom: 24px;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }
        .data-table thead {
            background: var(--soft-purple);
            border-bottom: 2px solid var(--border);
        }
        .data-table th {
            padding: 16px 20px;
            text-align: left;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .data-table td {
            padding: 16px 20px;
            font-size: 13.5px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
            vertical-align: middle;
        }
        .data-table tbody tr {
            transition: var(--transition);
        }
        .data-table tbody tr:hover {
            background: rgba(91, 33, 182, 0.02);
        }

        /* Badges */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 6px 12px;
            border-radius: 50px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }
        .badge.insert {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }
        .badge.update {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning);
        }
        .badge.delete {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
        }

        .action-btn {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: none;
            background: var(--soft-purple);
            color: var(--primary);
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
            text-decoration: none;
        }
        .action-btn:hover {
            background: var(--gradient);
            color: white;
            box-shadow: 0 4px 12px rgba(124, 58, 237, 0.25);
            transform: translateY(-2px);
        }

        /* Pagination */
        .pagination-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
            padding: 10px 8px;
        }
        .page-info {
            font-size: 13.5px;
            color: var(--text-light);
        }
        .pagination-buttons {
            display: flex;
            gap: 6px;
        }

        /* Modal Overlay */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .modal-overlay.active {
            display: flex;
        }
        .modal-card {
            background: white;
            border-radius: 20px;
            width: 90%;
            max-width: 800px;
            padding: 28px;
            box-shadow: var(--shadow-lg);
            position: relative;
            max-height: 85vh;
            overflow-y: auto;
        }
        
        .json-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 16px;
        }
        @@media (max-width: 768px) {
            .json-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<!-- Filters -->
<div class="filter-card">
    <form method="get" class="filter-form">
        <div class="input-group">
            <label>Table Name</label>
            <select name="tableNameFilter" class="filter-input">
                <option value="">All Tables</option>
                @foreach (var table in uniqueTables)
                {
                    <!option value="@table" @(tableNameFilter == table ? "selected" : "")>@table</!option>
                }
            </select>
        </div>

        <div class="input-group">
            <label>Action Type</label>
            <select name="actionFilter" class="filter-input">
                <option value="">All Actions</option>
                @foreach (var action in uniqueActions)
                {
                    <!option value="@action" @(actionFilter == action ? "selected" : "")>@action</!option>
                }
            </select>
        </div>

        <div class="input-group">
            <label>User ID</label>
            <input type="text" name="userIdFilter" value="@userIdFilter" placeholder="Filter by User ID" class="filter-input" />
        </div>

        <div class="input-group">
            <label>Start Date</label>
            <input type="date" name="startDate" value="@startDate" class="filter-input" />
        </div>

        <div class="input-group">
            <label>End Date</label>
            <input type="date" name="endDate" value="@endDate" class="filter-input" />
        </div>

        <div class="btn-group">
            <button type="submit" class="btn-primary">
                <i class="fas fa-filter"></i> Filter
            </button>
            <a href="/Admin/AuditLogs" class="btn-secondary" title="Clear Filters">
                <i class="fas fa-rotate-left"></i>
            </a>
        </div>
    </form>
</div>

<!-- Table -->
<div class="table-card">
    @if (Model.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 120px;">Action</th>
                    <th>Table Name</th>
                    <th>Entity ID</th>
                    <th>Performed By</th>
                    <th>Changed At</th>
                    <th style="text-align: right; width: 100px;">Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    var badgeClass = log.Action.ToLower() switch
                    {
                        "insert" => "insert",
                        "update" => "update",
                        "delete" => "delete",
                        _ => ""
                    };

                    var userDisplay = "System Auto";
                    if (!string.IsNullOrEmpty(log.UserId))
                    {
                        userDisplay = userMap.TryGetValue(log.UserId, out var name) ? name : log.UserId;
                    }

                    <tr>
                        <td>
                            <span class="badge @badgeClass">
                                @if (log.Action.ToLower() == "insert") { <i class="fas fa-plus-circle" style="font-size: 9px;"></i> }
                                @if (log.Action.ToLower() == "update") { <i class="fas fa-pen-fancy" style="font-size: 9px;"></i> }
                                @if (log.Action.ToLower() == "delete") { <i class="fas fa-trash-alt" style="font-size: 9px;"></i> }
                                @log.Action
                            </span>
                        </td>
                        <td style="font-weight: 600;">
                            <i class="fas fa-table" style="color: var(--accent); margin-right: 6px;"></i> @log.TableName
                        </td>
                        <td>
                            <code style="background: var(--soft-purple); padding: 4px 8px; border-radius: 4px; font-family: monospace; font-size: 12px;">@log.EntityId</code>
                        </td>
                        <td>
                            <span title="@log.UserId">
                                <i class="fas fa-user-circle" style="color: var(--text-light); margin-right: 4px;"></i> @userDisplay
                            </span>
                        </td>
                        <td>
                            <div style="font-weight: 500;">@log.ChangedAt.ToEgyptTime().ToString("MMM dd, yyyy")</div>
                            <div style="font-size: 11px; color: var(--text-light);">@log.ChangedAt.ToEgyptTime().ToString("hh:mm:ss tt")</div>
                        </td>
                        <td style="text-align: right;">
                            <button type="button" class="action-btn" title="View change details" 
                                    data-id="@log.Id" 
                                    data-table="@log.TableName" 
                                    data-action="@log.Action" 
                                    data-changed-at="@log.ChangedAt.ToEgyptTime().ToString("dd MMM yyyy, hh:mm:ss tt")" 
                                    data-old-values="@log.OldValues" 
                                    data-new-values="@log.NewValues" 
                                    data-user="@userDisplay" 
                                    data-ip-address="@log.IpAddress" 
                                    data-user-agent="@log.UserAgent" 
                                    onclick="openAuditDetailsModal(this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="text-align: center; padding: 60px; color: var(--text-light);">
            <i class="fas fa-clipboard-question" style="font-size: 48px; color: var(--accent); margin-bottom: 16px;"></i>
            <h3 style="font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 4px;">No Audit Logs Found</h3>
            <p style="font-size: 14px;">Try modifying or clearing your filters to see more results.</p>
        </div>
    }
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <div class="pagination-container">
        <div class="page-info">
            Showing page <strong>@pageNumber</strong> of <strong>@totalPages</strong> (@totalCount total records)
        </div>
        <div class="pagination-buttons">
            @if (pageNumber > 1)
            {
                <a href="/Admin/AuditLogs?tableNameFilter=@tableNameFilter&actionFilter=@actionFilter&userIdFilter=@userIdFilter&startDate=@startDate&endDate=@endDate&page=@(pageNumber - 1)" class="btn-secondary" style="height: 38px;"><i class="fas fa-chevron-left" style="margin-right: 6px;"></i> Prev</a>
            }
            else
            {
                <button class="btn-secondary" style="height: 38px; opacity: 0.5; cursor: not-allowed;" disabled><i class="fas fa-chevron-left" style="margin-right: 6px;"></i> Prev</button>
            }

            @if (pageNumber < totalPages)
            {
                <a href="/Admin/AuditLogs?tableNameFilter=@tableNameFilter&actionFilter=@actionFilter&userIdFilter=@userIdFilter&startDate=@startDate&endDate=@endDate&page=@(pageNumber + 1)" class="btn-secondary" style="height: 38px;">Next <i class="fas fa-chevron-right" style="margin-left: 6px;"></i></a>
            }
            else
            {
                <button class="btn-secondary" style="height: 38px; opacity: 0.5; cursor: not-allowed;" disabled>Next <i class="fas fa-chevron-right" style="margin-left: 6px;"></i></button>
            }
        </div>
    </div>
}

<!-- Audit Log Details Modal -->
<div id="auditDetailsModal" class="modal-overlay" onclick="handleDetailsOverlayClick(event)">
    <div class="modal-card">
        <button onclick="closeAuditDetailsModal()" style="position: absolute; top: 16px; right: 16px; border: none; background: transparent; font-size: 20px; cursor: pointer; color: var(--text-light);">&times;</button>
        
        <h3 style="font-size: 18px; font-weight: 800; color: var(--primary-dark); margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
            <i class="fas fa-clipboard-list"></i> Audit Log Details (Entry #<span id="detailLogId">-</span>)
        </h3>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; font-size: 13px; background: var(--soft-purple); padding: 14px; border-radius: 12px; border: 1px solid var(--border); margin-bottom: 20px;">
            <div><strong>Table:</strong> <span id="detailTableName">-</span></div>
            <div><strong>Action:</strong> <span id="detailAction">-</span></div>
            <div><strong>By:</strong> <span id="detailUser">-</span></div>
            <div><strong>Time:</strong> <span id="detailTime">-</span></div>
            <div><strong>IP Address:</strong> <span id="detailIpAddress">-</span></div>
            <div><strong>User Agent:</strong> <span id="detailUserAgent">-</span></div>
        </div>

        <div class="json-grid">
            <div>
                <h4 style="font-size: 13px; font-weight: 700; color: var(--text-light); text-transform: uppercase; margin-bottom: 8px;"><i class="fas fa-history" style="color: var(--error);"></i> Old Values (Before Change)</h4>
                <div id="detailOldValues">-</div>
            </div>
            <div>
                <h4 style="font-size: 13px; font-weight: 700; color: var(--text-light); text-transform: uppercase; margin-bottom: 8px;"><i class="fas fa-file-circle-plus" style="color: var(--success);"></i> New Values (After Change)</h4>
                <div id="detailNewValues">-</div>
            </div>
        </div>

        <div style="display: flex; justify-content: flex-end; margin-top: 24px;">
            <button type="button" class="btn-primary btn-small" style="background: var(--text-light) !important; box-shadow: none;" onclick="closeAuditDetailsModal()">Close Details</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function prettyPrintJson(jsonStr) {
            if (!jsonStr || jsonStr.trim() === "" || jsonStr.trim() === "null" || jsonStr.trim() === "[]" || jsonStr.trim() === "{}") {
                return '<em style="color: var(--text-light); font-size: 13px;">None / Empty</em>';
            }
            try {
                const obj = JSON.parse(jsonStr);
                return '<pre style="background: var(--soft-purple); padding: 14px; border-radius: 12px; border: 1px solid var(--border); overflow-x: auto; font-family: monospace; font-size: 12.5px; color: var(--text); line-height: 1.5; text-align: left; max-height: 380px; overflow-y: auto;">' + JSON.stringify(obj, null, 2) + '</pre>';
            } catch (e) {
                return '<pre style="background: var(--soft-purple); padding: 14px; border-radius: 12px; border: 1px solid var(--border); overflow-x: auto; font-family: monospace; font-size: 12.5px; color: var(--text); line-height: 1.5; text-align: left; max-height: 380px; overflow-y: auto;">' + jsonStr + '</pre>';
            }
        }

        function openAuditDetailsModal(btn) {
            const id = btn.getAttribute('data-id');
            const tableName = btn.getAttribute('data-table');
            const action = btn.getAttribute('data-action');
            const performedBy = btn.getAttribute('data-user');
            const changedAt = btn.getAttribute('data-changed-at');
            const oldValues = btn.getAttribute('data-old-values');
            const newValues = btn.getAttribute('data-new-values');
            const ipAddress = btn.getAttribute('data-ip-address') || 'N/A';
            const userAgent = btn.getAttribute('data-user-agent') || 'N/A';

            document.getElementById('detailLogId').innerText = id;
            document.getElementById('detailTableName').innerText = tableName;
            document.getElementById('detailAction').innerText = action;
            document.getElementById('detailUser').innerText = performedBy;
            document.getElementById('detailTime').innerText = changedAt;
            document.getElementById('detailIpAddress').innerText = ipAddress;
            document.getElementById('detailUserAgent').innerText = userAgent;
            
            document.getElementById('detailOldValues').innerHTML = prettyPrintJson(oldValues);
            document.getElementById('detailNewValues').innerHTML = prettyPrintJson(newValues);

            document.getElementById('auditDetailsModal').classList.add('active');
        }

        function closeAuditDetailsModal() {
            document.getElementById('auditDetailsModal').classList.remove('active');
        }

        function handleDetailsOverlayClick(event) {
            if (event.target === document.getElementById('auditDetailsModal')) {
                closeAuditDetailsModal();
            }
        }

        // Close modal on Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeAuditDetailsModal();
            }
        });
    </script>
}
