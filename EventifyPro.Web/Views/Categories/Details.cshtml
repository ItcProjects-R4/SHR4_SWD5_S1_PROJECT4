@model IEnumerable<EventSummaryViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = $"{ViewBag.CategoryName} Events - Eventify Pro";
}

<style>
    /* Category Details Event Card Styles */
    .events-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 30px;
        margin-top: 40px;
    }

    .event-card {
        background: var(--white);
        border: 1px solid rgba(124, 58, 237, 0.08);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.15), box-shadow 0.4s ease, border-color 0.4s ease;
        display: flex;
        flex-direction: column;
        height: 100%;
        position: relative;
    }

    .event-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 15px 30px rgba(91, 33, 182, 0.1);
        border-color: rgba(124, 58, 237, 0.2);
    }

    .event-card-image-wrapper {
        position: relative;
        height: 160px;
        overflow: hidden;
        background: var(--soft-purple);
    }

    .event-card-image {
        height: 100%;
        width: 100%;
        background-size: cover;
        background-position: center;
        transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .event-card-fallback-bg {
        height: 100%;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--soft-purple) 0%, rgba(124, 58, 237, 0.1) 100%);
    }

    .fallback-icon {
        color: var(--primary);
        font-size: 45px;
    }

    .event-card:hover .event-card-image {
        transform: scale(1.06);
    }

    .event-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(91, 33, 182, 0.95);
        backdrop-filter: blur(8px);
        color: var(--white);
        padding: 4px 10px;
        border-radius: 30px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.5px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.12);
        z-index: 2;
        text-transform: uppercase;
    }

    .event-card-body {
        padding: 20px 24px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .event-category-label {
        font-size: 10.5px;
        font-weight: 700;
        color: var(--primary-light);
        text-transform: uppercase;
        margin-bottom: 6px;
        letter-spacing: 0.8px;
    }

    .event-title {
        font-size: 18px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 12px;
        line-height: 1.4;
        transition: var(--transition);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 50px;
    }

    .event-card:hover .event-title {
        color: var(--primary);
    }

    .event-info-list {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px 16px;
        margin-bottom: 20px;
        font-size: 13px;
        color: var(--text-light);
    }

    .event-info-item {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .event-info-item i {
        color: var(--primary-light);
        width: 14px;
        font-size: 13px;
    }

    .event-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid var(--border);
        padding-top: 16px;
        margin-top: auto;
    }

    .event-price-box {
        display: flex;
        flex-direction: column;
    }

    .price-label {
        font-size: 9.5px;
        color: var(--text-light);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 2px;
    }

    .event-price {
        font-size: 13.5px;
        font-weight: 600;
        color: var(--text);
        display: flex;
        align-items: baseline;
    }

    .price-currency {
        font-size: 10px;
        font-weight: 700;
        color: var(--text-light);
        margin-right: 3px;
    }

    .price-amount {
        font-size: 17px;
        font-weight: 800;
        color: var(--primary);
        line-height: 1;
    }

    .price-free {
        font-size: 14px;
        font-weight: 700;
        color: var(--success);
    }

    .btn-card-action {
        background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary) 100%) !important;
        color: var(--white) !important;
        border: none;
        padding: 9px 18px;
        border-radius: 50px;
        font-size: 12.5px;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        outline: none;
        box-shadow: 0 4px 10px rgba(124, 58, 237, 0.12);
    }

    .btn-card-action:hover {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%) !important;
        color: var(--white) !important;
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(91, 33, 182, 0.25);
    }

    .btn-card-action i {
        font-size: 10px;
        transition: transform 0.3s ease;
    }

    .btn-card-action:hover i {
        transform: translateX(3px);
    }

    .events-browse-header {
        padding: 130px 0 30px;
        background: linear-gradient(180deg, var(--soft-purple) 0%, rgba(255, 255, 255, 0.9) 100%);
        border-bottom: 1px solid var(--border);
    }
</style>

<section class="events-browse-header">
    <div class="container">
        <span class="section-tag-enhanced" style="display: inline-flex; align-items: center; gap: 8px; margin-bottom: 8px; background: rgba(124, 58, 237, 0.08); color: var(--primary); padding: 6px 14px; border-radius: 30px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; width: fit-content;"><i class="fas fa-folder-open"></i> Category: @ViewBag.CategoryName</span>
        <p style="color: var(--text-light); margin: 0; font-size: 14px;">@(string.IsNullOrWhiteSpace(ViewBag.CategoryDescription) ? $"Browse all events belonging to the {ViewBag.CategoryName} category." : ViewBag.CategoryDescription)</p>
    </div>
</section>

<section class="content-page section enhanced-bg-glow" style="padding-top: 40px;">
    <div class="container">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h2 style="font-size: 22px; font-weight: 800;">Available Events (@Model.Count())</h2>
            <a asp-controller="Categories" asp-action="Index" class="btn-outline btn-small"><i class="fas fa-arrow-left"></i> All Categories</a>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="events-grid">
                @foreach (var ev in Model)
                {
                    <div class="event-card">
                        <div class="event-card-image-wrapper">
                            @if (!string.IsNullOrEmpty(ev.ImageUrl))
                            {
                                <div class="event-card-image" style="background-image: url('@ev.ImageUrl')"></div>
                            }
                            else
                            {
                                <div class="event-card-fallback-bg">
                                    <i class="fas fa-calendar-alt fallback-icon"></i>
                                </div>
                            }
                            <span class="event-badge">@ev.Status</span>
                        </div>

                        <div class="event-card-body">
                            <span class="event-category-label">@ev.CategoryName</span>
                            <h3 class="event-title" title="@ev.Title">@ev.Title</h3>
                            
                            <div class="event-info-list">
                                <div class="event-info-item">
                                    <i class="far fa-calendar-alt"></i>
                                    <span>@ev.StartDate.ToEgyptTime().ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="event-info-item">
                                    <i class="far fa-clock"></i>
                                    <span>@ev.StartDate.ToEgyptTime().ToString("hh:mm tt")</span>
                                </div>
                                <div class="event-info-item">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <span>@ev.City</span>
                                </div>
                                <div class="event-info-item">
                                    <i class="far fa-user"></i>
                                    <span>Organizer: @ev.OrganizerName</span>
                                </div>
                            </div>

                            <div class="event-card-footer">
                                <div class="event-price-box">
                                    <span class="price-label">Prices Start From</span>
                                    <span class="event-price">
                                        @if (ev.MinPrice > 0)
                                        {
                                            <span class="price-currency">EGP</span><span class="price-amount">@ev.MinPrice.ToString("N0")</span>
                                        }
                                        else
                                        {
                                            <span class="price-free">Free Admission</span>
                                        }
                                    </span>
                                </div>
                                <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="btn-card-action">
                                    Book Now <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center" style="padding: 80px 0; text-align: center; background: var(--white); border-radius: 24px; border: 1px solid var(--border); box-shadow: var(--shadow-sm);">
                <div style="font-size: 60px; color: var(--text-light); margin-bottom: 20px;"><i class="fas fa-calendar-times"></i></div>
                <h2>No Events Found</h2>
                <p style="color: var(--text-light); margin-bottom: 24px;">There are no published events in this category at the moment.</p>
                <a asp-controller="Events" asp-action="Index" class="btn-primary">Browse All Events</a>
            </div>
        }
    </div>
</section>
