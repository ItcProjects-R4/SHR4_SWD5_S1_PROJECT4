@{
    Layout = null;
}

<style>
    /* التنسيق هنا خاص بالصفحة دي بس */
    /* بدلاً من استخدام body للسنترة، عملنا كلاس خاص بالصفحة */
    /* الصفحة بالكامل */
    .scanner-page-content {
        min-height: 100vh;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 20px;
        background: linear-gradient(135deg, #f5f7ff 0%, #eef2ff 100%);
    }

    /* الكارد */
    .welcome-container {
        width: 100%;
        max-width: 750px;
        text-align: center;
        background: #ffffff;
        padding: 70px 50px;
        border-radius: 28px;
        box-shadow: 0 10px 30px rgba(138, 43, 226, 0.12), 0 2px 10px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(138, 43, 226, 0.08);
        transition: transform 0.3s ease;
    }

        .welcome-container:hover {
            transform: translateY(-4px);
        }

    /* العنوان */
    .welcome-title {
        color: #8A2BE2;
        font-size: clamp(3rem, 6vw, 5rem);
        font-weight: 800;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 4px;
        line-height: 1.1;
    }

    /* النص الصغير */
    .welcome-subtitle {
        color: #666;
        font-size: 1.4rem;
        margin-top: 18px;
        font-weight: 500;
        line-height: 1.6;
    }

    /* للموبايل */
    @@media (max-width: 768px) {
        .welcome-container {
            padding: 50px 25px;
            border-radius: 22px;
        }

        .welcome-subtitle {
            font-size: 1.1rem;
        }
    }

    /* زر Create Scanner */
    .btn-create-scanner {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 28px;
        padding: 16px 42px;
        background: linear-gradient(135deg, #8A2BE2 0%, #6f1fd1 100%);
        color: #ffffff;
        text-decoration: none;
        font-size: 1.15rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        border: none;
        border-radius: 16px;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(138, 43, 226, 0.25), 0 4px 10px rgba(138, 43, 226, 0.15);
        transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
    }

        /* Hover */
        .btn-create-scanner:hover {
            background: linear-gradient(135deg, #7b25cf 0%, #5f16ba 100%);
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 16px 30px rgba(138, 43, 226, 0.35), 0 6px 14px rgba(138, 43, 226, 0.2);
            color: #ffffff;
            text-decoration: none;
        }

        /* Click */
        .btn-create-scanner:active {
            transform: scale(0.98);
            box-shadow: 0 6px 14px rgba(138, 43, 226, 0.2);
        }

        /* Focus */
        .btn-create-scanner:focus {
            outline: none;
            box-shadow: 0 0 0 4px rgba(138, 43, 226, 0.2), 0 10px 25px rgba(138, 43, 226, 0.25);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .btn-create-scanner {
            width: 100%;
            padding: 15px 24px;
            font-size: 1rem;
        }
    }
</style>

<div class="scanner-page-content">
    <div class="welcome-container">
        <h1 class="welcome-title">Welcome Organizer</h1>
        <p class="welcome-subtitle">Here is your dashboard overview.</p>

        <!-- زرار Create Scanner باستخدام ASP.NET Core Tag Helpers -->
        <a asp-controller="OrganizerScanners" asp-action="Create" class="btn-create-scanner">
            <i class="fas fa-plus"></i> Create Scanner
        </a>
    </div>
</div>