@using System.Security.Claims
@using Eventify.Domain.Constants
@model IEnumerable<EventifyPro.BLL.DTOs.Review.ReviewResponseDto>
@{
    var eventTitle = Model.FirstOrDefault()?.EventTitle ?? "Event";
    ViewData["Title"] = $"Reviews - {eventTitle}";
    
    var reviewsCount = Model.Count();
    var averageRating = reviewsCount > 0 ? Model.Average(r => (double)r.Rating) : 0.0;
    
    var starCounts = new int[6];
    foreach (var r in Model)
    {
        if (r.Rating >= 1 && r.Rating <= 5)
        {
            starCounts[r.Rating]++;
        }
    }
    
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isAdmin = User.IsInRole(RoleNames.Admin);
}

<div class="bg-animation">
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>
    <div class="bg-blob blob-3"></div>
</div>

<div class="page-header">
    <div class="container">
        <h1>Event <span class="gradient-text">Reviews</span></h1>
        <p>Real feedback from people who attended: <strong>@eventTitle</strong></p>
    </div>
</div>

<div class="container" style="padding-top: 40px; padding-bottom: 80px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background: rgba(16, 185, 129, 0.1); border: 1px solid var(--success); color: var(--success); padding: 16px 20px; border-radius: 12px; margin-bottom: 30px; font-weight: 600;">
            <i class="fas fa-check-circle" style="margin-right: 8px;"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid var(--error); color: var(--error); padding: 16px 20px; border-radius: 12px; margin-bottom: 30px; font-weight: 600;">
            <i class="fas fa-exclamation-circle" style="margin-right: 8px;"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="checkout-grid reviews-layout-grid">
        <!-- Left: Rating Summary Breakdown -->
        <div class="summary-card">
            <h3>Reviews Summary</h3>
            <div class="rating-big" style="margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--border);">
                <h1>@averageRating.ToString("F1")</h1>
                <div class="stars">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round(averageRating))
                        {
                            <i class="fas fa-star"></i>
                        }
                        else
                        {
                            <i class="far fa-star"></i>
                        }
                    }
                </div>
                <p>Based on @reviewsCount review@(reviewsCount != 1 ? "s" : "")</p>
            </div>

            <div class="rating-bars">
                @for (int stars = 5; stars >= 1; stars--)
                {
                    var count = starCounts[stars];
                    var pct = reviewsCount > 0 ? (count * 100.0) / reviewsCount : 0.0;
                    <div class="rating-row">
                        <span style="font-weight: 600; color: var(--text-light);">@stars <i class="fas fa-star" style="color: #fcd34d; font-size: 11px;"></i></span>
                        <div class="bar">
                            <div class="fill" style="width: @pct.ToString("F1")%;"></div>
                        </div>
                        <span style="color: var(--text-light); font-weight: 500; text-align: right;">@count</span>
                    </div>
                }
            </div>

            <div style="margin-top: 30px; text-align: center;">
                <a href="/Events/Details/@(ViewBag.EventId ?? Model.FirstOrDefault()?.EventId ?? 0)" class="btn-outline btn-full btn-small">
                    <i class="fas fa-chevron-left"></i> Back to Event Details
                </a>
            </div>
        </div>

        <!-- Right: Reviews List -->
        <div class="checkout-card" style="margin-bottom: 0;">
            <h3><i class="fas fa-comments"></i> Attendees Feedback</h3>

            @if (!Model.Any())
            {
                <div class="empty-state" style="padding: 40px 20px;">
                    <i class="far fa-comments" style="font-size: 60px; color: var(--light-purple); margin-bottom: 16px; display: block;"></i>
                    <h3>No Reviews Yet</h3>
                    <p style="color: var(--text-light);">Be the first one to share your experience after attending this event.</p>
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 10px;">
                    @foreach (var review in Model)
                    {
                        if (review.IsHidden && !isAdmin)
                        {
                            continue; // Don't show hidden reviews unless user is admin
                        }

                        <div class="review-item" style="align-items: flex-start; @(review.IsHidden ? "opacity: 0.6; background: rgba(239, 68, 68, 0.03); padding: 16px; border-radius: 12px; border: 1px dashed var(--error);" : "")">
                            <img src="https://api.dicebear.com/7.x/initials/svg?seed=@Uri.EscapeDataString(review.UserName)" alt="@review.UserName" />
                            <div style="flex: 1;">
                                <div class="review-head">
                                    <h4>
                                        @review.UserName
                                        @if (review.IsHidden)
                                        {
                                            <span style="font-size: 10px; background: var(--error); color: white; padding: 2px 8px; border-radius: 10px; margin-left: 8px;">Hidden (Moderated)</span>
                                        }
                                    </h4>
                                    <div class="stars-small">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <i class="fas fa-star"></i>
                                            }
                                            else
                                            {
                                                <i class="far fa-star"></i>
                                            }
                                        }
                                    </div>
                                </div>
                                <div class="review-date">Reviewed on @review.CreatedAt.ToEgyptTime().ToString("MMMM dd, yyyy")</div>
                                <p style="color: var(--text); font-size: 14px; line-height: 1.6; white-space: pre-line;">@review.Comment</p>

                                <!-- Moderation Actions -->
                                @if (isAdmin || (currentUserId == review.UserId) || (currentUserId == review.OrganizerId))
                                {
                                    <div style="display: flex; gap: 12px; margin-top: 12px; justify-content: flex-end;">
                                        @if (currentUserId == review.UserId || currentUserId == review.OrganizerId)
                                        {
                                            <form asp-controller="Review" asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this review?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@review.Id" />
                                                <input type="hidden" name="eventId" value="@review.EventId" />
                                                <button type="submit" style="background: none; border: none; color: var(--error); font-size: 12px; cursor: pointer; font-weight: 600;">
                                                    <i class="fas fa-trash"></i> Delete
                                                </button>
                                            </form>
                                        }
                                        @if (isAdmin && !review.IsHidden)
                                        {
                                            <form asp-controller="Review" asp-action="HideReview" method="post" onsubmit="return confirm('Are you sure you want to hide this review from public view?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@review.Id" />
                                                <input type="hidden" name="eventId" value="@review.EventId" />
                                                <button type="submit" style="background: none; border: none; color: var(--warning); font-size: 12px; cursor: pointer; font-weight: 600;">
                                                    <i class="fas fa-eye-slash"></i> Hide Review
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
