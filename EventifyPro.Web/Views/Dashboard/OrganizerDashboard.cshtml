                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon icon-green">
                        <i class="fas fa-coins"></i>
                    </div>
                    <div class="stat-info">
                        <p>Total Revenue</p>
                        <h3>EGP <span id="total-revenue-amount">@string.Format("{0:N0}", Model.TotalRevenue)</span></h3>
                        <span class="trend up"><i class="fas fa-coins"></i> Gross Sales</span>
                    </div>
                </div>
                <a href="/OrganizerReviews" class="stat-card" style="text-decoration: none; color: inherit;">
                    <div class="stat-icon icon-purple" style="background: linear-gradient(135deg, #f59e0b, #fbbf24);">
                        <i class="fas fa-star"></i>
                    </div>
                    <div class="stat-info">
                        <p>Avg Event Rating</p>
                        <h3>@Model.AverageEventRating.ToString("F1")</h3>
                        <span class="trend up" style="color: #f59e0b;"><i class="fas fa-star"></i> Stars</span>
                    </div>
                </a>
                <div class="stat-card">
                    <div class="stat-icon icon-pink" style="background: linear-gradient(135deg, #06b6d4, #22d3ee);">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-info">
                        <p>Total Attendees</p>
                        <h3 id="total-attendees-count">@Model.TotalAttendees</h3>
                        <span class="trend up" style="color: #06b6d4;"><i class="fas fa-user-check"></i> Present</span>
                    </div>
                </div>
                <a href="/OrganizerWaitingList" class="stat-card" style="text-decoration: none; color: inherit;">
                    <div class="stat-icon icon-blue" style="background: linear-gradient(135deg, #ec4899, #f43f5e);">
                        <i class="fas fa-hourglass-half"></i>
                    </div>
                    <div class="stat-info">
                        <p>Waiting List</p>
                        <h3>@Model.WaitingListCount</h3>
                        <span class="trend up" style="color: #ec4899;"><i class="fas fa-clock"></i> Active Requests</span>
                    </div>
                </a>
            </div>

            <!-- Visualization Charts -->
            <div class="dashboard-grid">
                <!-- Revenue By Month -->
                <div class="chart-card" id="monthlyRevenueChartCard">
                    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
                        <h3>Monthly Sales Revenue Trend</h3>
                        <button type="button" onclick="exportChartAsImage('monthlyRevenueChartCard')" style="background: none; border: 1.5px solid var(--border); padding: 6px 10px; border-radius: 8px; font-size: 12px; cursor: pointer; color: var(--text-light); transition: var(--transition); outline: none; display: inline-flex; align-items: center; justify-content: center;" title="Export Chart as Image">
                            <i class="fas fa-camera"></i>
                        </button>
                    </div>
                    <div class="chart-area">
                        @if (revenueList.Any())
                        {
                            <div class="chart-bars">
                                @foreach (var rev in revenueList)
                                {
                                    double barHeight = (double)(rev.Value / maxRevenue) * 90;
                                    System.DateTime.TryParseExact(rev.Key, "yyyy-MM", System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var dtParsed);
                                    var displayLabel = dtParsed != default ? dtParsed.ToString("MMM yy") : rev.Key;
                                    var displayTooltip = dtParsed != default ? dtParsed.ToString("MMMM yyyy") : rev.Key;
                                    <div class="bar-container">
                                        <div class="bar" style="height: @(barHeight)%" title="Month: @displayTooltip | Sales: @string.Format("{0:N0}", rev.Value) EGP"></div>
                                        <div class="bar-label">@displayLabel</div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div style="width: 100%; text-align: center; color: var(--text-light); font-size: 14px;">
                                <i class="fas fa-chart-bar" style="font-size: 40px; margin-bottom: 12px; color: var(--accent);"></i>
                                <p>No monthly revenue records found.</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Booking Status Breakdown -->
                <div class="chart-card" id="bookingsBreakdownChartCard">
                    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
                        <h3>Bookings Breakdown</h3>
                        <button type="button" onclick="exportChartAsImage('bookingsBreakdownChartCard')" style="background: none; border: 1.5px solid var(--border); padding: 6px 10px; border-radius: 8px; font-size: 12px; cursor: pointer; color: var(--text-light); transition: var(--transition); outline: none; display: inline-flex; align-items: center; justify-content: center;" title="Export Chart as Image">
                            <i class="fas fa-camera"></i>
                        </button>
                    </div>
                    <div class="donut-chart">
                        @if (Model.BookingStatusBreakdown.Values.Sum() > 0)
                        {
                            <div class="donut" style="background: conic-gradient(var(--success) 0deg @(compDeg)deg, var(--warning) @(compDeg)deg @(compDeg + pendDeg)deg, var(--primary) @(compDeg + pendDeg)deg @(compDeg + pendDeg + refDeg)deg, var(--error) @(compDeg + pendDeg + refDeg)deg 360deg);">
                                <div class="donut-center">
                                    @Model.TotalBookings
                                    <span>Bookings</span>
                                </div>
                            </div>
                            <div class="donut-legend">
                                <div><span class="dot completed"></span> Confirmed (@compPercent%)</div>
                                <div><span class="dot pending"></span> Pending (@pendPercent%)</div>
                                <div><span class="dot refunded"></span> Refunded (@refPercent%)</div>
                                <div><span class="dot cancelled"></span> Cancelled (@cancPercent%)</div>
                            </div>
                        }
                        else
                        {
                            <div style="text-align: center; padding: 40px 0; color: var(--text-light);">
                                <i class="fas fa-pie-chart" style="font-size: 40px; margin-bottom: 12px; color: var(--accent);"></i>
                                <p>No bookings data to visualize.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Top Performing Events Table -->
            <div class="table-card">
                <div class="card-title-container">
                    <h3>Top Performing Events</h3>
                    <a href="/Events/OrganizerIndex" class="btn-primary btn-small">
                        <i class="fas fa-tasks"></i> All My Events
                    </a>
                </div>
                @if (Model.TopEvents.Any())
                {
                    <div class="table-wrapper">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Event Title</th>
                                    <th>Start Date</th>
                                    <th>Bookings</th>
                                    <th>Tickets Sold</th>
                                    <th>Average Price</th>
                                    <th>Total Revenue</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ev in Model.TopEvents)
                                {
                                    <tr>
                                        <td style="font-weight: 700; color: var(--primary);">@ev.EventTitle</td>
                                        <td>@ev.StartDate.ToEgyptTime().ToString("MMM dd, yyyy")</td>
                                        <td>@ev.TotalBookings</td>
                                        <td>@ev.TotalTicketsSold</td>
                                        <td>@ev.AverageTicketPrice.ToString("F2") EGP</td>
                                        <td style="font-weight: 700; color: var(--success);">@string.Format("{0:N2}", ev.TotalRevenue) EGP</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div style="text-align: center; padding: 48px; color: var(--text-light);">
                        <i class="fas fa-calendar-xmark" style="font-size: 44px; color: var(--accent); margin-bottom: 16px;"></i>
                        <h3 style="font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 4px;">No Events Found</h3>
                        <p style="font-size: 14px;">Create an event to start tracking sales performance!</p>
                    </div>
                }
            </div>
            
            <!-- Toast Notification Container -->
            <div id="toast-container" class="toast-container"></div>
        

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js" integrity="sha512-BNaRQnYjYiPSqHHDb58B0yaPfYLjYEXyyp8AM5tcJHURGmsUt28OhiGyVqYh5tzyIno5w98xCgQdfye50+5rUA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
        function exportChartAsImage(elementId) {
            const element = document.getElementById(elementId);
            if (!element) return;
            
            html2canvas(element, {
                backgroundColor: "#ffffff",
                scale: 2,
                logging: false,
                useCORS: true
            }).then(canvas => {
                const link = document.createElement('a');
                link.download = elementId + '_' + new Date().toISOString().slice(0, 10) + '.png';
                link.href = canvas.toDataURL('image/png');
                link.click();
            });
        }

        // ============================================
        // SIGNALR LIVE NOTIFICATIONS & UPDATES
        // ============================================
        (function() {
            const organizerId = '@ViewBag.OrganizerId';
            console.log("[SignalR Hub] Retrieved Organizer ID:", organizerId);
            if (!organizerId) {
                console.warn("[SignalR Hub] Organizer ID is empty. SignalR live updates skipped.");
                return;
            }

            const normalizedOrganizerId = organizerId.toLowerCase();

            // Create SignalR connection
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/notification")
                .configureLogging(signalR.LogLevel.Information)
                .withAutomaticReconnect()
                .build();

            // Start connection
            connection.start().then(function () {
                console.log("[SignalR Hub] Connected successfully!");
                connection.invoke("JoinOrganizerGroup", normalizedOrganizerId)
                    .then(() => console.log("[SignalR Hub] Joined group: organizer_" + normalizedOrganizerId))
                    .catch(err => console.error("[SignalR Hub] Error joining group: ", err));
            }).catch(function (err) {
                return console.error("[SignalR Hub] Connection failed: ", err.toString());
            });

            // Handle connection states for debug / logging
            connection.onreconnecting(error => {
                console.warn(`[SignalR Hub] Connection lost due to error "${error}". Reconnecting.`);
            });

            connection.onreconnected(() => {
                console.log("[SignalR Hub] Connection reestablished.");
                connection.invoke("JoinOrganizerGroup", normalizedOrganizerId);
            });

            // Listen for ticket bookings
            connection.on("ReceiveTicketBooked", function (data) {
                console.log("Ticket booked notification received: ", data);

                // Play synthesized pleasant audio chime
                playChime();

                // 1. Show dynamic Toast notification
                showToast('booking', 'New Ticket Booked! 🎟️', 
                    `<strong>${escapeHtml(data.attendeeName)}</strong> booked <strong>${data.quantity}</strong> tickets for <em>${escapeHtml(data.eventTitle)}</em> (EGP ${data.totalAmount.toLocaleString()}).`
                );

                // 2. Update Stats counts
                const bookingsElem = document.getElementById('total-bookings-count');
                if (bookingsElem) {
                    let currentBookings = parseInt(bookingsElem.textContent.replace(/,/g, '')) || 0;
                    bookingsElem.textContent = (currentBookings + data.quantity).toLocaleString();
                    highlightCard(bookingsElem);
                }

                const revenueElem = document.getElementById('total-revenue-amount');
                if (revenueElem) {
                    let currentRevenue = parseFloat(revenueElem.textContent.replace(/,/g, '')) || 0;
                    revenueElem.textContent = (currentRevenue + data.totalAmount).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
                    highlightCard(revenueElem);
                }
            });

            // Listen for ticket scans
            connection.on("ReceiveTicketScanned", function (data) {
                console.log("Ticket scanned notification received: ", data);

                // 1. Show dynamic Toast notification
                showToast('scan', 'Attendee Checked In! ✅', 
                    `<strong>${escapeHtml(data.attendeeName)}</strong> checked in for <em>${escapeHtml(data.eventTitle)}</em> (${escapeHtml(data.ticketTypeName)}).`
                );

                // 2. Update Stats counts
                const attendeesElem = document.getElementById('total-attendees-count');
                if (attendeesElem) {
                    let currentAttendees = parseInt(attendeesElem.textContent.replace(/,/g, '')) || 0;
                    attendeesElem.textContent = (currentAttendees + 1).toLocaleString();
                    highlightCard(attendeesElem);
                }
            });
        })();

        function showToast(type, title, message) {
            const container = document.getElementById('toast-container');
            if (!container) return;

            const toast = document.createElement('div');
            toast.className = `toast-notification ${type}`;

            const icon = type === 'booking' ? 'fa-ticket-alt' : 'fa-user-check';
            const iconClass = type === 'booking' ? 'booking' : 'scan';

            toast.innerHTML = `
                <div class="toast-icon-wrapper ${iconClass}">
                    <i class="fas ${icon}"></i>
                </div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-message">${message}</div>
                </div>
                <button class="toast-close" onclick="this.parentElement.remove()">
                    <i class="fas fa-times"></i>
                </button>
            `;

            container.appendChild(toast);

            // Trigger reflow
            toast.offsetHeight;
            toast.classList.add('show');

            // Auto remove after 5 seconds
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                    toast.remove();
                }, 400);
            }, 5000);
        }

        function playChime() {
            try {
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                const now = audioCtx.currentTime;
                
                // Note 1: C5
                const osc1 = audioCtx.createOscillator();
                const gain1 = audioCtx.createGain();
                osc1.type = 'sine';
                osc1.frequency.setValueAtTime(523.25, now);
                gain1.gain.setValueAtTime(0.12, now);
                gain1.gain.exponentialRampToValueAtTime(0.001, now + 0.35);
                osc1.connect(gain1);
                gain1.connect(audioCtx.destination);
                osc1.start(now);
                osc1.stop(now + 0.35);
                
                // Note 2: E5
                const osc2 = audioCtx.createOscillator();
                const gain2 = audioCtx.createGain();
                osc2.type = 'sine';
                osc2.frequency.setValueAtTime(659.25, now + 0.08);
                gain2.gain.setValueAtTime(0.12, now + 0.08);
                gain2.gain.exponentialRampToValueAtTime(0.001, now + 0.45);
                osc2.connect(gain2);
                gain2.connect(audioCtx.destination);
                osc2.start(now + 0.08);
                osc2.stop(now + 0.45);
            } catch (e) {
                console.warn("Could not play sound:", e);
            }
        }

        function highlightCard(element) {
            if (!element) return;
            const card = element.closest('.stat-card');
            if (card) {
                card.classList.remove('pulse-highlight');
                void card.offsetWidth; // Trigger reflow to restart animation
                card.classList.add('pulse-highlight');
                setTimeout(() => card.classList.remove('pulse-highlight'), 1000);
            }
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/&/g, "&amp;")
                      .replace(/</g, "&lt;")
                      .replace(/>/g, "&gt;")
                      .replace(/"/g, "&quot;")
                      .replace(/'/g, "&#039;");
        }
    </script>
}
