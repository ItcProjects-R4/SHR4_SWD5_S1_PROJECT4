<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Eventify Pro - Egypt's Premier Event Booking Platform")</title>
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon.png?v=2" />
    <link rel="icon" type="image/png" sizes="192x192" href="~/favicon.png?v=2" />
    @if (ViewData["MetaDescription"] != null)
    {
        <meta name="description" content="@ViewData["MetaDescription"]" />
    }
    else
    {
        <meta name="description" content="Eventify Pro is the leading Egyptian platform to discover, book, and manage events, concerts, and workshops." />
    }
    @if (ViewData["MetaKeywords"] != null)
    {
        <meta name="keywords" content="@ViewData["MetaKeywords"]" />
    }
    else
    {
        <meta name="keywords" content="Egypt events, ticket booking, concerts Cairo, workshops Egypt, event management" />
    }

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@(ViewData["Title"] ?? "Eventify Pro - Egypt's Premier Event Booking Platform")" />
    <meta property="og:description" content="@(ViewData["MetaDescription"] ?? "Eventify Pro is the leading Egyptian platform to discover, book, and manage events, concerts, and workshops.")" />
    <meta property="og:image" content="~/Images/Logo.png" />
    <meta property="og:url" content="@(Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path)" />

    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/support-pages-enhanced.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ux-improvements.css" asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
    <a href="#main-content" class="skip-link" style="position: absolute; top: -100px; left: 20px; background: var(--primary); color: white; padding: 10px 20px; z-index: 100000; transition: top 0.2s ease-in-out; font-weight: 700; border-radius: 0 0 10px 10px; text-decoration: none; box-shadow: var(--shadow-md);" onfocus="this.style.top='0'" onblur="this.style.top='-100px'">Skip to main content</a>

    <partial name="_Navbar" />

    <main id="main-content">
        @if (TempData["PaymentSuccess"] != null)
        {
            <div class="alert alert-success" style="background: #dcfce7; border: 1px solid #86efac; color: #166534; padding: 16px; border-radius: 12px; margin: 24px auto; max-width: 1200px; display: flex; align-items: center; gap: 12px;">
                <i class="fas fa-check-circle" style="font-size: 20px;"></i>
                <div>@TempData["PaymentSuccess"]</div>
            </div>
        }
        @RenderBody()
    </main>

    <partial name="_Footer" />

    <script src="~/js/ux-improvements.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>