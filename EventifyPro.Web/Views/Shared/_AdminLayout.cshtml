@inject Microsoft.AspNetCore.Identity.UserManager<Eventify.Domain.Entities.ApplicationUser> UserManager
@{
    var user = await UserManager.GetUserAsync(User);
    var fullName = user?.FullName ?? User.Identity?.Name ?? "Admin User";
    var avatarUrl = user?.ProfileImageUrl;

    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eventify Pro Admin</title>
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon.png?v=2" />
    <link rel="icon" type="image/png" sizes="192x192" href="~/favicon.png?v=2" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    <link rel="stylesheet" href="~/css/admin-layout-custom.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ux-improvements.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
</head>
<body>
    <a href="#main-content" class="skip-link" style="position: absolute; top: -100px; left: 20px; background: var(--primary); color: white; padding: 10px 20px; z-index: 100000; transition: top 0.2s ease-in-out; font-weight: 700; border-radius: 0 0 10px 10px; text-decoration: none; box-shadow: var(--shadow-md);" onfocus="this.style.top='0'" onblur="this.style.top='-100px'">Skip to main content</a>

    <div class="dashboard-layout">
        <!-- Sidebar -->
        <aside class="sidebar admin-sidebar">
            <div class="sidebar-header" style="display: flex; justify-content: space-between; align-items: center; position: relative;">
                <a href="/Admin/Index" class="logo">
                    <div class="logo-icon"><i class="fas fa-magic"></i></div>
                    <span class="logo-text">Eventify <b>Pro</b></span>
                </a>
                <button id="sidebarCollapse" aria-label="Collapse Sidebar" style="background: none; border: none; color: var(--text-light); cursor: pointer; font-size: 16px; padding: 4px; display: flex; align-items: center; justify-content: center; transition: var(--transition);"><i class="fas fa-chevron-left"></i></button>
                <button class="mobile-toggle" id="sidebarClose" aria-label="Close Sidebar"><i class="fas fa-times"></i></button>
            </div>
            
            <nav class="sidebar-nav">
                <div class="nav-label">Core Management</div>
                <a href="/Dashboard/Admin" class="nav-item @(currentController == "Dashboard" && currentAction == "Admin" ? "active" : "")">
                    <i class="fas fa-chart-line"></i> Dashboard
                </a>
                <a href="/Admin/Index" class="nav-item @(currentController == "Admin" && (currentAction == "Index" || currentAction == "") ? "active" : "")">
                    <i class="fas fa-th-large"></i> Moderation Queue
                </a>
                <a href="/Admin/Users" class="nav-item @(currentController == "AdminUsers" && currentAction == "Users" ? "active" : "")">
                    <i class="fas fa-users"></i> Users
                </a>
                <a href="/Admin/Events" class="nav-item @(currentController == "AdminEvents" && currentAction == "Events" ? "active" : "")">
                    <i class="fas fa-calendar-alt"></i> Events
                </a>
                <a href="/Admin/Categories" class="nav-item @(currentController == "AdminCategories" && currentAction == "Categories" ? "active" : "")">
                    <i class="fas fa-tags"></i> Categories
                </a>
                <a href="/Admin/Reviews" class="nav-item @(currentController == "AdminReviews" && currentAction == "Reviews" ? "active" : "")">
                    <i class="fas fa-star"></i> Reviews
                </a>
                <a href="/Admin/Payouts" class="nav-item @(currentController == "Admin" && currentAction == "Payouts" ? "active" : "")">
                    <i class="fas fa-wallet"></i> Payout Requests
                </a>

                <div class="nav-label">System & Security</div>
                <a href="/Admin/Settings" class="nav-item @(currentController == "AdminSettings" && currentAction == "Settings" ? "active" : "")">
                    <i class="fas fa-sliders-h"></i> Settings
                </a>
                <a href="/Admin/Security" class="nav-item @(currentController == "AdminSettings" && currentAction == "Security" ? "active" : "")">
                    <i class="fas fa-shield-alt"></i> Security Policies
                </a>
                <a href="/Admin/AuditLogs" class="nav-item @(currentController == "AdminSettings" && currentAction == "AuditLogs" ? "active" : "")">
                    <i class="fas fa-clipboard-list"></i> Audit Logs
                </a>
                <a href="/Admin/SystemHealth" class="nav-item @(currentController == "AdminSettings" && currentAction == "SystemHealth" ? "active" : "")">
                    <i class="fas fa-server"></i> System Health
                </a>
                <a href="/Admin/Notifications" class="nav-item @(currentController == "Admin" && currentAction == "Notifications" ? "active" : "")">
                    <i class="fas fa-bell"></i> Notifications
                </a>

                <div class="nav-label">Personal</div>
                <a href="/Admin/Profile" class="nav-item @(currentController == "Admin" && currentAction == "Profile" ? "active" : "")">
                    <i class="fas fa-user-circle"></i> Profile
                </a>
                
                <form asp-controller="Account" asp-action="Logout" method="post" onsubmit="return confirm('Are you sure you want to log out?');" style="margin-top: 40px; padding: 0 12px;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-item" style="width: 100%; border: none; background: transparent; cursor: pointer; color: var(--error); text-align: left; font-family: inherit;">
                        <i class="fas fa-sign-out-alt"></i> Sign Out
                    </button>
                </form>
            </nav>
        </aside>

        <!-- Main Workspace -->
        <main class="dashboard-main" id="main-content">
            <!-- Header -->
            <header class="dashboard-header">
                <div class="header-left" style="display: flex; align-items: center; gap: 15px;">
                    <button class="mobile-toggle" id="sidebarToggle" aria-label="Toggle Navigation"><i class="fas fa-bars"></i></button>
                    <div class="header-title-block">
                        <!-- Dynamic Breadcrumbs -->
                        <nav class="breadcrumbs" style="margin-bottom: 8px; font-size: 13px; color: var(--text-light); display: flex; align-items: center; gap: 8px;">
                            <a href="/Dashboard/Admin" style="color: var(--primary); text-decoration: none; font-weight: 500;"><i class="fas fa-home"></i> Admin</a>
                            <i class="fas fa-chevron-right" style="font-size: 9px;"></i>
                            @if (currentController == "Dashboard" && currentAction == "Admin")
                            {
                                <span style="font-weight: 600; color: var(--text);">Dashboard</span>
                            }
                            else if (currentController == "Admin" && (currentAction == "Index" || currentAction == ""))
                            {
                                <span style="font-weight: 600; color: var(--text);">Moderation Queue</span>
                            }
                            else if (currentController == "AdminUsers")
                            {
                                <span style="font-weight: 600; color: var(--text);">Users</span>
                            }
                            else if (currentController == "AdminCategories")
                            {
                                <span style="font-weight: 600; color: var(--text);">Categories</span>
                            }
                            else if (currentController == "AdminReviews")
                            {
                                <span style="font-weight: 600; color: var(--text);">Reviews</span>
                            }
                            else if (currentController == "AdminEvents")
                            {
                                <span style="font-weight: 600; color: var(--text);">Events</span>
                            }
                            else if (currentController == "AdminSettings" && currentAction == "Settings")
                            {
                                <span style="font-weight: 600; color: var(--text);">System Settings</span>
                            }
                            else if (currentController == "AdminSettings" && currentAction == "Security")
                            {
                                <span style="font-weight: 600; color: var(--text);">Security Settings</span>
                            }
                            else if (currentController == "AdminSettings" && currentAction == "AuditLogs")
                            {
                                <span style="font-weight: 600; color: var(--text);">Audit Logs</span>
                            }
                            else if (currentController == "AdminSettings" && currentAction == "SystemHealth")
                            {
                                <span style="font-weight: 600; color: var(--text);">System Health</span>
                            }
                            else if (currentController == "Admin" && currentAction == "Notifications")
                            {
                                <span style="font-weight: 600; color: var(--text);">Notifications</span>
                            }
                            else if (currentController == "Admin" && currentAction == "Profile")
                            {
                                <span style="font-weight: 600; color: var(--text);">Profile</span>
                            }
                        </nav>
                        
                        <h2>@ViewData["HeaderTitle"]</h2>
                        <p>@ViewData["HeaderSubtitle"]</p>
                    </div>
                </div>
                <div class="header-right">
                    <!-- Notification Center Component -->
                    @await Component.InvokeAsync("NotificationCenter")
                    
                    <a href="/Admin/Profile" class="user-menu">
                        @if (!string.IsNullOrEmpty(avatarUrl))
                        {
                            <img src="@avatarUrl" alt="Avatar" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover; border: 2px solid var(--accent);" />
                        }
                        else
                        {
                            <div style="width: 36px; height: 36px; border-radius: 50%; font-size: 14px; font-weight: 700; background: var(--primary-light); color: var(--white); display: flex; align-items: center; justify-content: center;">
                                @(string.IsNullOrEmpty(fullName) ? "AD" : string.Concat(fullName.Split(' ').Select(s => s[0])).ToUpper())
                            </div>
                        }
                        <div>
                            <h4>@fullName</h4>
                            <p>Super Admin</p>
                        </div>
                    </a>
                </div>
            </header>

            <!-- Alerts -->
            @if (TempData["AdminSuccess"] is string successMsg)
            {
                <div class="alert-banner" role="alert">
                    <span><i class="fas fa-check-circle" style="margin-right: 8px;"></i> @successMsg</span>
                    <button type="button" onclick="this.parentElement.remove()" style="background: none; border: none; color: inherit; cursor: pointer; font-size: 18px;">&times;</button>
                </div>
            }
            @if (TempData["AdminError"] is string errorMsg)
            {
                <div class="alert-banner error" role="alert">
                    <span><i class="fas fa-exclamation-circle" style="margin-right: 8px;"></i> @errorMsg</span>
                    <button type="button" onclick="this.parentElement.remove()" style="background: none; border: none; color: inherit; cursor: pointer; font-size: 18px;">&times;</button>
                </div>
            }
            @if (TempData["AdminFeedbackSuccess"] is string fbSuccessMsg)
            {
                <div class="alert-banner" role="alert">
                    <span><i class="fas fa-check-circle" style="margin-right: 8px;"></i> @fbSuccessMsg</span>
                    <button type="button" onclick="this.parentElement.remove()" style="background: none; border: none; color: inherit; cursor: pointer; font-size: 18px;">&times;</button>
                </div>
            }

            <!-- Body Body content -->
            @RenderBody()
        </main>
    </div>

    <!-- Beautiful Custom Confirmation Modal -->
    <div id="customConfirmModal" class="confirm-modal-overlay">
        <div class="confirm-modal-card">
            <div class="confirm-modal-icon">
                <i class="fas fa-question"></i>
            </div>
            <h3 class="confirm-modal-title">Confirm Action</h3>
            <p id="customConfirmMessage" class="confirm-modal-message">Are you sure you want to perform this action?</p>
            <div class="confirm-modal-actions">
                <button type="button" id="btnConfirmCancel" class="btn-confirm-cancel">Cancel</button>
                <button type="button" id="btnConfirmYes" class="btn-confirm-yes">Yes, Proceed</button>
            </div>
        </div>
    </div>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <script src="~/js/admin-layout-custom.js" asp-append-version="true"></script>
    <script src="~/js/ux-improvements.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
