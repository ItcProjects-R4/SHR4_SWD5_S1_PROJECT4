@inject EventifyPro.BLL.Services.Interfaces.ISystemSettingService SystemSettingService
@{
    var platformName = await SystemSettingService.GetSettingValueAsync("PlatformName", "Eventify Pro");
    var supportEmail = await SystemSettingService.GetSettingValueAsync("SupportEmail", "eventifypro.eg@gmail.com");
    var supportWhatsApp = await SystemSettingService.GetSettingValueAsync("SupportWhatsApp", "01064665247");

    var whatsappLink = "#";
    if (!string.IsNullOrEmpty(supportWhatsApp))
    {
        var cleanNumber = new string(supportWhatsApp.Where(char.IsDigit).ToArray());
        if (cleanNumber.StartsWith("01"))
        {
            cleanNumber = "2" + cleanNumber;
        }
        else if (cleanNumber.StartsWith("1"))
        {
            cleanNumber = "20" + cleanNumber;
        }
        whatsappLink = $"https://wa.me/{cleanNumber}";
    }
}
<footer class="footer" id="contact">
    <div class="container">
        <div class="footer-grid">
            <div class="footer-col">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <div class="logo-icon">
                        <img src="/Images/Logo-1.png" alt="Logo" class="logo-img" />
                    </div>
                    <span>@platformName</span>
                </a>
                <p>
                    The complete platform for managing events and selling tickets with
                    the latest technology.
                </p>
                <div class="social-links">
                    <a href="mailto:@supportEmail" title="Gmail"><i class="fas fa-envelope"></i></a>
                    <a href="@whatsappLink" target="_blank" title="WhatsApp"><i class="fab fa-whatsapp"></i></a>
                </div>
            </div>
            <div class="footer-col">
                <h4>Quick Links</h4>
                <ul>
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Events" asp-action="Index">Events</a></li>
                    <li><a href="#features">Features</a></li>
                    <li><a href="#">Pricing</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Support</h4>
                <ul>
                    <li><a asp-controller="Home" asp-action="HelpCenter">Help Center</a></li>
                    <li><a asp-controller="Home" asp-action="FAQs">FAQs</a></li>                 
                    <li><a asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                    <li><a asp-controller="Home" asp-action="Terms">Terms & Conditions</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Share Feedback</h4>
                <p>Your opinion helps us improve events, tickets, scanning, and the whole platform experience.</p>
                <a asp-controller="Home" asp-action="Feedback" class="footer-feedback-link">
                    <i class="fas fa-comment-dots"></i> Send Feedback
                </a>
            </div>
        </div>
        <div class="footer-bottom">
            <p>
                &copy; 2026 Eventify Pro. All rights reserved.
            </p>
        </div>
    </div>
</footer>
