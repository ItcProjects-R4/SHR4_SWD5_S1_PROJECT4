@model EventifyPro.Web.ViewModels.Organizer.OrganizerWaitingListListViewModel
@{
    Layout = "_OrganizerLayout";
    ViewData["Title"] = "Waiting List Management";
    ViewData["HeaderTitle"] = "Waiting List Management ⏳";
    ViewData["HeaderSubtitle"] = "Monitor and manage waiting list queues for your sold-out events.";

    var events = ViewBag.Events as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var ticketTypes = ViewBag.TicketTypes as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var selectedEventId = Model.SelectedEventId;
    var selectedStatus = Model.SelectedStatus;
    var searchTerm = Model.SearchTerm;
    var pageNum = Model.Page;
    var totalPages = Model.TotalPages;
}

@section Styles {
    <style>
        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: white;
            padding: 24px;
            border-radius: 20px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .stat-icon.waiting {
            background: var(--soft-purple);
            color: var(--primary);
        }

        .stat-icon.notified {
            background: rgba(245, 158, 11, 0.1);
            color: #d97706;
        }

        .stat-icon.converted {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .stat-icon.conversion {
            background: rgba(124, 58, 237, 0.1);
            color: var(--primary-dark);
        }

        .stat-info h3 {
            font-size: 24px;
            font-weight: 800;
            color: var(--text);
            line-height: 1;
            margin-bottom: 6px;
        }

        .stat-info p {
            font-size: 13px;
            color: var(--text-light);
            font-weight: 500;
        }

        /* Filter Panel */
        .filter-panel {
            background: white;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 20px 24px;
            margin-bottom: 28px;
            box-shadow: var(--shadow-sm);
        }

        .filter-form {
            display: flex;
            gap: 16px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .filter-group label {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .filter-input {
            padding: 10px 16px;
            border-radius: 10px;
            border: 1px solid var(--border);
            font-family: inherit;
            font-size: 14px;
            outline: none;
            transition: var(--transition);
            background: var(--soft-purple);
            min-width: 200px;
        }

        .filter-input:focus {
            border-color: var(--primary);
            background: white;
        }

        .filter-select {
            padding: 10px 16px;
            border-radius: 10px;
            border: 1px solid var(--border);
            font-family: inherit;
            font-size: 14px;
            outline: none;
            transition: var(--transition);
            background: var(--soft-purple);
            cursor: pointer;
            min-width: 200px;
        }

        .filter-select:focus {
            border-color: var(--primary);
            background: white;
        }

        .filter-buttons {
            display: flex;
            gap: 10px;
            align-items: center;
            margin-bottom: 2px;
        }

        /* Queue Actions Panel */
        .queue-actions-panel {
            background: linear-gradient(135deg, #fbfaff 0%, #f5f3ff 100%);
            border: 1px solid var(--light-purple);
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 24px;
            box-shadow: var(--shadow-sm);
        }

        @@media (max-width: 768px) {
            .queue-actions-panel {
                flex-direction: column;
                align-items: flex-start;
            }
        }

        .panel-info h3 {
            font-size: 16px;
            font-weight: 700;
            color: var(--primary-dark);
            margin-bottom: 4px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .panel-info p {
            font-size: 13.5px;
            color: var(--text-light);
        }

        .panel-buttons {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .form-inline-action {
            display: inline-block;
        }

        /* Table & Data Styles */
        .table-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
        }

        .table-responsive {
            overflow-x: auto;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table th {
            background: var(--bg);
            padding: 16px 24px;
            text-align: left;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--border);
        }

        .data-table td {
            padding: 16px 24px;
            border-bottom: 1px solid var(--border);
            font-size: 14.5px;
            color: var(--text);
            vertical-align: middle;
        }

        .data-table tbody tr:hover {
            background: var(--soft-purple);
        }

        .user-cell {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--light-purple);
            color: var(--primary);
            font-weight: 700;
            font-size: 13px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--accent);
        }

        .user-meta h4 {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 2px;
        }

        .user-meta p {
            font-size: 11.5px;
            color: var(--text-light);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 50px;
            text-transform: uppercase;
        }

        .status-badge.waiting {
            background: var(--soft-purple);
            color: var(--primary);
        }

        .status-badge.notified {
            background: rgba(245, 158, 11, 0.1);
            color: #d97706;
        }

        .status-badge.converted {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .status-badge.expired {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
        }

        .position-label {
            font-weight: 800;
            color: var(--primary);
            background: var(--soft-purple);
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 13px;
        }

        .action-btn {
            width: 34px;
            height: 34px;
            border: none;
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
            border-radius: 8px;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
        }
        .action-btn:hover {
            background: var(--error);
            color: white;
            transform: translateY(-2px);
        }

        .alert-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 24px;
            font-weight: 600;
            font-size: 14.5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .alert-error {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 24px;
            font-weight: 600;
            font-size: 14.5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .pagination {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 24px;
            padding: 20px;
            border-top: 1px solid var(--border);
        }
        .pagination-link {
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: white;
            color: var(--text);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: var(--transition);
        }
        .pagination-link:hover:not(.disabled) {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--soft-purple);
        }
        .pagination-link.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }
        .pagination-link.disabled {
            color: var(--text-light);
            background: var(--bg);
            cursor: not-allowed;
            pointer-events: none;
        }
    </style>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        <i class="fas fa-check-circle"></i>
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error">
        <i class="fas fa-exclamation-circle"></i>
        @TempData["ErrorMessage"]
    </div>
}

<!-- Stats Row -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon waiting"><i class="fas fa-clock"></i></div>
        <div class="stat-info">
            <h3>@Model.TotalWaiting</h3>
            <p>Waiting in Queue</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon notified"><i class="fas fa-bell"></i></div>
        <div class="stat-info">
            <h3>@Model.TotalNotified</h3>
            <p>Notified Users</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon converted"><i class="fas fa-check-circle"></i></div>
        <div class="stat-info">
            <h3>@Model.TotalConverted</h3>
            <p>Converted Bookings</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon conversion"><i class="fas fa-percentage"></i></div>
        <div class="stat-info">
            <h3>@Model.ConversionRate%</h3>
            <p>Conversion Rate</p>
        </div>
    </div>
</div>

<!-- Filters Panel -->
<div class="filter-panel">
    <form method="get" class="filter-form">
        <div class="filter-group">
            <label>Filter by Event</label>
            <select name="eventId" class="filter-select">
                <option value="">All Events</option>
                @foreach (var ev in events)
                {
                    <option value="@ev.Id" selected="@(selectedEventId == ev.Id)">@ev.Title</option>
                }
            </select>
        </div>

        <div class="filter-group">
            <label>Status</label>
            <select name="status" class="filter-select">
                <option value="">All Statuses</option>
                <option value="Waiting" selected="@(selectedStatus == Eventify.Domain.Enums.WaitingListStatus.Waiting)">Waiting</option>
                <option value="Notified" selected="@(selectedStatus == Eventify.Domain.Enums.WaitingListStatus.Notified)">Notified</option>
                <option value="Converted" selected="@(selectedStatus == Eventify.Domain.Enums.WaitingListStatus.Converted)">Converted</option>
                <option value="Expired" selected="@(selectedStatus == Eventify.Domain.Enums.WaitingListStatus.Expired)">Expired</option>
            </select>
        </div>

        <div class="filter-group">
            <label>Search Attendees</label>
            <input type="text" name="searchTerm" value="@searchTerm" placeholder="Name, email, ticket..." class="filter-input" />
        </div>

        <div class="filter-buttons">
            <button type="submit" class="btn-primary" style="padding: 10px 20px;">
                <i class="fas fa-filter"></i> Filter
            </button>
            @if (selectedEventId.HasValue || selectedStatus.HasValue || !string.IsNullOrWhiteSpace(searchTerm))
            {
                <a href="@Url.Action("Index", "OrganizerWaitingList")" class="btn-secondary" style="padding: 10px 20px;">
                    <i class="fas fa-times"></i> Clear
                </a>
            }
        </div>
    </form>
</div>

<!-- Queue Actions Panel (Displays only when an event is selected) -->
@if (selectedEventId.HasValue)
{
    <div class="queue-actions-panel">
        <div class="panel-info">
            <h3><i class="fas fa-bolt"></i> Queue Operations</h3>
            <p>Advance queue or notify next waiting attendees for this specific event.</p>
        </div>
        <div class="panel-buttons">
            <!-- Advance Queue (Process available spots) -->
            <form asp-action="AdvanceQueue" method="post" class="form-inline-action">
                @Html.AntiForgeryToken()
                <input type="hidden" name="eventId" value="@selectedEventId.Value" />
                <button type="submit" class="btn-primary btn-small" onclick="return confirm('Advance queue automatically? This will process empty spots and notify eligible users.');">
                    <i class="fas fa-arrow-circle-right"></i> Process & Advance Queue
                </button>
            </form>

            <!-- Notify Next per Ticket Type -->
            @foreach (var tt in ticketTypes)
            {
                <form asp-action="NotifyNext" method="post" class="form-inline-action">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ticketTypeId" value="@tt.Id" />
                    <button type="submit" class="btn-secondary btn-small" onclick="return confirm('Notify the next person in line for @Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(tt.Name))?');">
                        <i class="fas fa-paper-plane"></i> Notify Next (@tt.Name)
                    </button>
                </form>
            }
        </div>
    </div>
}

<div class="table-card">
    <div class="table-responsive">
        @if (!Model.Entries.Any())
        {
            <div style="text-align: center; padding: 60px 20px;">
                <div style="font-size: 48px; color: var(--accent); margin-bottom: 20px;"><i class="far fa-hourglass"></i></div>
                <h3>Queue is Empty</h3>
                <p style="color: var(--text-light); font-size: 14.5px; max-width: 400px; margin: 20px auto 0;">No waiting list entries match your filter criteria or no users are waiting for your events.</p>
            </div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Pos</th>
                        <th>Attendee</th>
                        <th>Event</th>
                        <th>Ticket Type</th>
                        <th>Qty</th>
                        <th>Status</th>
                        <th>Joined Date</th>
                        <th>Updates</th>
                        <th style="text-align: right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Model.Entries)
                    {
                        <tr>
                            <td>
                                @if (entry.PositionInQueue > 0)
                                {
                                    <span class="position-label">#@entry.PositionInQueue</span>
                                }
                                else
                                {
                                    <span style="color: var(--text-light); font-weight: 500;">-</span>
                                }
                            </td>
                            <td>
                                <div class="user-cell">
                                    <div class="user-avatar">@entry.AttendeeInitials</div>
                                    <div class="user-meta">
                                        <h4>@entry.AttendeeName</h4>
                                        <p>@entry.AttendeeEmail</p>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div style="font-weight: 600; color: var(--text);">@entry.EventTitle</div>
                            </td>
                            <td>
                                <span style="font-weight: 500; color: var(--primary-dark);">@entry.TicketTypeName</span>
                            </td>
                            <td>
                                <span style="font-weight: 700;">@entry.QuantityWanted</span>
                            </td>
                            <td>
                                @switch (entry.Status)
                                {
                                    case Eventify.Domain.Enums.WaitingListStatus.Waiting:
                                        <span class="status-badge waiting">
                                            <i class="fas fa-clock"></i> Waiting
                                        </span>
                                        break;
                                    case Eventify.Domain.Enums.WaitingListStatus.Notified:
                                        <span class="status-badge notified">
                                            <i class="fas fa-bell"></i> Notified
                                        </span>
                                        break;
                                    case Eventify.Domain.Enums.WaitingListStatus.Converted:
                                        <span class="status-badge converted">
                                            <i class="fas fa-check-circle"></i> Converted
                                        </span>
                                        break;
                                    case Eventify.Domain.Enums.WaitingListStatus.Expired:
                                        <span class="status-badge expired">
                                            <i class="fas fa-times-circle"></i> Expired
                                        </span>
                                        break;
                                }
                            </td>
                            <td>
                                <div style="color: var(--text-light);">@entry.JoinedAt.ToEgyptTime().ToString("MMM dd, yyyy HH:mm")</div>
                            </td>
                            <td>
                                @if (entry.Status == Eventify.Domain.Enums.WaitingListStatus.Notified && entry.NotifiedAt.HasValue)
                                {
                                    <div style="font-size: 12px; color: var(--warning);">
                                        <strong>Notified:</strong> @entry.NotifiedAt.Value.ToEgyptTime().ToString("MMM dd, HH:mm")
                                    </div>
                                    @if (entry.ExpiresAt.HasValue)
                                    {
                                        <div style="font-size: 11px; color: var(--text-light); margin-top: 2px;">
                                            <strong>Expires:</strong> @entry.ExpiresAt.Value.ToEgyptTime().ToString("MMM dd, HH:mm")
                                        </div>
                                    }
                                }
                                else if (entry.Status == Eventify.Domain.Enums.WaitingListStatus.Converted)
                                {
                                    <div style="font-size: 12px; color: var(--success); font-weight: 500;">
                                        Converted to Booking
                                    </div>
                                }
                                else if (entry.Status == Eventify.Domain.Enums.WaitingListStatus.Expired)
                                {
                                    <div style="font-size: 12px; color: var(--error);">
                                        Offer Expired
                                    </div>
                                }
                                else
                                {
                                    <span style="color: var(--text-light); font-style: italic;">In queue...</span>
                                }
                            </td>
                            <td style="text-align: right;">
                                @if (entry.Status == Eventify.Domain.Enums.WaitingListStatus.Waiting)
                                {
                                    <form asp-controller="OrganizerWaitingList" asp-action="Remove" asp-route-id="@entry.Id" method="post" style="display: inline-block;" onsubmit="return confirm('Are you sure you want to remove @Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(entry.AttendeeName)) from the waitlist?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="action-btn" title="Remove from waiting list">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span style="color: var(--text-light); font-size: 12px; font-style: italic;">No actions</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (totalPages > 1)
            {
                <div class="pagination">
                    <a href="@Url.Action("Index", new { eventId = selectedEventId, status = selectedStatus, searchTerm = searchTerm, page = pageNum - 1 })" class="pagination-link @(pageNum == 1 ? "disabled" : "")">
                        <i class="fas fa-chevron-left"></i> Previous
                    </a>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <a href="@Url.Action("Index", new { eventId = selectedEventId, status = selectedStatus, searchTerm = searchTerm, page = i })" class="pagination-link @(pageNum == i ? "active" : "")">@i</a>
                    }
                    <a href="@Url.Action("Index", new { eventId = selectedEventId, status = selectedStatus, searchTerm = searchTerm, page = pageNum + 1 })" class="pagination-link @(pageNum == totalPages ? "disabled" : "")">
                        Next <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            }
        }
    </div>
</div>
