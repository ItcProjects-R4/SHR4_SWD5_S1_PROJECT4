@model Eventify.Shared.Wrappers.PagedResult<EventifyPro.BLL.DTOs.Event.EventSummaryDto>
@{
    Layout = "_AttendeeLayout";
    ViewData["Title"] = "My Registered Events";
    var currentStatus = ViewBag.CurrentStatus as string ?? "all";
}

<style>
    .my-events-header {
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
    }
    
    .my-events-title h1 {
        font-size: 24px;
        font-weight: 800;
        color: var(--primary-dark);
        margin: 0;
    }
    
    .my-events-title p {
        font-size: 14px;
        color: var(--text-light);
        margin: 4px 0 0 0;
    }

    /* Tabs styling */
    .events-tabs {
        display: flex;
        gap: 8px;
        margin-bottom: 28px;
        border-bottom: 1px solid var(--border);
        padding-bottom: 2px;
    }
    
    .tab-link {
        font-size: 14px;
        font-weight: 700;
        color: var(--text-light);
        text-decoration: none;
        padding: 8px 16px 12px 16px;
        border-bottom: 2px solid transparent;
        transition: var(--transition);
        margin-bottom: -2px;
    }
    
    .tab-link:hover {
        color: var(--primary);
    }
    
    .tab-link.active {
        color: var(--primary);
        border-bottom-color: var(--primary);
    }

    .my-events-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
        margin-bottom: 30px;
    }

    .event-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
        display: flex;
        flex-direction: column;
        height: 100%;
        position: relative;
    }

    .event-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
        border-color: var(--primary-light);
    }

    .event-card-image {
        height: 150px;
        width: 100%;
        background-size: cover;
        background-position: center;
        position: relative;
    }

    .event-card-fallback-bg {
        height: 150px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--soft-purple) 0%, rgba(124, 58, 237, 0.1) 100%);
    }

    .event-fallback-icon {
        color: var(--primary);
        font-size: 40px;
    }

    .event-card-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(124, 58, 237, 0.9);
        backdrop-filter: blur(8px);
        color: var(--white);
        padding: 3px 10px;
        border-radius: 30px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .event-card-body {
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .event-card-category {
        font-size: 10.5px;
        font-weight: 700;
        color: var(--primary);
        text-transform: uppercase;
        margin-bottom: 6px;
        letter-spacing: 0.5px;
    }

    .event-card-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--text);
        margin: 0 0 12px 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 44px;
    }

    .event-card-meta {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 16px;
        font-size: 12.5px;
        color: var(--text-light);
    }

    .event-card-meta span {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .event-card-meta i {
        color: var(--primary-light);
        width: 14px;
        font-size: 13px;
    }

    .event-card-actions {
        display: flex;
        gap: 10px;
        margin-top: auto;
        padding-top: 14px;
        border-top: 1px solid var(--border);
    }

    .event-card-actions .btn-primary,
    .event-card-actions .btn-outline {
        flex: 1;
        text-align: center;
        justify-content: center;
        font-size: 12px;
        height: 38px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: var(--white);
        border: 1px dashed var(--border);
        border-radius: 16px;
        color: var(--text-light);
        max-width: 500px;
        margin: 40px auto;
        box-shadow: var(--shadow-sm);
    }

    .empty-state i {
        font-size: 48px;
        color: var(--primary-light);
        margin-bottom: 16px;
    }

    .empty-state h3 {
        font-size: 18px;
        color: var(--text);
        margin: 0 0 8px 0;
        font-weight: 700;
    }

    .empty-state p {
        font-size: 14px;
        margin: 0 0 20px 0;
        line-height: 1.5;
    }
</style>

<div class="attendee-dashboard-shell">
    <div class="my-events-header">
        <div class="my-events-title">
            <h1>My Registered Events</h1>
            <p>Access and view all events you have booked</p>
        </div>
        <a href="/Events" class="btn-primary btn-small" style="height: 38px; display: inline-flex; align-items: center; gap: 8px; border-radius: 8px;">
            <i class="fa-solid fa-compass"></i> Discover More Events
        </a>
    </div>

    <!-- Filter Tabs -->
    <div class="events-tabs">
        <a href="?status=all" class="tab-link @(currentStatus == "all" ? "active" : "")">All Events</a>
        <a href="?status=upcoming" class="tab-link @(currentStatus == "upcoming" ? "active" : "")">Upcoming</a>
        <a href="?status=finished" class="tab-link @(currentStatus == "finished" ? "active" : "")">Finished / Past</a>
    </div>

    @if (Model == null || !Model.Data.Any())
    {
        <div class="empty-state">
            <i class="fa-regular fa-calendar-xmark"></i>
            <h3>No Events Found</h3>
            <p>No events match this filter. Check out the latest experiences near you and get your tickets today.</p>
            <a href="/Events" class="btn-primary" style="border-radius: 8px; padding: 10px 24px;">Explore Events</a>
        </div>
    }
    else
    {
        <div class="my-events-grid">
            @foreach (var ev in Model.Data)
            {
                <div class="event-card">
                    @if (!string.IsNullOrEmpty(ev.ImageUrl))
                    {
                        <div class="event-card-image" style="background-image: url('@ev.ImageUrl');">
                            <span class="event-card-badge">@ev.CategoryName</span>
                        </div>
                    }
                    else
                    {
                        <div class="event-card-fallback-bg">
                            <i class="fa-regular fa-calendar-days event-fallback-icon"></i>
                            <span class="event-card-badge">@ev.CategoryName</span>
                        </div>
                    }

                    <div class="event-card-body">
                        <span class="event-card-category">@ev.CategoryName</span>
                        <h3 class="event-card-title">@ev.Title</h3>
                        
                        <div class="event-card-meta">
                            <span><i class="fa-regular fa-calendar"></i> @ev.StartDate.ToEgyptTime().ToString("MMM dd, yyyy @ hh:mm tt")</span>
                            <span><i class="fa-solid fa-map-pin"></i> @ev.Location, @ev.City</span>
                            <span><i class="fa-solid fa-user-tie"></i> Hosted by @ev.OrganizerName</span>
                        </div>

                        <div class="event-card-actions">
                            <a href="/Events/Details/@ev.Id" class="btn-primary">
                                <i class="fa-solid fa-circle-info"></i> Details
                            </a>
                            
                            <a href="/Ticket/MyTickets?search=@Uri.EscapeDataString(ev.Title)" class="btn-outline" style="color: var(--primary); border-color: var(--primary-light); background: transparent;">
                                <i class="fa-solid fa-ticket"></i> View Tickets
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="pagination-wrapper" style="display: flex; justify-content: center; gap: 8px; margin-top: 20px;">
                @if (Model.HasPreviousPage)
                {
                    <a href="?status=@currentStatus&page=@(Model.PageNumber - 1)" class="btn-outline btn-small" style="display: inline-flex; align-items: center; height: 36px; border-radius: 8px; gap: 6px;"><i class="fa-solid fa-chevron-left"></i> Prev</a>
                }

                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <a href="?status=@currentStatus&page=@p" class="@(Model.PageNumber == p ? "btn-primary" : "btn-outline") btn-small" style="display: inline-flex; align-items: center; justify-content: center; height: 36px; width: 36px; border-radius: 8px; padding: 0;">@p</a>
                }

                @if (Model.HasNextPage)
                {
                    <a href="?status=@currentStatus&page=@(Model.PageNumber + 1)" class="btn-outline btn-small" style="display: inline-flex; align-items: center; height: 36px; border-radius: 8px; gap: 6px;">Next <i class="fa-solid fa-chevron-right"></i></a>
                }
            </div>
        }
    }
</div>
