@model Eventify.Shared.Wrappers.PagedResult<EventifyPro.BLL.DTOs.SavedEvent.SavedEventDto>
@{
    Layout = "_AttendeeLayout";
    ViewData["Title"] = "Saved Events";
}

<style>
    .saved-events-header {
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
    }
    
    .saved-events-title h1 {
        font-size: 24px;
        font-weight: 800;
        color: var(--primary-dark);
        margin: 0;
    }
    
    .saved-events-title p {
        font-size: 14px;
        color: var(--text-light);
        margin: 4px 0 0 0;
    }

    .saved-events-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
        margin-bottom: 30px;
    }

    .saved-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
        display: flex;
        flex-direction: column;
        height: 100%;
        position: relative;
    }

    .saved-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
        border-color: var(--primary-light);
    }

    .saved-card-image {
        height: 140px;
        width: 100%;
        background-size: cover;
        background-position: center;
        position: relative;
    }

    .saved-card-fallback-bg {
        height: 140px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--soft-purple) 0%, rgba(124, 58, 237, 0.1) 100%);
    }

    .saved-fallback-icon {
        color: var(--primary);
        font-size: 40px;
    }

    .saved-card-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(124, 58, 237, 0.9);
        backdrop-filter: blur(8px);
        color: var(--white);
        padding: 3px 10px;
        border-radius: 30px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .saved-card-body {
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .saved-card-category {
        font-size: 10.5px;
        font-weight: 700;
        color: var(--primary);
        text-transform: uppercase;
        margin-bottom: 6px;
        letter-spacing: 0.5px;
    }

    .saved-card-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--text);
        margin: 0 0 12px 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 44px;
    }

    .saved-card-meta {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 16px;
        font-size: 12.5px;
        color: var(--text-light);
    }

    .saved-card-meta span {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .saved-card-meta i {
        color: var(--primary-light);
        width: 14px;
        font-size: 13px;
    }

    .saved-card-actions {
        display: flex;
        gap: 10px;
        margin-top: auto;
        padding-top: 14px;
        border-top: 1px solid var(--border);
    }

    .saved-card-actions .btn-primary,
    .saved-card-actions .btn-outline {
        flex: 1;
        text-align: center;
        justify-content: center;
        font-size: 12px;
        height: 38px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: var(--white);
        border: 1px dashed var(--border);
        border-radius: 16px;
        color: var(--text-light);
        max-width: 500px;
        margin: 40px auto;
        box-shadow: var(--shadow-sm);
    }

    .empty-state i {
        font-size: 48px;
        color: var(--primary-light);
        margin-bottom: 16px;
    }

    .empty-state h3 {
        font-size: 18px;
        color: var(--text);
        margin: 0 0 8px 0;
        font-weight: 700;
    }

    .empty-state p {
        font-size: 14px;
        margin: 0 0 20px 0;
        line-height: 1.5;
    }
</style>

<div class="attendee-dashboard-shell">
    <div class="saved-events-header">
        <div class="saved-events-title">
            <h1>Saved Events</h1>
            <p>Keep track of events you are interested in attending</p>
        </div>
        <a href="/Events" class="btn-primary btn-small" style="height: 38px; display: inline-flex; align-items: center; gap: 8px; border-radius: 8px;">
            <i class="fa-solid fa-compass"></i> Discover More
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast-success-banner" style="margin-bottom: 20px;">
            <i class="fa-solid fa-circle-check"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast-success-banner" style="margin-bottom: 20px; background: rgba(239, 68, 68, 0.08); border-color: rgba(239, 68, 68, 0.15); color: #ef4444;">
            <i class="fa-solid fa-triangle-exclamation" style="color: #ef4444;"></i>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    @if (Model == null || !Model.Data.Any())
    {
        <div class="empty-state">
            <i class="fa-regular fa-bookmark"></i>
            <h3>No Saved Events Yet</h3>
            <p>When you explore events, you can save them to keep track of details and get tickets later.</p>
            <a href="/Events" class="btn-primary" style="border-radius: 8px; padding: 10px 24px;">Explore Events</a>
        </div>
    }
    else
    {
        <div class="saved-events-grid">
            @foreach (var saved in Model.Data)
            {
                <div class="saved-card">
                    @if (!string.IsNullOrEmpty(saved.EventImageUrl))
                    {
                        <div class="saved-card-image" style="background-image: url('@saved.EventImageUrl');">
                            <span class="saved-card-badge">@saved.EventCategoryName</span>
                        </div>
                    }
                    else
                    {
                        <div class="saved-card-fallback-bg">
                            <i class="fa-regular fa-calendar-days saved-fallback-icon"></i>
                            <span class="saved-card-badge">@saved.EventCategoryName</span>
                        </div>
                    }

                    <div class="saved-card-body">
                        <span class="saved-card-category">@saved.EventCategoryName</span>
                        <h3 class="saved-card-title">@saved.EventTitle</h3>
                        
                        <div class="saved-card-meta">
                            <span><i class="fa-regular fa-calendar"></i> @saved.EventStartDate.ToEgyptTime().ToString("MMM dd, yyyy @ hh:mm tt")</span>
                            <span><i class="fa-solid fa-map-pin"></i> @saved.EventCity, @saved.EventLocation</span>
                            <span><i class="fa-regular fa-clock"></i> Saved @saved.CreatedAt.ToEgyptTime().ToString("MMM dd, yyyy")</span>
                        </div>

                        <div class="saved-card-actions">
                            <a href="/Events/Details/@saved.EventId" class="btn-primary">
                                <i class="fa-solid fa-circle-info"></i> View Details
                            </a>
                            
                            <form asp-controller="Attendee" asp-action="ToggleSave" method="post" style="display:inline-block; flex:1;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventId" value="@saved.EventId" />
                                <button type="submit" class="btn-outline btn-full" style="color: var(--error); border-color: rgba(239, 68, 68, 0.2); background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px; width: 100%; font-family: inherit; font-weight: 600;">
                                    <i class="fa-solid fa-bookmark"></i> Remove
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="pagination-wrapper" style="display: flex; justify-content: center; gap: 8px; margin-top: 20px;">
                @if (Model.HasPreviousPage)
                {
                    <a href="?page=@(Model.PageNumber - 1)" class="btn-outline btn-small" style="display: inline-flex; align-items: center; height: 36px; border-radius: 8px; gap: 6px;"><i class="fa-solid fa-chevron-left"></i> Prev</a>
                }

                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <a href="?page=@p" class="@(Model.PageNumber == p ? "btn-primary" : "btn-outline") btn-small" style="display: inline-flex; align-items: center; justify-content: center; height: 36px; width: 36px; border-radius: 8px; padding: 0;">@p</a>
                }

                @if (Model.HasNextPage)
                {
                    <a href="?page=@(Model.PageNumber + 1)" class="btn-outline btn-small" style="display: inline-flex; align-items: center; height: 36px; border-radius: 8px; gap: 6px;">Next <i class="fa-solid fa-chevron-right"></i></a>
                }
            </div>
        }
    }
</div>
