@model EventDetailViewModel
@inject EventifyPro.BLL.Services.Interfaces.ISystemSettingService SystemSettingService
@{
    Layout = "_Layout";
    ViewData["Title"] = $"Book Tickets - {Model.Title}";
    var ticketTypes = ViewBag.TicketTypes as IEnumerable<EventifyPro.BLL.DTOs.TicketType.TicketTypeResponseDto> ?? new List<EventifyPro.BLL.DTOs.TicketType.TicketTypeResponseDto>();
    int selectedTicketTypeId = ViewBag.SelectedTicketTypeId;
    var commissionRate = await SystemSettingService.GetSettingValueAsync<decimal>("TicketCommissionRate", 5.0m);
}

<style>
    /* Premium Ticket Booking Styling */
    .booking-wrapper {
        max-width: 650px;
        margin: 40px auto;
    }

    .booking-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 35px;
        box-shadow: var(--shadow-md);
        position: relative;
        overflow: hidden;
    }

    .booking-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 6px;
        background: var(--gradient);
    }

    .booking-header {
        border-bottom: 1px solid var(--border);
        padding-bottom: 24px;
        margin-bottom: 24px;
    }

    .booking-event-title {
        font-size: 22px;
        font-weight: 800;
        color: var(--primary-dark);
        margin-bottom: 6px;
    }

    .booking-event-date {
        font-size: 14px;
        color: var(--text-light);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .booking-event-date i {
        color: var(--primary);
    }

    /* Quantity Counter Controls */
    .quantity-control-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        margin: 20px 0;
    }

    .quantity-btn {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1px solid var(--border);
        background: var(--white);
        color: var(--primary);
        font-size: 20px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
        box-shadow: var(--shadow-sm);
    }

    .quantity-btn:hover {
        background: var(--primary);
        color: var(--white);
        border-color: var(--primary);
        transform: translateY(-2px);
    }

    .quantity-input {
        width: 60px;
        text-align: center;
        font-size: 20px;
        font-weight: 800;
        border: none;
        background: transparent;
        color: var(--text);
    }

    /* Invoice Breakdown */
    .invoice-breakdown {
        background: var(--soft-purple);
        border-radius: 20px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px dashed var(--accent);
    }

    .invoice-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        font-size: 14px;
        color: var(--text-light);
    }

    .invoice-row.invoice-total {
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
        font-size: 19px;
        font-weight: 800;
        color: var(--primary);
    }

    .invoice-row strong {
        color: var(--text);
    }

    .info-notice {
        font-size: 12px;
        color: var(--text-light);
        text-align: center;
        margin-top: 16px;
    }
</style>

<div class="container">
    <div class="booking-wrapper">

        <div class="booking-card">
            
            <div class="booking-header">
                <span class="section-tag-enhanced"><i class="fas fa-ticket-alt"></i> Ticket Selection</span>
                <h1 class="booking-event-title">@Model.Title</h1>
                <p class="booking-event-date"><i class="far fa-calendar-alt"></i> @Model.StartDate.ToEgyptTime().ToString("MMMM dd, yyyy @ hh:mm tt")</p>
                <p class="booking-event-date" style="margin-top: 4px;"><i class="fas fa-map-marker-alt"></i> @Model.Location, @Model.City</p>
            </div>

            <form asp-controller="Events" asp-action="Book" method="post" id="bookingForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="eventId" value="@Model.Id" />
                <input type="hidden" name="waitingListId" value="@ViewBag.WaitingListId" />

                <!-- Select Ticket Type -->
                <div class="form-group" style="margin-bottom: 24px;">
                    <label for="ticketTypeSelect">Select Ticket Category</label>
                    <select name="items[0].TicketTypeId" id="ticketTypeSelect" class="form-input" style="height: 52px; border-radius: 12px; font-weight: 600;" onchange="updateTotals()">
                        @foreach (var type in ticketTypes)
                        {
                            <option value="@type.Id" 
                                    data-price="@type.Price" 
                                    data-name="@type.Name"
                                    data-available="@type.AvailableQuantity"
                                    selected="@(type.Id == selectedTicketTypeId ? "selected" : null)">
                                @type.Name - @type.Price.ToString("F2") EGP (@type.AvailableQuantity remaining)
                            </option>
                        }
                    </select>
                </div>

                <!-- Select Quantity -->
                <div class="form-group" style="text-align: center; margin-bottom: 24px;">
                    <label style="text-align: center; display: block; margin-bottom: 8px;">Select Tickets Quantity</label>
                    
                    <div class="quantity-control-wrapper">
                        <button type="button" class="quantity-btn" onclick="adjustQuantity(-1)"><i class="fas fa-minus"></i></button>
                        <input type="number" name="items[0].Quantity" id="quantityInput" class="quantity-input" value="1" min="1" max="10" readonly />
                        <button type="button" class="quantity-btn" onclick="adjustQuantity(1)"><i class="fas fa-plus"></i></button>
                    </div>
                </div>

                <!-- Invoice Breakdown -->
                <div class="invoice-breakdown">
                    <div class="invoice-row">
                        <span id="invoiceTicketText">VIP Ticket x1</span>
                        <strong id="invoiceSubtotal">0.00 EGP</strong>
                    </div>
                    <div class="invoice-row">
                        <span>Service Fee</span>
                        <strong id="invoiceServiceFee">0.00 EGP</strong>
                    </div>
                    <div class="invoice-row invoice-total">
                        <span>Total Price</span>
                        <span id="invoiceTotal">0.00 EGP</span>
                    </div>
                </div>

                <!-- Book Now Action -->
                <button type="submit" class="btn-primary btn-large btn-full" style="border-radius: 12px;">
                    <i class="fas fa-arrow-right"></i> Continue to Checkout
                </button>

                <p class="info-notice">
                    <i class="fas fa-lock"></i> Secured & encrypted checkout. Tickets are sent immediately after validation.
                </p>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function adjustQuantity(amount) {
            const input = document.getElementById('quantityInput');
            const select = document.getElementById('ticketTypeSelect');
            const activeOption = select.options[select.selectedIndex];
            
            const maxAvailable = parseInt(activeOption.getAttribute('data-available') || '10');
            const limit = Math.min(10, maxAvailable); // limit to 10 max per transaction
            
            let current = parseInt(input.value) || 1;
            current += amount;
            
            if (current < 1) current = 1;
            if (current > limit) current = limit;
            
            input.value = current;
            updateTotals();
        }

        function updateTotals() {
            const select = document.getElementById('ticketTypeSelect');
            const quantityInput = document.getElementById('quantityInput');
            
            if (!select.options.length) return;
            
            const option = select.options[select.selectedIndex];
            const price = parseFloat(option.getAttribute('data-price') || '0');
            const name = option.getAttribute('data-name') || 'Ticket';
            const maxAvailable = parseInt(option.getAttribute('data-available') || '0');
            
            const quantity = parseInt(quantityInput.value) || 1;
            
            // Adjust quantity input max if it exceeds available
            if (quantity > maxAvailable && maxAvailable > 0) {
                quantityInput.value = maxAvailable;
            }

            const subtotal = price * quantity;
            const commissionRate = @commissionRate.ToString("F2");
            const fee = Math.round(subtotal * (commissionRate / 100.0) * 100) / 100;
            const total = subtotal + fee;

            document.getElementById('invoiceTicketText').textContent = `${name} x${quantity}`;
            document.getElementById('invoiceSubtotal').textContent = `${subtotal.toFixed(2)} EGP`;
            document.getElementById('invoiceServiceFee').textContent = `${fee.toFixed(2)} EGP`;
            document.getElementById('invoiceTotal').textContent = `${total.toFixed(2)} EGP`;
        }

        // Run on page load
        document.addEventListener('DOMContentLoaded', updateTotals);
    </script>
}
