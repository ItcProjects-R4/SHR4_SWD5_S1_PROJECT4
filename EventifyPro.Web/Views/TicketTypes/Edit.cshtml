@model EventifyPro.Web.ViewModels.TicketType.TicketTypeFormViewModel
@{
    Layout = "_OrganizerLayout";
    ViewData["Title"] = "Edit Ticket Type";
    ViewData["HeaderTitle"] = "Edit Ticket Type ✏️";
    ViewData["HeaderSubtitle"] = "Update details for this ticket tier.";
}

@section Styles {
    <style>
        .form-card {
            background: white;
            border-radius: 20px;
            padding: 32px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
            max-width: 800px;
            margin: 0 auto;
        }

        .form-group {
            margin-bottom: 24px;
        }

        .form-label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 8px;
        }

        .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border);
            border-radius: 12px;
            font-family: inherit;
            font-size: 14.5px;
            color: var(--text);
            background: var(--bg);
            transition: var(--transition);
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-light);
            box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.2);
            background: white;
        }

        textarea.form-control {
            min-height: 100px;
            resize: vertical;
        }

        .text-danger {
            color: var(--error);
            font-size: 12.5px;
            margin-top: 6px;
            display: block;
        }

        label .text-danger {
            display: inline;
            margin-top: 0;
        }

        .row-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-actions {
            margin-top: 32px;
            display: flex;
            gap: 16px;
            justify-content: flex-end;
            padding-top: 24px;
            border-top: 1px solid var(--border);
        }
    </style>
}

<div class="form-card">
    <form asp-action="Edit" asp-controller="TicketTypes" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="EventId" />

        <div class="form-group">
            <label asp-for="Name" class="form-label">Ticket Name <span class="text-danger">*</span></label>
            <input asp-for="Name" class="form-control" placeholder="e.g., VIP, General Admission, Early Bird" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="row-group">
            <div class="form-group">
                <label asp-for="Price" class="form-label">Price (EGP) <span class="text-danger">*</span></label>
                @if (ViewBag.SoldQuantity as int? > 0)
                {
                    <input asp-for="Price" type="number" step="0.01" class="form-control" readonly />
                    <div style="font-size: 11.5px; color: var(--warning); margin-top: 4px;"><i class="fas fa-info-circle"></i> Price cannot be changed once tickets are sold.</div>
                }
                else
                {
                    <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" placeholder="0.00 for Free" />
                }
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TotalQuantity" class="form-label">Total Quantity <span class="text-danger">*</span></label>
                @if (ViewBag.SoldQuantity as int? > 0)
                {
                    <input asp-for="TotalQuantity" type="number" min="@ViewBag.SoldQuantity" class="form-control" placeholder="Number of tickets available" />
                    <div style="font-size: 11.5px; color: var(--warning); margin-top: 4px;"><i class="fas fa-info-circle"></i> Cannot reduce capacity below @ViewBag.SoldQuantity sold tickets.</div>
                }
                else
                {
                    <input asp-for="TotalQuantity" type="number" min="1" class="form-control" placeholder="Number of tickets available" />
                }
                <span asp-validation-for="TotalQuantity" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" placeholder="What's included in this ticket?"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="row-group">
            <div class="form-group">
                <label asp-for="SaleStartDate" class="form-label">Sale Start Date (Optional)</label>
                <input asp-for="SaleStartDate" type="datetime-local" class="form-control" />
                <span asp-validation-for="SaleStartDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SaleEndDate" class="form-label">Sale End Date (Optional)</label>
                <input asp-for="SaleEndDate" type="datetime-local" class="form-control" />
                <span asp-validation-for="SaleEndDate" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <a href="/TicketTypes/Index?eventId=@Model.EventId" class="btn-secondary">Cancel</a>
            <button type="submit" class="btn-primary">
                <i class="fas fa-save"></i> Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
