@{
    Layout = "_Layout";
    ViewData["Title"] = "Server Error - 500";
}

<div class="bg-animation">
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>
    <div class="bg-blob blob-3"></div>
</div>

<div class="container text-center" style="padding: 100px 0; max-width: 600px; margin: 0 auto; text-align: center;">
    <div style="font-size: 120px; font-weight: 900; line-height: 1; margin-bottom: 24px; color: var(--error);" class="gradient-text">500</div>
    <h2 style="font-size: 28px; font-weight: 800; margin-bottom: 16px; color: var(--primary-dark);">Internal Server Error</h2>
    <p style="color: var(--text-light); font-size: 16px; margin-bottom: 24px; line-height: 1.6;">
        @ViewBag.ErrorMessage
    </p>
    @if (ViewBag.CorrelationId != null)
    {
        <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 36px; font-family: monospace;">
            Correlation ID: @ViewBag.CorrelationId
        </p>
    }
    <div style="display: flex; gap: 16px; justify-content: center;">
        <a href="/" class="btn-primary">
            <i class="fas fa-home" style="margin-right: 8px;"></i> Go to Home
        </a>
        <a href="javascript:location.reload();" class="btn-outline">
            <i class="fas fa-redo" style="margin-right: 8px;"></i> Reload Page
        </a>
    </div>
</div>
