@{
    Layout = "_Layout";
    ViewData["Title"] = "Page Not Found - 404";
}

<div class="bg-animation">
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>
    <div class="bg-blob blob-3"></div>
</div>

<div class="container text-center" style="padding: 100px 0; max-width: 600px; margin: 0 auto; text-align: center;">
    <div style="font-size: 120px; font-weight: 900; line-height: 1; margin-bottom: 24px;" class="gradient-text">404</div>
    <h2 style="font-size: 28px; font-weight: 800; margin-bottom: 16px; color: var(--primary-dark);">Page Not Found</h2>
    <p style="color: var(--text-light); font-size: 16px; margin-bottom: 36px; line-height: 1.6;">
        @ViewBag.ErrorMessage
    </p>
    <div style="display: flex; gap: 16px; justify-content: center;">
        <a href="/" class="btn-primary">
            <i class="fas fa-home" style="margin-right: 8px;"></i> Go to Home
        </a>
        <a href="/Events" class="btn-outline">
            <i class="fas fa-calendar-alt" style="margin-right: 8px;"></i> Explore Events
        </a>
    </div>
</div>
