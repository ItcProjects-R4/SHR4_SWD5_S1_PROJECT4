@model IEnumerable<EventifyPro.Web.ViewModels.OrganizerScanners.ScannerViewModel>
@{
    Layout = "_OrganizerLayout";
    ViewData["Title"] = "Manage Scanners";
    ViewData["HeaderTitle"] = "Manage Scanners 📱";
    ViewData["HeaderSubtitle"] = "Create and manage scanner accounts for your event entrances.";

    var searchTerm = ViewBag.SearchTerm as string;
    var pageNum = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
}

@section Styles {
    <style>
        .table-card {
            background: white;
            border-radius: 20px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            margin-top: 24px;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }
        .data-table th {
            background: var(--bg);
            padding: 16px 24px;
            text-align: left;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 2px solid var(--border);
        }
        .data-table td {
            padding: 16px 24px;
            border-bottom: 1px solid var(--border);
            font-size: 14.5px;
            color: var(--text);
            vertical-align: middle;
        }
        .data-table tbody tr:hover {
            background: var(--soft-purple);
        }

        .action-btn {
            width: 34px;
            height: 34px;
            border: none;
            background: var(--soft-purple);
            color: var(--primary);
            border-radius: 8px;
            cursor: pointer;
            transition: var(--transition);
            margin-right: 4px;
            font-size: 13px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
        }
        .action-btn:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-2px);
        }
        .action-btn.disable {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
        }
        .action-btn.disable:hover {
            background: var(--error);
            color: white;
        }
        .action-btn.enable {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }
        .action-btn.enable:hover {
            background: var(--success);
            color: white;
        }

        .scanner-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .scanner-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--gradient);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 16px;
        }
        .scanner-name h4 {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 2px;
        }
        .scanner-name p {
            font-size: 13px;
            color: var(--text-light);
        }
        
        .header-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 16px;
        }

        .search-box {
            display: flex;
            gap: 10px;
            max-width: 400px;
            width: 100%;
        }

        .search-input {
            flex-grow: 1;
            padding: 10px 16px;
            border-radius: 10px;
            border: 1px solid var(--border);
            font-family: inherit;
            font-size: 14px;
            outline: none;
            transition: var(--transition);
        }
        .search-input:focus {
            border-color: var(--primary);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 50px;
            text-transform: uppercase;
        }
        .status-badge.active {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }
        .status-badge.inactive {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
        }

        .pagination {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 24px;
            padding: 20px;
            border-top: 1px solid var(--border);
        }
        .pagination-link {
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: white;
            color: var(--text);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: var(--transition);
        }
        .pagination-link:hover:not(.disabled) {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--soft-purple);
        }
        .pagination-link.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }
        .pagination-link.disabled {
            color: var(--text-light);
            background: var(--bg);
            cursor: not-allowed;
            pointer-events: none;
        }

        .alert-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 24px;
            font-weight: 600;
            font-size: 14.5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
    </style>
}

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert-success">
        <i class="fas fa-check-circle"></i> @message
    </div>
}

<div class="header-actions">
    <form method="get" class="search-box">
        <input type="text" name="searchTerm" value="@searchTerm" placeholder="Search by name or email..." class="search-input" />
        <button type="submit" class="btn-primary" style="padding: 10px 20px;">Search</button>
        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <a href="@Url.Action("Index", "OrganizerScanners")" class="btn-secondary" style="display: inline-flex; align-items: center; justify-content: center; width: 42px; padding: 0;"><i class="fas fa-times"></i></a>
        }
    </form>
    <a asp-controller="OrganizerScanners" asp-action="Create" class="btn-primary">
        <i class="fas fa-plus"></i> Add New Scanner
    </a>
</div>

<div class="table-card">
    @if (Model != null && Model.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Scanner Details</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Added On</th>
                    <th style="text-align: center;">Total Scans</th>
                    <th>Latest Scan</th>
                    <th style="text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var scanner in Model)
                {
                    <tr>
                        <td>
                            <div class="scanner-info">
                                <div class="scanner-avatar">
                                    @(scanner.FullName.Length > 0 ? scanner.FullName.Substring(0, 1).ToUpper() : "S")
                                </div>
                                <div class="scanner-name">
                                    <h4>@scanner.FullName</h4>
                                    <p>Scanner Account</p>
                                </div>
                            </div>
                        </td>
                        <td>@scanner.Email</td>
                        <td>
                            @if (scanner.IsActive)
                            {
                                <span class="status-badge active"><i class="fas fa-check-circle"></i> Active</span>
                            }
                            else
                            {
                                <span class="status-badge inactive"><i class="fas fa-ban"></i> Disabled</span>
                            }
                        </td>
                        <td>@scanner.CreatedAt.ToEgyptTime().ToString("MMM dd, yyyy")</td>
                        <td style="text-align: center;">
                            <span style="font-weight: 700; color: var(--primary);">@scanner.TotalScans</span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(scanner.LastScannedEventTitle))
                            {
                                <div style="font-weight: 600; font-size: 13.5px; color: var(--text);">
                                    @scanner.LastScannedEventTitle
                                </div>
                                <div style="font-size: 11.5px; color: var(--text-light); margin-top: 2px;">
                                    @scanner.LastScannedAt?.ToEgyptTime().ToString("MMM dd, HH:mm")
                                    @if (!string.IsNullOrEmpty(scanner.LastScanStatus))
                                    {
                                        var statusClass = scanner.LastScanStatus.ToLower() == "valid" ? "color: var(--success);" : "color: var(--error);";
                                        <span style="@statusClass font-weight: 600; margin-left: 4px;">(@scanner.LastScanStatus)</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span style="font-style: italic; color: var(--text-light); font-size: 13px;">No scans logged</span>
                            }
                        </td>
                        <td style="text-align: right;">
                            <a asp-controller="OrganizerScanners" asp-action="Details" asp-route-id="@scanner.Id" class="action-btn" title="View Scan History">
                                <i class="fas fa-history"></i>
                            </a>
                            <a asp-controller="OrganizerScanners" asp-action="AssignEvents" asp-route-id="@scanner.Id" class="action-btn" title="Assign Events" style="color: var(--primary); margin-right: 4px;">
                                <i class="fas fa-calendar-alt"></i>
                            </a>
                            <a asp-controller="OrganizerScanners" asp-action="Edit" asp-route-id="@scanner.Id" class="action-btn" title="Edit Scanner">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-controller="OrganizerScanners" asp-action="ToggleStatus" method="post" style="display: inline-block;" onsubmit="return confirm('Are you sure you want to @(scanner.IsActive ? "disable" : "enable") access for this scanner?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@scanner.Id" />
                                @if (scanner.IsActive)
                                {
                                    <button type="submit" class="action-btn disable" title="Disable Scanner">
                                        <i class="fas fa-ban"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="action-btn enable" title="Enable Scanner">
                                        <i class="fas fa-check-circle"></i>
                                    </button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (totalPages > 1)
        {
            <div class="pagination">
                <a href="@Url.Action("Index", new { searchTerm = searchTerm, page = pageNum - 1 })" class="pagination-link @(pageNum == 1 ? "disabled" : "")">
                    <i class="fas fa-chevron-left"></i> Previous
                </a>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a href="@Url.Action("Index", new { searchTerm = searchTerm, page = i })" class="pagination-link @(pageNum == i ? "active" : "")">@i</a>
                }
                <a href="@Url.Action("Index", new { searchTerm = searchTerm, page = pageNum + 1 })" class="pagination-link @(pageNum == totalPages ? "disabled" : "")">
                    Next <i class="fas fa-chevron-right"></i>
                </a>
            </div>
        }
    }
    else
    {
        <div style="text-align: center; padding: 60px 20px;">
            <div style="width: 80px; height: 80px; background: var(--soft-purple); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; color: var(--primary); font-size: 32px;">
                <i class="fas fa-qrcode"></i>
            </div>
            <h3 style="font-size: 20px; font-weight: 800; margin-bottom: 8px;">No Scanners Found</h3>
            <p style="color: var(--text-light); margin-bottom: 24px; max-width: 400px; margin-left: auto; margin-right: auto;">
                Create scanner accounts so your team can validate tickets at the entrance using the Eventify Pro Scanner App.
            </p>
            <a asp-controller="OrganizerScanners" asp-action="Create" class="btn-primary">
                <i class="fas fa-plus"></i> Add New Scanner
            </a>
        </div>
    }
</div>
