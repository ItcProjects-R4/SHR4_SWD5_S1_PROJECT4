@model EventifyPro.Web.ViewModels.OrganizerScanners.ScannerDetailsViewModel
@{
    Layout = "_OrganizerLayout";
    ViewData["Title"] = "Scanner Activity Details";
    ViewData["HeaderTitle"] = "Scanner Activity details 📱";
    ViewData["HeaderSubtitle"] = $"Drill down into scan activity logs for {Model.FullName}.";

    var pageNum = Model.Page;
    var totalPages = Model.TotalPages;
}

@section Styles {
    <style>
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: white;
            padding: 24px;
            border-radius: 20px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .stat-icon.total {
            background: var(--soft-purple);
            color: var(--primary);
        }

        .stat-icon.success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .stat-icon.failed {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
        }

        .stat-info h3 {
            font-size: 24px;
            font-weight: 800;
            color: var(--text);
            line-height: 1;
            margin-bottom: 6px;
        }

        .stat-info p {
            font-size: 13.5px;
            color: var(--text-light);
            font-weight: 500;
        }

        .activity-card {
            background: white;
            border-radius: 20px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .card-header {
            padding: 20px 24px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .card-header h3 {
            font-size: 16px;
            font-weight: 700;
            color: var(--text);
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }
        .data-table th {
            background: var(--bg);
            padding: 16px 24px;
            text-align: left;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 2px solid var(--border);
        }
        .data-table td {
            padding: 16px 24px;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
            color: var(--text);
            vertical-align: middle;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 50px;
            text-transform: uppercase;
        }
        .status-badge.valid {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }
        .status-badge.alreadyused {
            background: rgba(245, 158, 11, 0.1);
            color: #d97706;
        }
        .status-badge.invalidtoken, .status-badge.wrongevent {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
        }

        .pagination {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 24px;
            padding: 20px;
            border-top: 1px solid var(--border);
        }
        .pagination-link {
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: white;
            color: var(--text);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: var(--transition);
        }
        .pagination-link:hover:not(.disabled) {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--soft-purple);
        }
        .pagination-link.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }
        .pagination-link.disabled {
            color: var(--text-light);
            background: var(--bg);
            cursor: not-allowed;
            pointer-events: none;
        }
    </style>
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon total"><i class="fas fa-qrcode"></i></div>
        <div class="stat-info">
            <h3>@Model.TotalScans</h3>
            <p>Total Scan Attempts</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon success"><i class="fas fa-check-circle"></i></div>
        <div class="stat-info">
            <h3>@Model.ValidScans</h3>
            <p>Successful Entry Scans</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon failed"><i class="fas fa-exclamation-triangle"></i></div>
        <div class="stat-info">
            <h3>@Model.InvalidScans</h3>
            <p>Failed / Invalid Scans</p>
        </div>
    </div>
</div>

<div class="activity-card">
    <div class="card-header">
        <h3>Scan Log History</h3>
        <a asp-controller="OrganizerScanners" asp-action="Index" class="btn-secondary btn-small">
            <i class="fas fa-arrow-left"></i> Back to Scanners
        </a>
    </div>

    @if (Model.ScanLogs != null && Model.ScanLogs.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Event</th>
                    <th>Scanned At</th>
                    <th>Ticket Serial</th>
                    <th>Attendee</th>
                    <th>Result Status</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.ScanLogs)
                {
                    <tr>
                        <td>
                            <a href="/Events/Performance/@log.EventId" style="font-weight: 600; color: var(--primary); text-decoration: none;">
                                @log.EventTitle
                            </a>
                        </td>
                        <td>@log.ScannedAt.ToEgyptTime().ToString("MMM dd, yyyy HH:mm:ss")</td>
                        <td>
                            <span style="font-family: monospace; font-weight: 600;">@(log.TicketSerialNumber ?? "-")</span>
                        </td>
                        <td>@(log.AttendeeName ?? "-")</td>
                        <td>
                            @{
                                var resultLower = log.Result.ToLower();
                                var badgeClass = resultLower;
                            }
                            <span class="status-badge @badgeClass">
                                @if (resultLower == "valid")
                                {
                                    <i class="fas fa-check-circle"></i>
                                }
                                else if (resultLower == "alreadyused")
                                {
                                    <i class="fas fa-redo"></i>
                                }
                                else
                                {
                                    <i class="fas fa-times-circle"></i>
                                }
                                @log.Result
                            </span>
                        </td>
                        <td style="color: var(--text-light); font-style: italic; font-size: 13px;">@(log.Notes ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (totalPages > 1)
        {
            <div class="pagination">
                <a href="@Url.Action("Details", new { id = Model.Id, page = pageNum - 1 })" class="pagination-link @(pageNum == 1 ? "disabled" : "")">
                    <i class="fas fa-chevron-left"></i> Previous
                </a>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a href="@Url.Action("Details", new { id = Model.Id, page = i })" class="pagination-link @(pageNum == i ? "active" : "")">@i</a>
                }
                <a href="@Url.Action("Details", new { id = Model.Id, page = pageNum + 1 })" class="pagination-link @(pageNum == totalPages ? "disabled" : "")">
                    Next <i class="fas fa-chevron-right"></i>
                </a>
            </div>
        }
    }
    else
    {
        <div style="text-align: center; padding: 40px 20px; color: var(--text-light);">
            <div style="font-size: 40px; margin-bottom: 12px; color: var(--border);"><i class="fas fa-history"></i></div>
            <p>No scanning activity has been logged for this scanner account yet.</p>
        </div>
    }
</div>
