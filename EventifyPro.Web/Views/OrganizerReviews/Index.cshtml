@model EventifyPro.Web.ViewModels.Organizer.OrganizerReviewsListViewModel
@{
    Layout = "_OrganizerLayout";
    ViewData["Title"] = "Attendee Reviews";
    ViewData["HeaderTitle"] = "Attendee Reviews ⭐";
    ViewData["HeaderSubtitle"] = "View ratings and feedback left by attendees for your events.";

    var searchTerm = Model.SearchTerm;
    var ratingFilter = Model.RatingFilter;
    var totalReviews = Model.TotalReviews;
    var averageRating = Model.AverageRating;
    var ratingDistribution = Model.RatingDistribution;
    var pageNum = Model.Page;
    var totalPages = Model.TotalPages;
}

@section Styles {
    <style>
        /* Stats Panel */
        .reviews-stats-row {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 24px;
            margin-bottom: 30px;
        }

        @@media (max-width: 992px) {
            .reviews-stats-row {
                grid-template-columns: 1fr;
            }
        }

        .stats-summary-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 30px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            box-shadow: var(--shadow-sm);
        }

        .average-score {
            font-size: 64px;
            font-weight: 800;
            color: var(--primary-dark);
            line-height: 1;
            margin-bottom: 12px;
        }

        .stars-large {
            font-size: 20px;
            color: #fbbf24;
            margin-bottom: 12px;
            display: flex;
            gap: 4px;
        }

        .total-reviews-label {
            font-size: 14px;
            color: var(--text-light);
            font-weight: 500;
        }

        .distribution-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 24px 30px;
            box-shadow: var(--shadow-sm);
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 12px;
        }

        .dist-row {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .dist-label {
            width: 60px;
            font-size: 13.5px;
            font-weight: 600;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .dist-label i {
            color: #fbbf24;
            font-size: 12px;
        }

        .dist-bar-container {
            flex-grow: 1;
            height: 10px;
            background: var(--soft-purple);
            border-radius: 10px;
            overflow: hidden;
        }

        .dist-bar-fill {
            height: 100%;
            background: var(--gradient);
            border-radius: 10px;
            transition: width 0.6s ease;
        }

        .dist-count {
            width: 45px;
            font-size: 13px;
            font-weight: 700;
            color: var(--text-light);
            text-align: right;
        }

        /* Filter Panel */
        .filter-panel {
            background: white;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 20px 24px;
            margin-bottom: 28px;
            box-shadow: var(--shadow-sm);
        }

        .filter-form {
            display: flex;
            gap: 16px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .filter-group label {
            font-size: 12px;
            font-weight: 700;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .filter-input {
            padding: 10px 16px;
            border-radius: 10px;
            border: 1px solid var(--border);
            font-family: inherit;
            font-size: 14px;
            outline: none;
            transition: var(--transition);
            background: var(--bg);
            min-width: 180px;
        }

        .filter-input:focus {
            border-color: var(--primary);
            background: white;
        }

        .filter-select {
            padding: 10px 16px;
            border-radius: 10px;
            border: 1px solid var(--border);
            font-family: inherit;
            font-size: 14px;
            outline: none;
            transition: var(--transition);
            background: var(--bg);
            cursor: pointer;
            min-width: 150px;
        }

        .filter-select:focus {
            border-color: var(--primary);
            background: white;
        }

        .filter-buttons {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        /* Reviews List */
        .reviews-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
        }

        .review-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 16px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
            position: relative;
        }

        .review-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-md);
        }

        .review-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
        }

        .reviewer-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .reviewer-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: var(--light-purple);
            color: var(--primary);
            font-weight: 700;
            font-size: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--accent);
        }

        .reviewer-details h4 {
            font-size: 14.5px;
            font-weight: 600;
            color: var(--text);
        }

        .review-date {
            font-size: 11.5px;
            color: var(--text-light);
            margin-top: 2px;
        }

        .review-rating {
            color: #fbbf24;
            font-size: 13px;
            display: flex;
            gap: 2px;
        }

        .event-tag {
            font-size: 12px;
            font-weight: 600;
            padding: 4px 10px;
            background: var(--soft-purple);
            color: var(--primary);
            border-radius: 50px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: var(--transition);
            align-self: flex-start;
        }

        .event-tag:hover {
            background: var(--light-purple);
            color: var(--primary-dark);
        }

        .review-comment {
            font-size: 14px;
            color: var(--text);
            line-height: 1.6;
            font-style: italic;
            background: #fafafd;
            padding: 12px 16px;
            border-radius: 12px;
            border-left: 3px solid var(--accent);
            flex-grow: 1;
        }

        /* Reply & Actions */
        .review-footer {
            border-top: 1px dashed var(--border);
            padding-top: 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .reply-container {
            background: #fbfbfe;
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 14px;
            margin-top: 12px;
        }
        
        .reply-header {
            font-size: 12.5px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 6px;
            display: flex;
            justify-content: space-between;
        }

        .reply-content {
            font-size: 13.5px;
            color: var(--text);
            line-height: 1.5;
        }

        /* Modals */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0,0,0,0.4);
            align-items: center;
            justify-content: center;
        }
        .modal.active {
            display: flex;
        }
        .modal-content {
            background-color: #fefefe;
            border-radius: 20px;
            padding: 28px;
            border: 1px solid var(--border);
            width: 90%;
            max-width: 500px;
            box-shadow: var(--shadow-lg);
            animation: slideDown 0.3s ease;
        }
        @@keyframes slideDown {
            from { transform: translateY(-50px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .pagination {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 30px;
        }
        .pagination-link {
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: white;
            color: var(--text);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: var(--transition);
        }
        .pagination-link:hover:not(.disabled) {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--soft-purple);
        }
        .pagination-link.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }
        .pagination-link.disabled {
            color: var(--text-light);
            background: var(--bg);
            cursor: not-allowed;
            pointer-events: none;
        }

        .alert-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 24px;
            font-weight: 600;
            font-size: 14.5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .alert-error {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 24px;
            font-weight: 600;
            font-size: 14.5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
    </style>
}

@if (TempData["SuccessMessage"] is string msg)
{
    <div class="alert-success">
        <i class="fas fa-check-circle"></i> @msg
    </div>
}
@if (TempData["ErrorMessage"] is string errMsg)
{
    <div class="alert-error">
        <i class="fas fa-exclamation-circle"></i> @errMsg
    </div>
}

<div class="reviews-stats-row">
    <!-- Average Rating Score -->
    <div class="stats-summary-card">
        <div class="average-score">@averageRating</div>
        <div class="stars-large">
            @for (int i = 1; i <= 5; i++)
            {
                if (i <= Math.Round(averageRating))
                {
                    <i class="fas fa-star"></i>
                }
                else
                {
                    <i class="far fa-star"></i>
                }
            }
        </div>
        <div class="total-reviews-label">Based on @totalReviews reviews</div>
    </div>

    <!-- Rating Distribution horizontal bars -->
    <div class="distribution-card">
        @for (int stars = 5; stars >= 1; stars--)
        {
            var count = ratingDistribution.ContainsKey(stars) ? ratingDistribution[stars] : 0;
            double percent = totalReviews > 0 ? ((double)count / totalReviews * 100) : 0;
            
            <div class="dist-row">
                <div class="dist-label">
                    @stars <i class="fas fa-star"></i>
                </div>
                <div class="dist-bar-container">
                    <div class="dist-bar-fill" style="width: @(percent)%"></div>
                </div>
                <div class="dist-count">@count</div>
            </div>
        }
    </div>
</div>

<!-- Filters Panel -->
<div class="filter-panel">
    <form method="get" class="filter-form">
        <div class="filter-group">
            <label>Search comments</label>
            <input type="text" name="searchTerm" value="@searchTerm" placeholder="Search comments or events..." class="filter-input" />
        </div>
        <div class="filter-group">
            <label>Rating</label>
            <select name="ratingFilter" class="filter-select">
                <option value="">All Ratings</option>
                @for (int i = 5; i >= 1; i--)
                {
                    <option value="@i" selected="@(ratingFilter == i)">@i Stars</option>
                }
            </select>
        </div>
        <div class="filter-group">
            <label>Start Date</label>
            <input type="date" name="startDate" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" class="filter-input" />
        </div>
        <div class="filter-group">
            <label>End Date</label>
            <input type="date" name="endDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" class="filter-input" />
        </div>
        <div class="filter-buttons" style="display: flex; gap: 8px; align-items: center;">
            <button type="submit" class="btn-primary" style="padding: 10px 20px;">
                <i class="fas fa-filter"></i> Apply Filters
            </button>
            @if (!string.IsNullOrWhiteSpace(searchTerm) || ratingFilter.HasValue || Model.StartDate.HasValue || Model.EndDate.HasValue)
            {
                <a href="@Url.Action("Index", "OrganizerReviews")" class="btn-secondary" style="padding: 10px 20px;">
                    <i class="fas fa-times"></i> Clear
                </a>
            }
            <div class="dropdown" style="position: relative; display: inline-block;">
                <button type="button" class="btn-secondary" onclick="toggleExportDropdown()" style="padding: 10px 20px; display: inline-flex; align-items: center; gap: 8px;">
                    <i class="fas fa-download"></i> Export <i class="fas fa-chevron-down" style="font-size: 10px;"></i>
                </button>
                <div id="exportDropdownMenu" style="display: none; position: absolute; right: 0; top: 100%; margin-top: 8px; background: white; border: 1px solid var(--border); border-radius: 12px; box-shadow: var(--shadow-md); z-index: 100; min-width: 140px; overflow: hidden;">
                    <a href="/OrganizerReviews/ExportReviews?format=csv" style="display: block; padding: 12px 16px; font-size: 13.5px; color: var(--text); text-decoration: none; transition: var(--transition);" onmouseover="this.style.background='var(--soft-purple)'" onmouseout="this.style.background='transparent'"><i class="fas fa-file-csv" style="color: #10b981; margin-right: 8px;"></i> CSV</a>
                    <a href="/OrganizerReviews/ExportReviews?format=excel" style="display: block; padding: 12px 16px; font-size: 13.5px; color: var(--text); text-decoration: none; transition: var(--transition);" onmouseover="this.style.background='var(--soft-purple)'" onmouseout="this.style.background='transparent'"><i class="fas fa-file-excel" style="color: #3b82f6; margin-right: 8px;"></i> Excel</a>
                    <a href="/OrganizerReviews/ExportReviews?format=pdf" style="display: block; padding: 12px 16px; font-size: 13.5px; color: var(--text); text-decoration: none; transition: var(--transition);" onmouseover="this.style.background='var(--soft-purple)'" onmouseout="this.style.background='transparent'"><i class="fas fa-file-pdf" style="color: #ef4444; margin-right: 8px;"></i> PDF</a>
                </div>
            </div>
        </div>
    </form>
</div>

@if (!Model.Reviews.Any())
{
    <div style="background: white; border: 1px solid var(--border); border-radius: 20px; padding: 60px 40px; text-align: center; box-shadow: var(--shadow-sm);">
        <div style="font-size: 48px; color: var(--accent); margin-bottom: 20px;"><i class="far fa-comments"></i></div>
        <h3>No Reviews Found</h3>
        <p style="color: var(--text-light); font-size: 14.5px; max-width: 400px; margin: 20px auto 0;">No attendee reviews match your active filter criteria or there are no reviews for your events yet.</p>
    </div>
}
else
{
    <div class="reviews-grid">
        @foreach (var review in Model.Reviews)
        {
            <div class="review-card">
                <div class="review-header">
                    <div class="reviewer-info">
                        <div class="reviewer-avatar">@review.AttendeeInitials</div>
                        <div class="reviewer-details">
                            <h4>@review.AttendeeName</h4>
                            <div class="review-date">@review.CreatedAt.ToEgyptTime().ToString("MMMM dd, yyyy")</div>
                        </div>
                    </div>
                    
                    <div class="review-rating">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= review.Rating)
                            {
                                <i class="fas fa-star"></i>
                            }
                            else
                            {
                                <i class="far fa-star"></i>
                            }
                        }
                    </div>
                </div>

                <a href="/Events/Performance/@review.EventId" class="event-tag">
                    <i class="fas fa-calendar-alt"></i> @review.EventTitle
                </a>

                @if (!string.IsNullOrWhiteSpace(review.Comment))
                {
                    <div class="review-comment">
                        "@review.Comment"
                    </div>
                }
                else
                {
                    <div class="review-comment" style="color: var(--text-light); border-left-color: var(--border);">
                        No written comments provided.
                    </div>
                }

                @if (!string.IsNullOrEmpty(review.OrganizerReply))
                {
                    <div class="reply-container">
                        <div class="reply-header">
                            <span>Your Response</span>
                            <span style="color: var(--text-light); font-weight: 500;">@review.RepliedAt?.ToEgyptTime().ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="reply-content">@review.OrganizerReply</div>
                    </div>
                }

                <div class="review-footer">
                    @if (string.IsNullOrEmpty(review.OrganizerReply))
                    {
                        <button class="btn-secondary btn-small" onclick="openReplyModal(@review.Id, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(review.AttendeeName))')">
                            <i class="fas fa-reply"></i> Reply
                        </button>
                    }
                    else
                    {
                        <span style="font-size: 12px; color: var(--success); font-weight: 600;"><i class="fas fa-check"></i> Replied</span>
                    }

                    <div style="display: flex; gap: 12px; align-items: center;">
                        <form asp-controller="OrganizerReviews" asp-action="Delete" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this review? This action cannot be undone.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@review.Id" />
                            <button type="submit" style="background: none; border: none; color: var(--error); cursor: pointer; padding: 4px;" title="Delete Review">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </form>

                        @if (review.IsFlagged)
                        {
                            <span style="font-size: 12px; color: var(--error); font-weight: 600;"><i class="fas fa-flag"></i> Flagged for Moderation</span>
                        }
                        else
                        {
                            <button class="action-btn" style="background: transparent; color: var(--text-light); border: none; cursor: pointer; padding: 4px;" title="Report Inappropriate Content" onclick="openFlagModal(@review.Id)">
                                <i class="far fa-flag"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <div class="pagination">
            <a href="@Url.Action("Index", new { searchTerm = searchTerm, ratingFilter = ratingFilter, startDate = Model.StartDate?.ToString("yyyy-MM-dd"), endDate = Model.EndDate?.ToString("yyyy-MM-dd"), page = pageNum - 1 })" class="pagination-link @(pageNum == 1 ? "disabled" : "")">
                <i class="fas fa-chevron-left"></i> Previous
            </a>
            @for (int i = 1; i <= totalPages; i++)
            {
                <a href="@Url.Action("Index", new { searchTerm = searchTerm, ratingFilter = ratingFilter, startDate = Model.StartDate?.ToString("yyyy-MM-dd"), endDate = Model.EndDate?.ToString("yyyy-MM-dd"), page = i })" class="pagination-link @(pageNum == i ? "active" : "")">@i</a>
            }
            <a href="@Url.Action("Index", new { searchTerm = searchTerm, ratingFilter = ratingFilter, startDate = Model.StartDate?.ToString("yyyy-MM-dd"), endDate = Model.EndDate?.ToString("yyyy-MM-dd"), page = pageNum + 1 })" class="pagination-link @(pageNum == totalPages ? "disabled" : "")">
                Next <i class="fas fa-chevron-right"></i>
            </a>
        </div>
    }
}

<!-- Reply Modal -->
<div id="replyModal" class="modal">
    <div class="modal-content">
        <h3 style="margin-bottom: 16px; font-weight: 700; color: var(--primary-dark);">Reply to <span id="replyTargetName"></span></h3>
        <form asp-controller="OrganizerReviews" asp-action="Reply" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="reviewId" id="replyReviewId" />
            <div class="form-group" style="margin-bottom: 20px;">
                <label class="form-label" style="font-weight: 600; font-size: 13px; display: block; margin-bottom: 8px;">Response Content</label>
                <textarea name="replyContent" class="form-control" rows="5" placeholder="Write your professional response..." required style="width: 100%; border: 1px solid var(--border); border-radius: 12px; padding: 12px; font-family: inherit; font-size: 14px; resize: none;"></textarea>
            </div>
            <div style="display: flex; justify-content: flex-end; gap: 10px;">
                <button type="button" class="btn-secondary" onclick="closeReplyModal()">Cancel</button>
                <button type="submit" class="btn-primary">Post Reply</button>
            </div>
        </form>
    </div>
</div>

<!-- Flag Modal -->
<div id="flagModal" class="modal">
    <div class="modal-content">
        <h3 style="margin-bottom: 16px; font-weight: 700; color: var(--error);">Report Inappropriate Review</h3>
        <p style="font-size: 13.5px; color: var(--text-light); margin-bottom: 16px; line-height: 1.5;">This review will be submitted to the administration for policy violation review. Please provide a reason below.</p>
        <form asp-controller="OrganizerReviews" asp-action="Flag" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="reviewId" id="flagReviewId" />
            <div class="form-group" style="margin-bottom: 20px;">
                <label class="form-label" style="font-weight: 600; font-size: 13px; display: block; margin-bottom: 8px;">Reason for reporting</label>
                <select name="flaggedReason" class="filter-select" style="width: 100%;" required>
                    <option value="">Select a reason...</option>
                    <option value="Spam or misleading content">Spam or misleading content</option>
                    <option value="Harassment or abusive language">Harassment or abusive language</option>
                    <option value="Hate speech">Hate speech</option>
                    <option value="Contains private personal information">Contains private personal information</option>
                    <option value="Off-topic or irrelevant">Off-topic or irrelevant</option>
                </select>
            </div>
            <div style="display: flex; justify-content: flex-end; gap: 10px;">
                <button type="button" class="btn-secondary" onclick="closeFlagModal()">Cancel</button>
                <button type="submit" class="btn-primary" style="background: var(--error);">Submit Report</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openReplyModal(reviewId, name) {
            document.getElementById('replyReviewId').value = reviewId;
            document.getElementById('replyTargetName').innerText = name;
            document.getElementById('replyModal').classList.add('active');
        }

        function closeReplyModal() {
            document.getElementById('replyModal').classList.remove('active');
        }

        function openFlagModal(reviewId) {
            document.getElementById('flagReviewId').value = reviewId;
            document.getElementById('flagModal').classList.add('active');
        }

        function closeFlagModal() {
            document.getElementById('flagModal').classList.remove('active');
        }

        function toggleExportDropdown() {
            const menu = document.getElementById('exportDropdownMenu');
            if (menu) {
                if (menu.style.display === 'none' || !menu.style.display) {
                    menu.style.display = 'block';
                } else {
                    menu.style.display = 'none';
                }
            }
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            var replyModal = document.getElementById('replyModal');
            var flagModal = document.getElementById('flagModal');
            if (event.target == replyModal) {
                closeReplyModal();
            }
            if (event.target == flagModal) {
                closeFlagModal();
            }
            
            const dropdown = document.querySelector('.dropdown');
            if (dropdown && !dropdown.contains(event.target)) {
                const menu = document.getElementById('exportDropdownMenu');
                if (menu) menu.style.display = 'none';
            }
        }
    </script>
}
