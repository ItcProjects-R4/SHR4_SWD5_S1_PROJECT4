@model IEnumerable<Eventify.Domain.Entities.WaitingList>
@using Eventify.Domain.Enums
@{
    ViewData["Title"] = "My Waiting List";
    Layout = "~/Views/Shared/_AttendeeLayout.cshtml";
}

<style>
    .waiting-list-container {
        max-width: 950px;
        margin: 0 auto;
        padding: 20px;
    }

    .list-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(91, 33, 182, 0.08);
        border: 1px solid #e5e7eb;
        padding: 30px;
    }

    .list-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        border-bottom: 1px solid #ede9fe;
        padding-bottom: 16px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .list-header h2 {
        font-size: 24px;
        font-weight: 800;
        color: #5b21b6;
    }

    .list-header p {
        color: #6b7280;
        font-size: 14px;
        margin-top: 4px;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table thead {
        border-bottom: 2px solid #e5e7eb;
    }

    .data-table th {
        padding: 14px 12px;
        text-align: left;
        font-size: 12px;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .data-table td {
        padding: 16px 12px;
        border-bottom: 1px solid #e5e7eb;
        font-size: 14px;
        vertical-align: middle;
    }

    .data-table tbody tr:last-child td {
        border-bottom: none;
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .status-waiting {
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
    }

    .status-notified {
        background: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
    }

    .status-converted {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    .status-expired {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .btn-leave {
        background: transparent;
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
        padding: 6px 12px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: inherit;
    }

    .btn-leave:hover {
        background: #ef4444;
        color: white;
        border-color: #ef4444;
        transform: translateY(-1px);
    }

    .btn-book {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .btn-book:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(16, 185, 129, 0.35);
    }
</style>

<div class="waiting-list-container">
    <div class="list-card">
        <div class="list-header">
            <div>
                <h2>My Waiting List</h2>
                <p>Track waitlists for sold-out events and buy tickets when notified.</p>
            </div>
            <a href="/Events" class="btn-book" style="background: linear-gradient(135deg, #5b21b6 0%, #7c3aed 100%); box-shadow: 0 4px 12px rgba(124, 58, 237, 0.2);">
                <i class="fas fa-search"></i> Explore Events
            </a>
        </div>

        @if (TempData["WaitingListSuccess"] is string successMsg)
        {
            <div style="background: rgba(16, 185, 129, 0.1); border: 1px solid #10b981; color: #10b981; padding: 14px; border-radius: 10px; margin-bottom: 20px; font-size: 14px; font-weight: 600;">
                <i class="fas fa-check-circle" style="margin-right: 8px;"></i> @successMsg
            </div>
        }
        @if (TempData["WaitingListError"] is string errorMsg)
        {
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; color: #ef4444; padding: 14px; border-radius: 10px; margin-bottom: 20px; font-size: 14px; font-weight: 600;">
                <i class="fas fa-exclamation-circle" style="margin-right: 8px;"></i> @errorMsg
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div style="overflow-x: auto;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Event Details</th>
                            <th>Ticket Type</th>
                            <th>Qty Wanted</th>
                            <th>Joined Date</th>
                            <th>Expiry Info</th>
                            <th>Status</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model)
                        {
                            var statusClass = entry.Status switch
                            {
                                WaitingListStatus.Waiting => "status-waiting",
                                WaitingListStatus.Notified => "status-notified",
                                WaitingListStatus.Converted => "status-converted",
                                WaitingListStatus.Expired => "status-expired",
                                _ => ""
                            };

                            <tr>
                                <td>
                                    <div style="font-weight: 700; color: #5b21b6;">@entry.Event.Title</div>
                                    <div style="font-size: 11px; color: #6b7280; margin-top: 2px;">
                                        <i class="fas fa-calendar-alt"></i> @entry.Event.StartDate.ToEgyptTime().ToString("MMM dd, yyyy")
                                    </div>
                                </td>
                                <td>@entry.TicketType.Name</td>
                                <td style="font-weight: 600;">@entry.QuantityWanted</td>
                                <td>@entry.JoinedAt.ToEgyptTime().ToString("MMM dd, yyyy")</td>
                                <td>
                                    @if (entry.Status == WaitingListStatus.Notified && entry.ExpiresAt.HasValue)
                                    {
                                        <div style="color: #ef4444; font-weight: 600; font-size: 12px;">
                                            Expires: @entry.ExpiresAt.Value.ToEgyptTime().ToString("MMM dd, hh:mm tt")
                                        </div>
                                    }
                                    else if (entry.ExpiresAt.HasValue)
                                    {
                                        <div style="color: #9ca3af; font-size: 12px;">
                                            @entry.ExpiresAt.Value.ToEgyptTime().ToString("MMM dd, yyyy")
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="color: #9ca3af; font-style: italic;">No expiry</span>
                                    }
                                </td>
                                <td>
                                    <span class="status-badge @statusClass">
                                        <i class="fas fa-circle" style="font-size: 5px;"></i> @entry.Status.ToString()
                                    </span>
                                </td>
                                <td style="text-align: right; white-space: nowrap;">
                                    @if (entry.Status == WaitingListStatus.Notified)
                                    {
                                        <a href="/Events/Details/@entry.EventId" class="btn-book" style="margin-right: 6px;">
                                            <i class="fas fa-shopping-cart"></i> Book Now
                                        </a>
                                    }
                                    @if (entry.Status == WaitingListStatus.Waiting || entry.Status == WaitingListStatus.Notified)
                                    {
                                        <form asp-controller="WaitingList" asp-action="Leave" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to leave this waiting list?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="waitingListEntryId" value="@entry.Id" />
                                            <button type="submit" class="btn-leave">Leave</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div style="text-align: center; padding: 48px; color: #6b7280;">
                <i class="fas fa-clock" style="font-size: 44px; color: #ede9fe; margin-bottom: 16px;"></i>
                <h3 style="font-size: 18px; font-weight: 700; color: #1f1b2e; margin-bottom: 4px;">Waiting List is Empty</h3>
                <p style="font-size: 14px;">You have not joined any event waiting lists yet.</p>
            </div>
        }
    </div>
</div>
